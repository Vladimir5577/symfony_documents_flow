# Файловое хранилище (MinIO + imgproxy + nginx-кэш) — шаблон переменных.
# Скопировать в .env и заполнить:  cp .env.example .env
# В .env держать реальные значения (он в .gitignore, в репозиторий НЕ попадает).

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=                 # ОБЯЗАТЕЛЬНО задать (особенно в проде)
MINIO_KANBAN_BUCKET=kanban
MINIO_REGION=us-east-1
# Console (веб-админка, localhost). S3 API наружу не публикуется (см. compose).
MINIO_CONSOLE_PORT=9001

# --- imgproxy ---
# Подпись URL: сгенерировать каждый ключ через  openssl rand -hex 32
IMGPROXY_KEY=
IMGPROXY_SALT=
# 1 — подпись ОТКЛЮЧЕНА (только локальная отладка). В проде: 0 + задать KEY/SALT.
IMGPROXY_ALLOW_UNSAFE_URL=1
IMGPROXY_MAX_SRC_RESOLUTION=50
IMGPROXY_LOG_LEVEL=info
# Публичная дверь медиа-стека (попадает в <img src>):
IMGPROXY_CACHE_PORT=8082

# --- Сеть ---
# Имя общей docker-сети. В материнском проекте создаётся основным
# docker-compose.yml (external). При переезде в отдельный репозиторий —
# создать вручную:  docker network create project-net
SHARED_NETWORK=project-net
