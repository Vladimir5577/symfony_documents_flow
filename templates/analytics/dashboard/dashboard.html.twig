                    <div class="cat-bar-row"><span class="cat-bar-label">Сост. контейн. площ.</span><div class="cat-bar-track"><div class="cat-bar-fill" style="width:10%;background:var(--text-muted)"></div></div><span class="cat-bar-val">2</span></div>
