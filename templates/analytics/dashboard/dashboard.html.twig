{#        <span class="ico">📞</span>Жалобы#}
{#    </button>#}
    <button class="bnav-btn" onclick="switchTab('compare');setActiveNav(this)">
        <span class="ico">📊</span>Свод
    </button>
</nav>

<script>
    /* ── DATA ── */
    let dashboardData = {{ dashboardDataJson|raw }};
    let currentTab = 'finance';
    let currentScale = '{{ initialScale|default('month') }}';

    /* ── TABS ── */
    function switchTab(id) {
        currentTab = id;
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('tab-' + id).classList.add('active');
        const btns = document.querySelectorAll('.tab-btn');
        const map = { finance:0, tko:1, hr:2, compare:3 };
        if (btns[map[id]]) btns[map[id]].classList.add('active');
        renderTab(id);
    }

    function setActiveNav(el) {
        document.querySelectorAll('.bnav-btn').forEach(b => b.classList.remove('active'));
        el.classList.add('active');
    }

    function selectFilial(idx, orgId) {
        document.querySelectorAll('.filial-card').forEach(c => c.classList.remove('selected'));
        document.querySelector(`[data-fil="${idx}"]`).classList.add('selected');
        loadDashboardData(orgId);
    }

    /* ── AJAX LOAD ── */
    function loadDashboardData(orgId) {
        fetch('/analytics/dashboard/data?org_id=' + orgId + '&scale=' + currentScale)
            .then(r => r.json())
            .then(data => {
                dashboardData = data;
                renderAllTabs();
                updateHrStats();
            });
    }

    function getSelectedOrgId() {
        const selected = document.querySelector('.filial-card.selected');
        if (!selected) return 0;
        const raw = selected.getAttribute('data-org-id');
        return raw ? parseInt(raw, 10) : 0;
    }

    function setScale(scale) {
        currentScale = (scale === 'week') ? 'week' : 'month';
        const monthBtn = document.getElementById('scaleMonthBtn');
        const weekBtn = document.getElementById('scaleWeekBtn');
        if (monthBtn) monthBtn.classList.toggle('active', currentScale === 'month');
        if (weekBtn) weekBtn.classList.toggle('active', currentScale === 'week');
        loadDashboardData(getSelectedOrgId());
    }

    /* ── CHART.JS DEFAULTS ── */
    Chart.defaults.color = '#8b949e';
    Chart.defaults.borderColor = 'rgba(255,255,255,0.06)';
    Chart.defaults.font.family = "'IBM Plex Sans', sans-serif";
    Chart.defaults.font.size = 11;
    const FILIALS = ['Ф-1','Ф-2','Ф-3','Ф-4','Ф-5','Ф-6'];

    function mkChart(id, cfg) {
        const el = document.getElementById(id);
        if (!el) return;
        if (el._chart) { el._chart.destroy(); el._chart = null; }
        el._chart = new Chart(el, cfg);
    }

    /* ── UPDATE HR STATS ── */
    function updateHrStats() {
        const hr = dashboardData.hr || {};
        const sp = document.getElementById('statStaffPlanned');
        const sa = document.getElementById('statStaffActual');
        const sv = document.getElementById('statVacancies');
        if (sp) sp.textContent = hr.staffPlanned || '--';
        if (sa) sa.textContent = hr.staffActual || '--';
        if (sv) sv.textContent = hr.vacancies || '--';
    }

    /* ── RENDER ── */
    function renderAllTabs() {
        renderTab('finance');
        renderTab('tko');
        renderTab('hr');
        renderTab('compare');
    }

    function renderTab(id) {
        if (chartRenderers[id]) chartRenderers[id]();
    }

    function xLabels() {
        return dashboardData.labels || dashboardData.monthLabels || [];
    }

    const chartRenderers = {
        finance: () => {
            const labels = xLabels();
            const fin = dashboardData.finance || {};
            mkChart('chartCashflow', {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [
                        { label: 'Поступления', data: fin.cashInflow || [], backgroundColor: 'rgba(63,185,80,0.7)', borderRadius: 4 },
                        { label: 'Списания', data: fin.cashOutflow || [], backgroundColor: 'rgba(248,81,73,0.5)', borderRadius: 4 }
                    ]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } }, scales: { y: { ticks: { callback: v => v+'М' } }, x: { stacked: false } } }
            });
        },
        tko: () => {
            const labels = xLabels();
            const tko = dashboardData.tko || {};
            mkChart('chartTko', {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        { label: 'Вывезено, т', data: tko.tkoExport || [], borderColor: '#39c5cf', backgroundColor: 'rgba(57,197,207,0.1)', fill: true, tension: 0.4, pointRadius: 4 }
                    ]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
            });
            mkChart('chartFuelConsumption', {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        { label: 'Расход топлива, л', data: tko.fuelConsumption || [], borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.12)', fill: true, tension: 0.35, pointRadius: 4 }
                    ]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
            });
        },
        hr: () => {
            const labels = xLabels();
            const hr = dashboardData.hr || {};
            mkChart('chartHiringFiring', {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [
                        { label: 'Принято', data: hr.hired || [], backgroundColor: 'rgba(63,185,80,0.7)', borderRadius: 4 },
                        { label: 'Уволено', data: hr.terminated || [], backgroundColor: 'rgba(248,81,73,0.6)', borderRadius: 4 }
                    ]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
            });
        },
        clients: () => {
            const labels = xLabels();
            mkChart('chartBilling', {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [
                        { label: 'Начислено', data: [], backgroundColor: 'rgba(88,166,255,0.6)', borderRadius: 4 },
                        { label: 'Оплачено', data: [], backgroundColor: 'rgba(63,185,80,0.7)', borderRadius: 4 }
                    ]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
            });
            mkChart('chartCollection', {
                type: 'bar',
                data: {
                    labels: FILIALS,
                    datasets: [
                        { label: 'Население, %', data: [], backgroundColor: 'rgba(88,166,255,0.7)', borderRadius: 4 },
                        { label: 'Юрлица, %', data: [], backgroundColor: 'rgba(57,197,207,0.7)', borderRadius: 4 }
                    ]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } }, scales: { y: { min: 60, max: 100, ticks: { callback: v => v+'%' } } } }
            });
            mkChart('chartDebtAge', {
                type: 'doughnut',
                data: {
                    labels: ['До 30 дней','31–60 дней','61–90 дней','Более 90 дней'],
                    datasets: [{ data: [38,22,14,26], backgroundColor: ['#3fb950','#d29922','#f0883e','#f85149'], borderWidth: 0 }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { boxWidth: 10 } } }, cutout: '60%' }
            });
        },
        complaints: () => {
            const labels = xLabels();
            mkChart('chartComplaints', {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        { label: 'Поступило', data: [], borderColor: '#f85149', backgroundColor: 'rgba(248,81,73,0.1)', fill: true, tension: 0.4, pointRadius: 4 },
                        { label: 'Отработано', data: [], borderColor: '#3fb950', backgroundColor: 'rgba(63,185,80,0.05)', fill: true, tension: 0.4, pointRadius: 4 }
                    ]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
            });
            mkChart('chartComplFilial', {
                type: 'bar',
                data: {
                    labels: FILIALS,
                    datasets: [
                        { label: 'Поступило', data: [], backgroundColor: 'rgba(248,81,73,0.6)', borderRadius: 4 },
                        { label: 'Закрыто', data: [], backgroundColor: 'rgba(63,185,80,0.7)', borderRadius: 4 }
                    ]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
            });
        },
        compare: () => {
            renderCompareTable(dashboardData.compare || {});
        }
    };

    /* ── COMPARE TAB ── */
    let compareScale = '{{ initialScale }}';

    function setCompareScale(scale) {
        compareScale = scale;
        document.querySelectorAll('.scale-btn-cmp').forEach(b => b.classList.toggle('active', b.dataset.scale === scale));
        loadCompareData();
    }

    function loadCompareData() {
        const orgId = getSelectedOrgId();
        const sel = document.getElementById('comparePeriodSelect');
        let url = '/analytics/dashboard/compare-data?org_id=' + orgId + '&scale=' + compareScale;
        if (sel && sel.value) {
            const parts = sel.value.split('-');
            url += '&year=' + parts[0] + '&period=' + parts[1];
        }
        fetch(url)
            .then(r => r.json())
            .then(data => {
                dashboardData.compare = data;
                renderCompareTable(data);
            });
    }

    function renderCompareTable(data) {
        const sel = document.getElementById('comparePeriodSelect');
        const tbody = document.getElementById('compareTableBody');
        if (!sel || !tbody) return;

        // Update period selector
        const periods = data.availablePeriods || [];
        const currentVal = sel.value || (data.selectedYear + '-' + data.selectedPeriod);
        sel.innerHTML = '';
        periods.forEach(p => {
            const opt = document.createElement('option');
            opt.value = p.year + '-' + p.period;
            opt.textContent = p.label;
            if (opt.value === String(data.selectedYear) + '-' + String(data.selectedPeriod)) opt.selected = true;
            sel.appendChild(opt);
        });

        // Update table rows
        const rows = data.rows || [];
        tbody.innerHTML = '';
        if (rows.length === 0) {
            tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;color:var(--text-muted);padding:24px">Нет данных за выбранный период</td></tr>';
            return;
        }
        rows.forEach(row => {
            const tr = document.createElement('tr');
            if (row.isTotal) tr.classList.add('hq');
            tr.innerHTML =
                '<td>' + (row.isTotal ? '\uD83C\uDFE2 ' : '') + row.name + '</td>' +
                '<td>' + row.cashInflow + '</td>' +
                '<td>' + row.cashOutflow + '</td>' +
                '<td>' + row.tkoExport.toLocaleString('ru-RU') + '</td>' +
                '<td>' + row.fuelConsumption + '</td>' +
                '<td>' + row.staffPlanned + '</td>' +
                '<td>' + row.staffActual + '</td>' +
                '<td>' + row.hired + '</td>' +
                '<td>' + row.terminated + '</td>';
            tbody.appendChild(tr);
        });
    }

    /* ── INIT ── */
    window.addEventListener('load', () => {
        updateHrStats();
        renderTab('finance');
    });
</script>
</body>
</html>
