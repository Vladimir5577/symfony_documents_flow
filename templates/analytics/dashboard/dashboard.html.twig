<div class="content">

    <!-- FILIAL CARDS -->
    <div class="section-title">Филиалы</div>
    <div class="filial-grid" id="filialGrid">
        {% for organization in organizations %}
            <div class="filial-card {{ loop.first ? 'selected filial-hq' : '' }}" data-fil="{{ loop.index0 }}" data-org-id="{{ organization.id }}" onclick="selectFilial({{ loop.index0 }}, {{ organization.id }})">
                <div class="filial-name">{{ organization.name }}</div>
            </div>
        {% else %}
            <div class="filial-card selected filial-hq" data-fil="0">
                <div class="filial-name">Нет организаций верхнего уровня</div>
            </div>
        {% endfor %}
    </div>

    <!-- TAB NAVIGATION -->
    <div class="tabs-nav" id="tabsNav">
        <button class="tab-btn active" onclick="switchTab('finance')"><span class="ico">💰</span> Финансы</button>
        <button class="tab-btn" onclick="switchTab('tko')"><span class="ico">🚛</span> ТКО</button>
{#        <button class="tab-btn" onclick="switchTab('clients')"><span class="ico">👤</span> Клиенты</button>#}
