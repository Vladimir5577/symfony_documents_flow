{#        <button class="tab-btn" onclick="switchTab('complaints')"><span class="ico">📞</span> Жалобы</button>#}
        <button class="tab-btn" onclick="switchTab('compare')"><span class="ico">📊</span> Сравнение</button>
    </div>

