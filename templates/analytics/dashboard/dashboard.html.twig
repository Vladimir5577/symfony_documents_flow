<body>

<!-- HEADER -->
<header class="header">
    <a class="header-logo" href="/dashboard">
        <span class="org">ГУП ДНР</span>
        <span class="name">Донснабкомплект</span>
    </a>
    <div class="header-meta">
{#        <span class="badge-period">Апрель 2025</span>#}
    </div>
</header>

<div class="content">

    <!-- FILIAL CARDS -->
    <div class="section-title">Филиалы</div>
    <div class="filial-grid" id="filialGrid">
        {% for organization in organizations %}
            <div class="filial-card {{ loop.first ? 'selected filial-hq' : '' }}" data-fil="{{ loop.index0 }}" data-org-id="{{ organization.id }}" onclick="selectFilial({{ loop.index0 }}, {{ organization.id }})">
                <div class="filial-name">{{ organization.name }}</div>
            </div>
        {% else %}
            <div class="filial-card selected filial-hq" data-fil="0">
                <div class="filial-name">Нет организаций верхнего уровня</div>
            </div>
        {% endfor %}
    </div>

    <!-- TAB NAVIGATION -->
    <div class="tabs-nav" id="tabsNav">
        <button class="tab-btn active" onclick="switchTab('finance')"><span class="ico">💰</span> Финансы</button>
        <button class="tab-btn" onclick="switchTab('tko')"><span class="ico">🚛</span> ТКО</button>
{#        <button class="tab-btn" onclick="switchTab('clients')"><span class="ico">👤</span> Клиенты</button>#}
        <button class="tab-btn" onclick="switchTab('hr')"><span class="ico">👥</span> Кадры</button>
{#        <button class="tab-btn" onclick="switchTab('complaints')"><span class="ico">📞</span> Жалобы</button>#}
        <button class="tab-btn" onclick="switchTab('compare')"><span class="ico">📊</span> Сравнение</button>
    </div>
    <div class="tabs-nav" style="margin-top:8px;">
        <button id="scaleMonthBtn" class="tab-btn {{ initialScale == 'month' ? 'active' : '' }}" onclick="setScale('month')">По месяцам</button>
        <button id="scaleWeekBtn" class="tab-btn {{ initialScale == 'week' ? 'active' : '' }}" onclick="setScale('week')">По неделям</button>
    </div>

