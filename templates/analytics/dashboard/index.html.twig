{% extends 'base_dashboard.html.twig' %}

{% block title %}Дашборд{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">Дашборд аналитики</h1>
    </div>

    {# Фильтры #}
    <section class="section">
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Фильтры</h4>
                    </div>
                    <div class="card-body">
                        <form action="{{ path('app_analytics_dashboard') }}" method="get" class="form">
                            <div class="row align-items-end">
                                <div class="col">
                                    <label class="form-label">Доска <span class="text-danger">*</span></label>
                                    <select name="board_id" class="form-select" required>
                                        <option value="0">— Выберите доску —</option>
                                        {% for b in userBoards %}
                                            <option value="{{ b.id }}" {{ selectedBoardId == b.id ? 'selected' : '' }}>{{ b.name }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col">
                                    <label class="form-label">Период</label>
                                    <select name="period_id" class="form-select">
                                        <option value="0">Все периоды</option>
                                        {% for p in periods %}
                                            <option value="{{ p.id }}" {{ selectedPeriodId == p.id ? 'selected' : '' }}>{{ p.description }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-auto">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-search me-1"></i>Применить
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        {% if selectedBoardId and dashboardData %}
            {# Карточки метрик #}
            {% if dashboardData.metrics|length > 0 %}
            <div class="row">
                {% for metric in dashboardData.metrics %}
                <div class="col-lg-4 col-md-6 col-12 mb-3">
                    <div class="card">
                        <div class="card-body">
                            <h6 class="card-title text-muted">{{ metric.name }}</h6>
                            <h2 class="mb-1">
                                {% if metric.value is not null %}
                                    {{ metric.value ~ ' ' ~ metric.unit }}
                                {% else %}
                                    <span class="text-muted">—</span>
                                {% endif %}
                            </h2>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
            {% else %}
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <p class="text-muted mb-0">Нет данных за выбранный период. Убедитесь, что отчёты заполнены и утверждены.</p>
                        </div>
                    </div>
                </div>
            </div>
            {% endif %}
        {% elseif selectedBoardId %}
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <p class="text-muted mb-0">Данные не найдены. Возможно, для выбранной доски ещё нет утверждённых отчётов.</p>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <p class="text-muted mb-0">Выберите доску для просмотра данных дашборда.</p>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
    </section>
{% endblock %}
