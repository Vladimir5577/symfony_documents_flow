{% extends 'base_dashboard.html.twig' %}

{% block title %}Просмотр аналитики ТКО — помесячно{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    <style>
        .tko-polygon-list .list-group-item-action.active {
            background-color: #ffe600;
            border-color: #e6cf00;
            color: #1a1a1a;
            font-weight: 600;
        }
        .tko-grid th, .tko-grid td { vertical-align: middle; white-space: nowrap; }
        .tko-grid .metric-label { font-weight: 600; }
        .tko-grid thead th { text-align: center; }
        .tko-grid td.metric-value { text-align: right; }
        .tko-grid .total-col { background-color: rgba(255, 230, 0, 0.18); font-weight: 600; }
        [data-bs-theme=dark] .tko-grid .total-col { background-color: rgba(255, 230, 0, 0.12); }
        .tko-grid .tko-col-link { color: inherit; text-decoration: none; }
        .tko-grid .tko-col-link:hover { text-decoration: underline; }
        .tko-week-label { font-weight: 600; font-size: 1rem; }
    </style>

    <div class="page-title">
        <div class="row">
            <div class="col-12">
                <h3>Просмотр аналитики ТКО</h3>
                <p class="text-subtitle text-muted">Суммарные данные по месяцам года — клик по месяцу откроет понедельно</p>
            </div>
        </div>
    </div>

    <section class="section">
        <div class="row">
            {% include 'analytics/tko/partials/_polygon_list.html.twig' with {
                route: 'app_analytics_tko_view_month',
                period_param: periodParam,
                period_value: period,
            } %}

            <div class="col-12 col-lg-9 mb-3">
                <div class="card">
                    <div class="card-body">
                        {% include 'analytics/tko/partials/_period_nav.html.twig' with {
                            level: 'month',
                            route: 'app_analytics_tko_view_month',
                            period_param: periodParam,
                        } %}

                        {% if selectedPolygon is null %}
                            <p class="text-muted mb-0">Выберите полигон слева.</p>
                        {% else %}
                            {% include 'analytics/tko/partials/_grid.html.twig' %}
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
