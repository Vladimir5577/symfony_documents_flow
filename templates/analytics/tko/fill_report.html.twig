{% extends 'base_dashboard.html.twig' %}

{% block title %}Аналитика ТКО{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    <style>
        .tko-polygon-list .list-group-item-action.active {
            background-color: #ffe600;
            border-color: #e6cf00;
            color: #1a1a1a;
            font-weight: 600;
        }
        .tko-grid th, .tko-grid td { vertical-align: middle; white-space: nowrap; }
        .tko-grid .metric-label { font-weight: 600; }
        .tko-grid input.form-control { min-width: 90px; }
        .tko-grid .machinery-work-input,
        .tko-grid .timed-event-input { min-width: 180px; }
        .tko-grid thead th { text-align: center; }
        .tko-week-label { font-weight: 600; font-size: 1rem; }
    </style>

    <div class="page-title">
        <div class="row">
            <div class="col-12">
                <h3>Аналитика ТКО</h3>
                <p class="text-subtitle text-muted">Ввод и просмотр суточной отчётности по полигонам</p>
            </div>
        </div>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : (label == 'warning' ? 'warning' : 'success') }} alert-dismissible">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <section class="section">
        <div class="row">
            {# ===== Слева: список полигонов ===== #}
            <div class="col-12 col-lg-3 mb-3">
                <div class="card">
                    <div class="card-header"><h5 class="mb-0">Полигоны</h5></div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush tko-polygon-list" style="max-height: 70vh; overflow-y: auto;">
                            {% for polygon in polygons %}
                                <a href="{{ path('app_analytics_tko', { polygon_id: polygon.id, week: week }) }}"
                                   class="list-group-item list-group-item-action {{ selectedPolygon and polygon.id == selectedPolygon.id ? 'active' : '' }}">
                                    {{ polygon.name }}
                                </a>
                            {% else %}
                                <div class="p-3 text-muted">Нет полигонов.</div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>

            {# ===== Справа: неделя + таблица ===== #}
            <div class="col-12 col-lg-9 mb-3">
                <div class="card">
                    <div class="card-body">
                        {# Навигация по неделям #}
                        <div class="d-flex align-items-center justify-content-center gap-3 mb-4">
                            <a href="{{ path('app_analytics_tko', { polygon_id: selectedPolygon ? selectedPolygon.id : null, week: prevWeek }) }}"
                               class="btn btn-light-secondary btn-sm" title="Предыдущая неделя">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                            <span class="tko-week-label">Период {{ weekLabel }}</span>
                            <a href="{{ path('app_analytics_tko', { polygon_id: selectedPolygon ? selectedPolygon.id : null, week: nextWeek }) }}"
                               class="btn btn-light-secondary btn-sm" title="Следующая неделя">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </div>

                        {% if selectedPolygon is null %}
                            <p class="text-muted mb-0">Выберите полигон слева.</p>
                        {% else %}
                            {# Отдельная форма на каждый день; поля связываются через атрибут form="" #}
                            {% for day in days %}
                                <form id="tko-form-{{ loop.index0 }}" method="post"
                                      action="{{ path('app_analytics_tko_save') }}" class="d-none">
                                    <input type="hidden" name="_token" value="{{ csrf_token('analytics_tko_save') }}">
                                    <input type="hidden" name="polygon_id" value="{{ selectedPolygon.id }}">
                                    <input type="hidden" name="week" value="{{ week }}">
                                    <input type="hidden" name="date" value="{{ day.date }}">
                                </form>
                            {% endfor %}

                            <div class="table-responsive">
                                <table class="table table-bordered tko-grid mb-0">
                                    <thead>
                                        <tr>
                                            <th style="min-width: 180px;">Метрики</th>
                                            {% for day in days %}
                                                <th>{{ day.dow }}<br><small class="text-muted">{{ day.short }}</small></th>
                                            {% endfor %}
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for metric in metrics %}
                                            <tr>
                                                <td class="metric-label">{{ metric.label }}</td>
                                                {% for day in days %}
                                                    <td>
                                                        {% if metric.type == 'num' %}
                                                            <input type="number" step="any" min="0"
                                                                   class="form-control form-control-sm"
                                                                   form="tko-form-{{ loop.index0 }}"
                                                                   name="{{ metric.key }}"
                                                                   value="{{ day.values[metric.key] }}">
                                                        {% else %}
                                                            {% if metric.key == 'machinery_work' %}
                                                                <div class="input-group input-group-sm">
                                                                    <input type="text"
                                                                           class="form-control form-control-sm machinery-work-input"
                                                                           form="tko-form-{{ loop.index0 }}"
                                                                           name="{{ metric.key }}"
                                                                           value="{{ day.values[metric.key] }}">
                                                                    <button type="button"
                                                                            class="btn btn-outline-secondary machinery-work-open"
                                                                            data-bs-toggle="modal"
                                                                            data-bs-target="#machineryWorkModal">
                                                                        <i class="bi bi-list-ul"></i>
                                                                    </button>
                                                                </div>
                                                            {% elseif metric.key in ['smoke', 'fire_without_mchs', 'fire_with_mchs', 'irrigation'] %}
                                                                <div class="input-group input-group-sm">
                                                                    <input type="text"
                                                                           class="form-control form-control-sm timed-event-input"
                                                                           form="tko-form-{{ loop.index0 }}"
                                                                           name="{{ metric.key }}"
                                                                           value="{{ day.values[metric.key] }}">
                                                                    <button type="button"
                                                                            class="btn btn-outline-secondary timed-event-open"
                                                                            data-bs-toggle="modal"
                                                                            data-bs-target="#timedEventModal"
                                                                            data-title="{{ metric.label }}"
                                                                            data-placeholder="Например, {{ metric.label|lower }}">
                                                                        <i class="bi bi-clock"></i>
                                                                    </button>
                                                                </div>
                                                            {% else %}
                                                                <input type="text"
                                                                       class="form-control form-control-sm"
                                                                       form="tko-form-{{ loop.index0 }}"
                                                                       name="{{ metric.key }}"
                                                                       value="{{ day.values[metric.key] }}">
                                                            {% endif %}
                                                        {% endif %}
                                                    </td>
                                                {% endfor %}
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td></td>
                                            {% for day in days %}
                                                <td class="text-center">
                                                    <button type="submit" form="tko-form-{{ loop.index0 }}"
                                                            class="btn btn-primary btn-sm">
                                                        Сохранить
                                                    </button>
                                                </td>
                                            {% endfor %}
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="modal fade" id="machineryWorkModal" tabindex="-1" aria-labelledby="machineryWorkModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="machineryWorkModalLabel">Работа техники</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
                <div class="modal-body">
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-2">
                            <thead>
                                <tr>
                                    <th>Техника</th>
                                    <th style="width: 180px;">Моточасы</th>
                                    <th style="width: 48px;"></th>
                                </tr>
                            </thead>
                            <tbody id="machineryWorkRows"></tbody>
                        </table>
                    </div>
                    <button type="button" class="btn btn-light-secondary btn-sm" id="machineryWorkAddRow">
                        Добавить технику
                    </button>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="button" class="btn btn-primary" id="machineryWorkApply">Применить</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="timedEventModal" tabindex="-1" aria-labelledby="timedEventModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="timedEventModalLabel">Интервал</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
                <div class="modal-body">
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-2">
                            <thead>
                                <tr>
                                    <th>Описание</th>
                                    <th style="width: 140px;">С</th>
                                    <th style="width: 140px;">По</th>
                                    <th style="width: 48px;"></th>
                                </tr>
                            </thead>
                            <tbody id="timedEventRows"></tbody>
                        </table>
                    </div>
                    <button type="button" class="btn btn-light-secondary btn-sm" id="timedEventAddRow">
                        Добавить интервал
                    </button>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="button" class="btn btn-primary" id="timedEventApply">Применить</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const modalElement = document.getElementById('machineryWorkModal');
            const rowsElement = document.getElementById('machineryWorkRows');
            const addRowButton = document.getElementById('machineryWorkAddRow');
            const applyButton = document.getElementById('machineryWorkApply');
            const timedEventModalElement = document.getElementById('timedEventModal');
            const timedEventTitleElement = document.getElementById('timedEventModalLabel');
            const timedEventRowsElement = document.getElementById('timedEventRows');
            const timedEventAddRowButton = document.getElementById('timedEventAddRow');
            const timedEventApplyButton = document.getElementById('timedEventApply');
            let activeInput = null;
            let activeTimedEventInput = null;
            let activeTimedEventPlaceholder = '';

            const addRow = (name = '', hours = '') => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td><input type="text" class="form-control form-control-sm machinery-name" value="${escapeHtml(name)}" placeholder="Например, трактор"></td>
                    <td><input type="number" step="any" min="0" class="form-control form-control-sm machinery-hours" value="${escapeHtml(hours)}" placeholder="0"></td>
                    <td class="text-center">
                        <button type="button" class="btn btn-light-danger btn-sm machinery-row-remove" title="Удалить">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                `;
                rowsElement.appendChild(row);
            };

            const escapeHtml = (value) => String(value)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');

            const parseValue = (value) => {
                const normalized = value.trim();

                if (!normalized) {
                    return [];
                }

                const rows = [];
                const pattern = /(.+?)\s*(?:—|-|:)\s*([\d.,]+)\s*(?:моточас(?:а|ов)?|мч)?(?=\s*(?:;|\n|$|.+?\s*(?:—|-|:)\s*[\d.,]+\s*(?:моточас(?:а|ов)?|мч)?))/gi;
                let match;

                while ((match = pattern.exec(normalized)) !== null) {
                    rows.push({ name: match[1].replace(/^[;\s]+|[;\s]+$/g, ''), hours: match[2].replace(',', '.') });
                }

                if (rows.length > 0) {
                    return rows;
                }

                return normalized
                    .split(/[;\n]+/)
                    .map((part) => part.trim())
                    .filter(Boolean)
                    .map((part) => ({ name: part, hours: '' }));
            };

            document.querySelectorAll('.machinery-work-open').forEach((button) => {
                button.addEventListener('click', () => {
                    activeInput = button.closest('.input-group').querySelector('.machinery-work-input');
                    rowsElement.innerHTML = '';

                    const rows = parseValue(activeInput.value);

                    if (rows.length === 0) {
                        addRow();
                        return;
                    }

                    rows.forEach((row) => addRow(row.name, row.hours));
                });
            });

            const addTimedEventRow = (text = '', from = '', to = '') => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td><input type="text" class="form-control form-control-sm timed-event-text" value="${escapeHtml(text)}" placeholder="${escapeHtml(activeTimedEventPlaceholder)}"></td>
                    <td><input type="text" class="form-control form-control-sm timed-event-from" value="${escapeHtml(from)}" placeholder="00:00" inputmode="numeric" maxlength="5" pattern="[0-2][0-9]:[0-5][0-9]"></td>
                    <td><input type="text" class="form-control form-control-sm timed-event-to" value="${escapeHtml(to)}" placeholder="00:00" inputmode="numeric" maxlength="5" pattern="[0-2][0-9]:[0-5][0-9]"></td>
                    <td class="text-center">
                        <button type="button" class="btn btn-light-danger btn-sm timed-event-row-remove" title="Удалить">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                `;
                timedEventRowsElement.appendChild(row);
            };

            const parseTimedEventValue = (value) => {
                const normalized = value.trim();

                if (!normalized) {
                    return [];
                }

                return normalized
                    .split(/[;\n]+/)
                    .map((part) => part.trim())
                    .filter(Boolean)
                    .map((part) => {
                        const match = part.match(/^(.+?)\s*(?:—|-|:)\s*(\d{2}:\d{2})\s*(?:–|—|-|по)\s*(\d{2}:\d{2})\s*$/i);

                        if (!match) {
                            return { text: part, from: '', to: '' };
                        }

                        return { text: match[1].trim(), from: match[2], to: match[3] };
                    });
            };

            document.querySelectorAll('.timed-event-open').forEach((button) => {
                button.addEventListener('click', () => {
                    activeTimedEventInput = button.closest('.input-group').querySelector('.timed-event-input');
                    activeTimedEventPlaceholder = button.dataset.placeholder || '';
                    timedEventTitleElement.textContent = button.dataset.title || 'Интервал';
                    timedEventRowsElement.innerHTML = '';

                    const rows = parseTimedEventValue(activeTimedEventInput.value);

                    if (rows.length === 0) {
                        addTimedEventRow();
                        return;
                    }

                    rows.forEach((row) => addTimedEventRow(row.text, row.from, row.to));
                });
            });

            timedEventAddRowButton.addEventListener('click', () => addTimedEventRow());

            const normalizeTimeInput = (input) => {
                const digits = input.value.replace(/\D/g, '').slice(0, 4);

                if (digits.length <= 2) {
                    input.value = digits;
                    return;
                }

                input.value = `${digits.slice(0, 2)}:${digits.slice(2)}`;
            };

            timedEventRowsElement.addEventListener('input', (event) => {
                if (event.target.matches('.timed-event-from, .timed-event-to')) {
                    normalizeTimeInput(event.target);
                }
            });

            timedEventRowsElement.addEventListener('click', (event) => {
                const removeButton = event.target.closest('.timed-event-row-remove');

                if (!removeButton) {
                    return;
                }

                removeButton.closest('tr').remove();

                if (timedEventRowsElement.children.length === 0) {
                    addTimedEventRow();
                }
            });

            timedEventApplyButton.addEventListener('click', () => {
                if (!activeTimedEventInput) {
                    return;
                }

                const value = Array.from(timedEventRowsElement.querySelectorAll('tr'))
                    .map((row) => {
                        const text = row.querySelector('.timed-event-text').value.trim();
                        const from = row.querySelector('.timed-event-from').value.trim();
                        const to = row.querySelector('.timed-event-to').value.trim();

                        if (!text && !from && !to) {
                            return null;
                        }

                        if (!from && !to) {
                            return text;
                        }

                        const interval = [from, to].filter(Boolean).join('–');

                        if (!text) {
                            return interval;
                        }

                        return `${text}: ${interval}`;
                    })
                    .filter(Boolean)
                    .join('; ');

                activeTimedEventInput.value = value;
                bootstrap.Modal.getOrCreateInstance(timedEventModalElement).hide();
            });

            addRowButton.addEventListener('click', () => addRow());

            rowsElement.addEventListener('click', (event) => {
                const removeButton = event.target.closest('.machinery-row-remove');

                if (!removeButton) {
                    return;
                }

                removeButton.closest('tr').remove();

                if (rowsElement.children.length === 0) {
                    addRow();
                }
            });

            applyButton.addEventListener('click', () => {
                if (!activeInput) {
                    return;
                }

                const value = Array.from(rowsElement.querySelectorAll('tr'))
                    .map((row) => {
                        const name = row.querySelector('.machinery-name').value.trim();
                        const hours = row.querySelector('.machinery-hours').value.trim();

                        if (!name && !hours) {
                            return null;
                        }

                        if (!hours) {
                            return name;
                        }

                        if (!name) {
                            return `${hours} моточасов`;
                        }

                        return `${name}: ${hours} моточасов`;
                    })
                    .filter(Boolean)
                    .join('; ');

                activeInput.value = value;
                bootstrap.Modal.getOrCreateInstance(modalElement).hide();
            });
        });
    </script>
{% endblock %}
