{% extends 'base_dashboard.html.twig' %}

{% block title %}Сравнительная аналитика{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">Сравнительная аналитика</h1>
    </div>

    <section class="section">
        {# Фильтры #}
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Фильтры</h4>
                    </div>
                    <div class="card-body">
                        <form action="{{ path('app_analytics_chart_show') }}" method="get" class="form">
                            <div class="row align-items-end">
                                <div class="col">
                                    <label class="form-label">Доска <span class="text-danger">*</span></label>
                                    <select name="board_id" class="form-select" onchange="this.form.submit()">
                                        <option value="0">— Выберите доску —</option>
                                        {% for b in boards %}
                                            <option value="{{ b.id }}" {{ selectedBoardId == b.id ? 'selected' : '' }}>{{ b.name }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col">
                                    <label class="form-label">Период</label>
                                    <select name="period_id" class="form-select">
                                        <option value="0">Все периоды</option>
                                        {% for p in periods %}
                                            <option value="{{ p.id }}" {{ selectedPeriodId == p.id ? 'selected' : '' }}>{{ p.description }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-auto">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-search me-1"></i>Применить
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        {% if not board %}
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <p class="text-muted mb-0">Выберите доску для отображения сравнительных данных.</p>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}

        {% if board and comparisonData|length > 0 %}
            {# Собираем все уникальные метрики #}
            {% set allMetrics = [] %}
            {% for orgName, metrics in comparisonData %}
                {% for metricName in metrics|keys %}
                    {% if metricName not in allMetrics %}
                        {% set allMetrics = allMetrics|merge([metricName]) %}
                    {% endif %}
                {% endfor %}
            {% endfor %}

            {# Сравнительная таблица #}
            <div class="row">
                <div class="col-12">
                    <div class="card mb-3">
                        <div class="card-header">
                            <h4 class="card-title">Сравнительная таблица — {{ board.name }}</h4>
                        </div>
                        <div class="card-content">
                            <div class="table-responsive">
                                <table class="table table-bordered table-hover mb-0">
                                    <thead class="table-light">
                                    <tr>
                                        <th>Организация</th>
                                        {% for metricName in allMetrics %}
                                            <th>{{ metricName }}</th>
                                        {% endfor %}
                                    </tr>
                                    </thead>
                                    <tbody>
                                    {% set orgNames = comparisonData|keys %}
                                    {% for orgName in orgNames|sort %}
                                        <tr>
                                            <td><strong>{{ orgName }}</strong></td>
                                            {% for metricName in allMetrics %}
                                                <td>
                                                    {% if comparisonData[orgName][metricName] is defined %}
                                                        {{ comparisonData[orgName][metricName] }}
                                                    {% else %}
                                                        <span class="text-muted">—</span>
                                                    {% endif %}
                                                </td>
                                            {% endfor %}
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {# Графики трендов по метрикам с Chart.js #}
            {% for metricName, orgData in trendData|slice(0, 6) %}
            <div class="row">
                <div class="col-12">
                    <div class="card mb-3">
                        <div class="card-header">
                            <h4 class="card-title">Тренд: {{ metricName }}</h4>
                        </div>
                        <div class="card-body">
                            <canvas id="chart_{{ loop.index }}" height="100"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}

            {# Передаём данные для графиков как JSON, рендерим на чистом JS #}
            {% set chartData = [] %}
            {% for metricName, orgData in trendData|slice(0, 6) %}
                {% set allPeriods = [] %}
                {% for orgName, periodData in orgData %}
                    {% for period in periodData|keys %}
                        {% if period not in allPeriods %}
                            {% set allPeriods = allPeriods|merge([period]) %}
                        {% endif %}
                    {% endfor %}
                {% endfor %}

                {% set datasets = [] %}
                {% set colorList = ['#2962FF', '#E53935', '#43A047', '#FF8F00', '#6A1B9A', '#00ACC1', '#EF5350'] %}
                {% for orgName, periodData in orgData %}
                    {% set values = [] %}
                    {% for period in allPeriods %}
                        {% set val = periodData[period] is defined ? periodData[period] : null %}
                        {% set values = values|merge([val]) %}
                    {% endfor %}
                    {% set datasets = datasets|merge([{
                        'label': orgName,
                        'data': values,
                        'borderColor': colorList[loop.index0 % 7],
                        'backgroundColor': colorList[loop.index0 % 7],
                    }]) %}
                {% endfor %}

                {% set chartData = chartData|merge([{
                    'canvasId': 'chart_' ~ loop.index,
                    'title': metricName,
                    'labels': allPeriods,
                    'datasets': datasets,
                }]) %}
            {% endfor %}

            <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
            <script>
            (function() {
                var charts = {{ chartData|json_encode(constant('JSON_UNESCAPED_UNICODE'))|raw }};

                charts.forEach(function(chart) {
                    var ctx = document.getElementById(chart.canvasId);
                    if (!ctx) return;

                    var datasets = chart.datasets.map(function(ds, i) {
                        return {
                            label: ds.label,
                            data: ds.data,
                            borderColor: ds.borderColor,
                            backgroundColor: ds.borderColor,
                            tension: 0.3,
                            pointRadius: 5,
                            fill: false,
                        };
                    });

                    new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: chart.labels,
                            datasets: datasets,
                        },
                        options: {
                            responsive: true,
                            plugins: {
                                legend: { position: 'bottom' },
                                title: { display: true, text: chart.title }
                            },
                            scales: {
                                y: { beginAtZero: false }
                            }
                        }
                    });
                });
            })();
            </script>
        {% elseif board %}
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <p class="text-muted mb-0">Нет данных для отображения. Убедитесь, что есть утверждённые отчёты за данный период.</p>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
    </section>
{% endblock %}
