{% extends 'base_dashboard.html.twig' %}

{% block title %}Организации и доски{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">Назначение досок организациям</h1>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    <section class="section">
        {# Форма назначения #}
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Назначить доску организации</h4>
                    </div>
                    <div class="card-body">
                        <form action="{{ path('app_analytics_admin_organization_board_create') }}" method="post" class="form">
                            <input type="hidden" name="_token" value="{{ csrf_token('org_board_create') }}">

                            <div class="row align-items-end">
                                <div class="col">
                                    <label class="form-label">Организация <span class="text-danger">*</span></label>
                                    <input type="hidden" id="organization_id" name="organization_id" value="" required>
                                    <div class="input-group">
                                        <input
                                            type="text"
                                            id="org-display"
                                            class="form-control"
                                            readonly
                                            placeholder="— Выберите организацию —"
                                            style="cursor:pointer"
                                            data-bs-toggle="modal"
                                            data-bs-target="#orgPickerModal"
                                        >
                                        <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#orgPickerModal">
                                            <i class="bi bi-building"></i> Выбрать
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary" id="clear-org-btn" style="display:none;">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="col">
                                    <label class="form-label">Доска <span class="text-danger">*</span></label>
                                    <select name="board_id" class="form-select" required>
                                        <option value="">— Выберите доску —</option>
                                        {% for board in boards %}
                                            <option value="{{ board.id }}">{{ board.name }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-auto">
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" name="is_required" id="org_board_required" value="1">
                                        <label class="form-check-label" for="org_board_required">Обязательна</label>
                                    </div>
                                </div>
                                <div class="col-auto">
                                    <button type="submit" class="btn btn-primary">Назначить</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        {# Таблица назначений #}
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Текущие назначения</h4>
                    </div>
                    <div class="card-content">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Организация</th>
                                    <th>Доска</th>
                                    <th>Обязательна</th>
                                    <th>Действия</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% if orgBoards|length > 0 %}
                                    {% for orgBoard in orgBoards %}
                                        <tr>
                                            <td>{{ orgBoard.id }}</td>
                                            <td>{{ orgBoard.organization.name }}</td>
                                            <td>{{ orgBoard.board.name }}</td>
                                            <td>
                                                {% if orgBoard.isRequired %}
                                                    <span class="badge bg-warning">Да</span>
                                                {% else %}
                                                    <span class="badge bg-secondary">Нет</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                <form action="{{ path('app_analytics_admin_organization_board_toggle_required', {id: orgBoard.id}) }}" method="post" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('org_board_toggle_' ~ orgBoard.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-info" title="Переключить обязательность">
                                                        <i class="bi bi-toggle-{{ orgBoard.isRequired ? 'on' : 'off' }}"></i>
                                                    </button>
                                                </form>
                                                <form action="{{ path('app_analytics_admin_organization_board_delete', {id: orgBoard.id}) }}" method="post" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('org_board_delete_' ~ orgBoard.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Открепить доску от организации?')">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">Нет назначений</td>
                                    </tr>
                                {% endif %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div id="org-tree-data" class="d-none">
        {% for org in organizations %}
            <div
                class="org-node"
                data-org-id="{{ org.id }}"
                data-parent-id="{{ org.parent ? org.parent.id : '' }}"
                data-name="{{ org.name }}"
            ></div>
        {% endfor %}
    </div>

    {% include 'analytics/admin/organization_board/partials/_modal_select_organization.html.twig' %}
{% endblock %}
