{% extends 'base_dashboard.html.twig' %}

{% block title %}Метрики аналитики{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">Метрики аналитики</h1>
        <a href="{{ path('app_analytics_admin_metric_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Создать метрику
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    <section class="section">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Список метрик</h4>
                    </div>
                    <div class="card-content">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Бизнес-ключ</th>
                                    <th>Название</th>
                                    <th>Тип</th>
                                    <th>Единица</th>
                                    <th>Агрегация</th>
                                    <th>Активна</th>
                                    <th>Действия</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% if metrics|length > 0 %}
                                    {% for metric in metrics %}
                                        <tr>
                                            <td>{{ metric.id }}</td>
                                            <td><code>{{ metric.businessKey }}</code></td>
                                            <td>{{ metric.name }}</td>
                                            <td>{{ metric.type }}</td>
                                            <td>{{ metric.unit }}</td>
                                            <td>
                                                <span class="badge bg-primary">{{ metric.aggregationType.value }}</span>
                                            </td>
                                            <td>
                                                {% if metric.isActive %}
                                                    <span class="badge bg-success">Да</span>
                                                {% else %}
                                                    <span class="badge bg-secondary">Нет</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                <a href="{{ path('app_analytics_admin_metric_edit', {id: metric.id}) }}" class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <form action="{{ path('app_analytics_admin_metric_delete', {id: metric.id}) }}" method="post" class="d-inline" onsubmit="return confirm('Удалить метрику «{{ metric.name }}»?')">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('metric_delete_' ~ metric.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                {% else %}
                                    <tr>
                                        <td colspan="8" class="text-center text-muted py-4">Метрики пока не созданы</td>
                                    </tr>
                                {% endif %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
