{% extends 'base_dashboard.html.twig' %}

{% block title %}Редактирование v{{ version.versionNumber }} — {{ board.name }}{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Состав метрик — v{{ version.versionNumber }}</h1>
        <a href="{{ path('app_analytics_admin_board_show', {id: board.id}) }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Назад к доске
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    <div class="mb-3">
        Статус:
        {% if version.status.value == 'published' %}
            <span class="badge bg-success">Опубликована</span>
        {% elseif version.status.value == 'archived' %}
            <span class="badge bg-secondary">Архив</span>
        {% else %}
            <span class="badge bg-info">Черновик</span>
        {% endif %}
    </div>

    <section id="multiple-column-form">
        <div class="row match-height">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Метрики доски</h4>
                    </div>
                    <div class="card-content">
                        <div class="card-body">
                            <form action="{{ path('app_analytics_admin_board_version_edit', {boardId: board.id, versionId: version.id}) }}" method="post" class="form">
                                <input type="hidden" name="_token" value="{{ csrf_token('version_edit_' ~ version.id) }}">

                                {% if allMetrics|length > 0 %}
                                    <table class="table table-bordered mb-0">
                                        <thead>
                                        <tr>
                                            <th style="width:40px"></th>
                                            <th style="width:60px">№</th>
                                            <th>Бизнес-ключ</th>
                                            <th>Название</th>
                                            <th>Тип</th>
                                            <th>Единица</th>
                                            <th>Агрегация</th>
                                            <th style="width:80px">Обязательна</th>
                                        </tr>
                                        </thead>
                                        <tbody id="metrics-sortable">
                                        {% set selected_metrics = [] %}
                                        {% set unselected_metrics = [] %}
                                        {% for item in allMetrics %}
                                            {% set is_selected = false %}
                                            {% set is_required = false %}
                                            {% set item_pos = 999 %}
                                            {% for vm in version.versionMetrics %}
                                                {% if vm.metric.id == item.id %}
                                                    {% set is_selected = true %}
                                                    {% set is_required = vm.isRequired %}
                                                    {% set item_pos = vm.position %}
                                                {% endif %}
                                            {% endfor %}
                                            {% if is_selected %}
                                                {% set selected_metrics = selected_metrics|merge([{metric: item, is_required: is_required, position: item_pos}]) %}
                                            {% else %}
                                                {% set unselected_metrics = unselected_metrics|merge([item]) %}
                                            {% endif %}
                                        {% endfor %}

                                        {% for entry in selected_metrics|sort((a, b) => a.position <=> b.position) %}
                                            <tr data-metric-id="{{ entry.metric.id }}">
                                                <td class="drag-handle" style="cursor: grab; text-align: center; vertical-align: middle;">
                                                    <i class="bi bi-grip-vertical" style="font-size: 1.2rem; color: #999;"></i>
                                                </td>
                                                <td>
                                                    <input type="hidden" name="metrics[{{ entry.metric.id }}][position]" class="position-input" value="{{ entry.position }}">
                                                    <span class="position-label">{{ entry.position }}</span>
                                                </td>
                                                <td>
                                                    <div class="form-check">
                                                        <input class="form-check-input metric-toggle" type="checkbox" name="metrics[{{ entry.metric.id }}][enabled]" id="metric_{{ entry.metric.id }}" value="1" checked>
                                                        <label class="form-check-label" for="metric_{{ entry.metric.id }}">
                                                            <code>{{ entry.metric.businessKey }}</code>
                                                        </label>
                                                    </div>
                                                </td>
                                                <td>{{ entry.metric.name }}</td>
                                                <td>{{ entry.metric.type }}</td>
                                                <td>{{ entry.metric.unit }}</td>
                                                <td><span class="badge bg-primary">{{ entry.metric.aggregationType.value }}</span></td>
                                                <td class="text-center">
                                                    <input class="form-check-input" type="checkbox" name="metrics[{{ entry.metric.id }}][is_required]" value="1" {{ entry.is_required ? 'checked' : '' }}>
                                                </td>
                                            </tr>
                                        {% endfor %}

                                        {% for item in unselected_metrics %}
                                            <tr class="text-muted" data-metric-id="{{ item.id }}">
                                                <td></td>
                                                <td>
                                                    <input type="hidden" name="metrics[{{ item.id }}][position]" class="position-input" value="0" disabled>
                                                    <span class="position-label">—</span>
                                                </td>
                                                <td>
                                                    <div class="form-check">
                                                        <input class="form-check-input metric-toggle" type="checkbox" name="metrics[{{ item.id }}][enabled]" id="metric_{{ item.id }}" value="1">
                                                        <label class="form-check-label" for="metric_{{ item.id }}">
                                                            <code>{{ item.businessKey }}</code>
                                                        </label>
                                                    </div>
                                                </td>
                                                <td>{{ item.name }}</td>
                                                <td>{{ item.type }}</td>
                                                <td>{{ item.unit }}</td>
                                                <td><span class="badge bg-primary">{{ item.aggregationType.value }}</span></td>
                                                <td class="text-center">
                                                    <input class="form-check-input" type="checkbox" name="metrics[{{ item.id }}][is_required]" value="1" disabled>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                        </tbody>
                                    </table>
                                {% else %}
                                    <p class="text-muted">Метрики ещё не созданы. <a href="{{ path('app_analytics_admin_metric_new') }}">Создать метрику</a></p>
                                {% endif %}

                                <div class="mt-3 d-flex justify-content-end">
                                    <button type="submit" name="save_metrics" class="btn btn-primary">Сохранить состав</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script src="/front_end/assets/extensions/sortablejs/Sortable.min.js"></script>
    <script>
        (function() {
            var tbody = document.getElementById('metrics-sortable');

            function updatePositions() {
                var rows = tbody.querySelectorAll('tr');
                var pos = 1;
                rows.forEach(function(row) {
                    var cb = row.querySelector('.metric-toggle');
                    var posInput = row.querySelector('.position-input');
                    var posLabel = row.querySelector('.position-label');
                    if (cb && cb.checked) {
                        posInput.value = pos;
                        posInput.disabled = false;
                        posLabel.textContent = pos;
                        pos++;
                    } else if (posInput) {
                        posInput.value = 0;
                        posInput.disabled = true;
                        posLabel.textContent = '—';
                    }
                });
            }

            Sortable.create(tbody, {
                handle: '.drag-handle',
                animation: 150,
                ghostClass: 'table-active',
                onEnd: updatePositions
            });

            tbody.querySelectorAll('.metric-toggle').forEach(function(cb) {
                cb.addEventListener('change', function() {
                    var row = cb.closest('tr');
                    var reqCb = row.querySelector('input[name*="is_required"]');
                    var handle = row.querySelector('.drag-handle');
                    if (cb.checked) {
                        row.classList.remove('text-muted');
                        if (reqCb) reqCb.disabled = false;
                        if (handle) handle.style.cursor = 'grab';
                    } else {
                        row.classList.add('text-muted');
                        if (reqCb) { reqCb.disabled = true; reqCb.checked = false; }
                        if (handle) handle.style.cursor = 'default';
                    }
                    updatePositions();
                });
            });
        })();
    </script>
{% endblock %}
