{% extends 'base_dashboard.html.twig' %}

{% block title %}Редактирование доски — {{ board.name }}{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Редактирование доски</h1>
        <a href="{{ path('app_analytics_admin_board_show', {id: board.id}) }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Назад к доске
        </a>
    </div>

    <section id="multiple-column-form">
        <div class="row match-height">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Параметры доски</h4>
                    </div>
                    <div class="card-content">
                        <div class="card-body">
                            <form action="{{ path('app_analytics_admin_board_edit', {id: board.id}) }}" method="post" class="form">
                                <input type="hidden" name="_token" value="{{ csrf_token('board_edit_' ~ board.id) }}">

                                {% for message in app.flashes('success') %}
                                    <div class="alert alert-success">{{ message }}</div>
                                {% endfor %}

                                {% for message in app.flashes('error') %}
                                    <div class="alert alert-danger">{{ message }}</div>
                                {% endfor %}

                                <div class="row">
                                    <div class="col-md-6 col-12">
                                        <div class="form-group">
                                            <label for="name">Название <span class="text-danger">*</span></label>
                                            <input type="text" id="name" class="form-control" name="name"
                                                   value="{{ board.name }}" required>
                                        </div>
                                    </div>

                                    <div class="col-md-6 col-12">
                                        <div class="form-group">
                                            <label for="period_type">Частота отчётов <span class="text-danger">*</span></label>
                                            <select id="period_type" name="period_type" class="form-select" required
                                                    {{ not can_change_period_type ? 'disabled' : '' }}>
                                                <option value="weekly"  {{ board.periodType.value == 'weekly'  ? 'selected' : '' }}>Еженедельно</option>
                                                <option value="daily"   {{ board.periodType.value == 'daily'   ? 'selected' : '' }}>Ежедневно</option>
                                                <option value="monthly" {{ board.periodType.value == 'monthly' ? 'selected' : '' }}>Ежемесячно</option>
                                            </select>
                                            {% if not can_change_period_type %}
                                                <input type="hidden" name="period_type" value="{{ board.periodType.value }}">
                                                <small class="text-muted">
                                                    <i class="bi bi-lock-fill"></i>
                                                    Частоту нельзя менять: по доске уже есть отчёты.
                                                </small>
                                            {% else %}
                                                <small class="text-muted">Как часто заполняются отчёты для этой доски</small>
                                            {% endif %}
                                        </div>
                                    </div>

                                    <div class="col-md-6 col-12">
                                        <div class="form-group">
                                            <label for="category">Категория <span class="text-danger">*</span></label>
                                            <select id="category" name="category" class="form-select" required
                                                    {{ not can_change_category ? 'disabled' : '' }}>
                                                {% for case in categories %}
                                                    <option value="{{ case.value }}" {{ case.value == board.category.value ? 'selected' : '' }}>
                                                        {{ case.label() }}
                                                    </option>
                                                {% endfor %}
                                            </select>
                                            {% if not can_change_category %}
                                                <input type="hidden" name="category" value="{{ board.category.value }}">
                                                <small class="text-muted">
                                                    <i class="bi bi-lock-fill"></i>
                                                    Категорию нельзя менять: на доске уже есть метрики или отчёты.
                                                </small>
                                            {% else %}
                                                <small class="text-muted">Все метрики на доске должны принадлежать этой категории</small>
                                            {% endif %}
                                        </div>
                                    </div>

                                    <div class="col-md-6 col-12">
                                        <div class="form-group">
                                            <label for="belongs_to_role_id">Роль доступа</label>
                                            <select id="belongs_to_role_id" name="belongs_to_role_id" class="form-select">
                                                <option value="">— не выбрано —</option>
                                                {% for role in roles %}
                                                    <option value="{{ role.id }}"
                                                        {{ board.belongsToRole and board.belongsToRole.id == role.id ? 'selected' : '' }}>
                                                        {{ role.label ?: role.name }}
                                                    </option>
                                                {% endfor %}
                                            </select>
                                            <small class="text-muted">
                                                Пользователи с этой ролью смогут работать с отчётами по данной доске
                                            </small>
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <div class="form-group">
                                            <label for="description">Описание</label>
                                            <textarea id="description" class="form-control" name="description" rows="3">{{ board.description }}</textarea>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12 d-flex justify-content-end">
                                        <button type="submit" class="btn btn-primary me-1 mb-1">Сохранить</button>
                                        <a href="{{ path('app_analytics_admin_board_show', {id: board.id}) }}" class="btn btn-secondary me-1 mb-1">Отмена</a>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
