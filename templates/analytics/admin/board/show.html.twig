{% extends 'base_dashboard.html.twig' %}

{% block title %}Доска: {{ board.name }}{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>{{ board.name }}</h1>
        <div class="d-flex gap-2">
            <a href="{{ path('app_analytics_admin_board_edit', {id: board.id}) }}" class="btn btn-outline-primary">
                <i class="bi bi-pencil me-1"></i>Редактировать
            </a>
            <a href="{{ path('app_analytics_admin_board') }}" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-1"></i>Назад к списку
            </a>
        </div>
    </div>

    {% if board.description %}
        <p class="text-muted mb-3">{{ board.description }}</p>
    {% endif %}

    <div class="mb-3">
        <span class="badge bg-info">
            Частота отчётов:
            {% if board.periodType.value == 'daily' %}Ежедневно
            {% elseif board.periodType.value == 'weekly' %}Еженедельно
            {% elseif board.periodType.value == 'monthly' %}Ежемесячно
            {% endif %}
        </span>
        <span class="badge bg-secondary ms-1">
            Категория: {{ board.category.label() }}
        </span>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    <section class="section">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Версии доски</h4>
                    </div>
                    <div class="card-content">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                <tr>
                                    <th>Версия</th>
                                    <th>Статус</th>
                                    <th>Метрик</th>
                                    <th>Создана</th>
                                    <th>Обновлена</th>
                                    <th>Действия</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for version in board.boardVersions|sort((a, b) => b.versionNumber <=> a.versionNumber) %}
                                    {% set is_active_version = board.activeVersion and board.activeVersion.id == version.id %}
                                    <tr>
                                        <td><strong>v{{ version.versionNumber }}</strong></td>
                                        <td>
                                            <span class="badge {{ is_active_version ? 'bg-success' : 'bg-secondary' }}">
                                                {{ is_active_version ? 'Активная' : 'Неактивная' }}
                                            </span>
                                        </td>
                                        <td>{{ version.versionMetrics|length }}</td>
                                        <td>{{ version.createdAt ? version.createdAt|date('d.m.Y H:i') : '—' }}</td>
                                        <td>{{ version.updatedAt ? version.updatedAt|date('d.m.Y H:i') : '—' }}</td>
                                        <td>
                                            <a href="{{ path('app_analytics_admin_board_version_edit', {boardId: board.id, versionId: version.id}) }}" class="btn btn-sm btn-outline-primary" title="Редактировать состав метрик">
                                                <i class="bi bi-pencil"></i> Состав
                                            </a>

                                            {% if not is_active_version %}
                                                <form action="{{ path('app_analytics_admin_board_publish', {versionId: version.id}) }}" method="post" class="d-inline"
                                                      onsubmit="return confirm('Сделать версию v{{ version.versionNumber }} активной? Новые отчёты будут создаваться по ней.');">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('version_publish_' ~ version.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                                        <i class="bi bi-check-circle"></i> Сделать активной
                                                    </button>
                                                </form>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Клонирование версии #}
        {% if board.boardVersions|length > 0 %}
        <div class="row mt-3">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Создать новую версию</h4>
                    </div>
                    <div class="card-body">
                        <form action="{{ path('app_analytics_admin_board_clone', {id: board.id}) }}" method="post">
                            <input type="hidden" name="_token" value="{{ csrf_token('board_clone_' ~ board.id) }}">

                            <div class="row align-items-end">
                                <div class="col">
                                    <label class="form-label">Копировать состав из версии</label>
                                    <select name="source_version_id" class="form-select">
                                        {% for v in board.boardVersions %}
                                            {% set is_active_source = board.activeVersion and v.id == board.activeVersion.id %}
                                            <option value="{{ v.id }}"
                                                {% if is_active_source %}selected{% endif %}>
                                                v{{ v.versionNumber }} ({{ is_active_source ? 'активная' : 'неактивная' }})
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-auto">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-files me-1"></i>Клонировать
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
    </section>
{% endblock %}
