{% extends 'base_dashboard.html.twig' %}

{% block title %}Организации аналитики{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">Организации аналитики</h1>
        <a href="{{ path('app_analytics_admin_organization_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Добавить организацию
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    <section class="section">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Список организаций</h4>
                    </div>
                    <div class="card-content">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Организация</th>
                                    <th>Порядок сортировки</th>
                                    <th>Видимость</th>
                                    <th>Действия</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% if organizations|length > 0 %}
                                    {% for org in organizations %}
                                        <tr>
                                            <td>{{ org.id }}</td>
                                            <td>{{ org.organization.name }}</td>
                                            <td>{{ org.sortOrder }}</td>
                                            <td>
                                                {% if org.visible %}
                                                    <span class="badge bg-success">Да</span>
                                                {% else %}
                                                    <span class="badge bg-secondary">Нет</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                <a href="{{ path('app_analytics_admin_organization_edit', {id: org.id}) }}" class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <form action="{{ path('app_analytics_admin_organization_delete', {id: org.id}) }}" method="post" class="d-inline" onsubmit="return confirm('Удалить организацию «{{ org.organization.name }}» из аналитики?')">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('organization_delete_' ~ org.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">Организации пока не добавлены</td>
                                    </tr>
                                {% endif %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
