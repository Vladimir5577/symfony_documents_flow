{% extends 'base_dashboard.html.twig' %}

{% block title %}Редактирование организации{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Редактирование организации</h1>
        <a href="{{ path('app_analytics_admin_organization_index') }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Назад к списку
        </a>
    </div>

    <section id="multiple-column-form">
        <div class="row match-height">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Форма редактирования организации</h4>
                    </div>
                    <div class="card-content">
                        <div class="card-body">
                            <form action="{{ path('app_analytics_admin_organization_edit', {id: analyticsOrg.id}) }}" method="post" class="form">
                                <input type="hidden" name="_token" value="{{ csrf_token('organization_edit_' ~ analyticsOrg.id) }}">

                                {% for message in app.flashes('success') %}
                                    <div class="alert alert-success">{{ message }}</div>
                                {% endfor %}

                                {% for message in app.flashes('error') %}
                                    <div class="alert alert-danger">{{ message }}</div>
                                {% endfor %}

                                <div class="row">
                                    <div class="col-md-6 col-12">
                                        <div class="form-group">
                                            <label for="analytics-org-display">Организация <span class="text-danger">*</span></label>
                                            <input type="hidden" id="analytics_organization_id" name="organization_id" value="{{ analyticsOrg.organization.id }}" required>
                                            <div class="input-group">
                                                <input type="text" id="analytics-org-display" class="form-control" readonly placeholder="— Выберите организацию —" value="{{ analyticsOrg.organization.name }}" style="cursor:pointer" data-bs-toggle="modal" data-bs-target="#analyticsOrgPickerModal">
                                                <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#analyticsOrgPickerModal">
                                                    <i class="bi bi-building"></i> Выбрать
                                                </button>
                                                <button type="button" class="btn btn-outline-secondary" id="analytics-org-clear-btn" style="display:none;">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6 col-12">
                                        <div class="form-group">
                                            <label for="sort_order">Порядок сортировки <span class="text-danger">*</span></label>
                                            <input type="number" id="sort_order" class="form-control" name="sort_order" value="{{ analyticsOrg.sortOrder }}" required>
                                            <small class="form-text text-muted">Чем меньше число, тем выше в списке</small>
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="is_visible" name="is_visible" value="1" {{ analyticsOrg.visible ? 'checked' : '' }}>
                                            <label class="form-check-label" for="is_visible">Видима на дашборде</label>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12 d-flex justify-content-end">
                                        <button type="submit" class="btn btn-primary me-1 mb-1">Сохранить изменения</button>
                                        <a href="{{ path('app_analytics_admin_organization_index') }}" class="btn btn-secondary me-1 mb-1">Отмена</a>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div id="analytics-org-tree-data" class="d-none">
        {% for org in allOrganizations %}
            <div class="org-node"
                 data-org-id="{{ org.id }}"
                 data-parent-id="{{ org.parent ? org.parent.id : '' }}"
                 data-name="{{ org.name }}"></div>
        {% endfor %}
    </div>

    {% include 'analytics/admin/organization/partials/_org_tree_modal.html.twig' %}
    {% include 'analytics/admin/organization/partials/_org_tree_modal_script.html.twig' %}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var clearBtn = document.getElementById('analytics-org-clear-btn');
            var hiddenInput = document.getElementById('analytics_organization_id');
            var displayInput = document.getElementById('analytics-org-display');
            if (!clearBtn || !hiddenInput || !displayInput) return;

            function updateClearBtn() {
                clearBtn.style.display = hiddenInput.value ? '' : 'none';
            }

            clearBtn.addEventListener('click', function () {
                hiddenInput.value = '';
                displayInput.value = '';
                updateClearBtn();
                var tree = document.getElementById('analytics-org-tree');
                if (tree) {
                    var sel = tree.querySelector('.org-tree-item.selected');
                    if (sel) sel.classList.remove('selected');
                }
                var selectBtn = document.getElementById('analytics-org-select-btn');
                if (selectBtn) selectBtn.disabled = true;
            });

            var modal = document.getElementById('analyticsOrgPickerModal');
            if (modal) {
                modal.addEventListener('hidden.bs.modal', function () {
                    updateClearBtn();
                });
            }

            updateClearBtn();
        });
    </script>
{% endblock %}
