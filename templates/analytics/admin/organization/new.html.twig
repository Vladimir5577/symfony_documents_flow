{% extends 'base_dashboard.html.twig' %}

{% block title %}Добавить организацию{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Добавление организации</h1>
        <a href="{{ path('app_analytics_admin_organization_index') }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Назад к списку
        </a>
    </div>

    <section id="multiple-column-form">
        <div class="row match-height">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Форма добавления организации</h4>
                    </div>
                    <div class="card-content">
                        <div class="card-body">
                            <form action="{{ path('app_analytics_admin_organization_new') }}" method="post" class="form">
                                <input type="hidden" name="_token" value="{{ csrf_token('organization_new') }}">

                                {% for message in app.flashes('success') %}
                                    <div class="alert alert-success">{{ message }}</div>
                                {% endfor %}

                                {% for message in app.flashes('error') %}
                                    <div class="alert alert-danger">{{ message }}</div>
                                {% endfor %}

                                <div class="row">
                                    <div class="col-md-6 col-12">
                                        <div class="form-group">
                                            <label for="organization_id">Организация <span class="text-danger">*</span></label>
                                            <select id="organization_id" class="form-control" name="organization_id" required>
                                                <option value="">— Выберите организацию —</option>
                                                {% for org in allOrganizations %}
                                                    <option value="{{ org.id }}">{{ org.name }}</option>
                                                {% endfor %}
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-6 col-12">
                                        <div class="form-group">
                                            <label for="sort_order">Порядок сортировки <span class="text-danger">*</span></label>
                                            <input type="number" id="sort_order" class="form-control" name="sort_order" value="0" required>
                                            <small class="form-text text-muted">Чем меньше число, тем выше в списке</small>
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="is_visible" name="is_visible" value="1" checked>
                                            <label class="form-check-label" for="is_visible">Видима на дашборде</label>
                                        </div>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-12 d-flex justify-content-end">
                                        <button type="submit" class="btn btn-primary me-1 mb-1">Добавить организацию</button>
                                        <a href="{{ path('app_analytics_admin_organization_index') }}" class="btn btn-secondary me-1 mb-1">Отмена</a>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
