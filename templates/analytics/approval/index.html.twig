{% extends 'base_dashboard.html.twig' %}

{% block title %}Утверждение отчётов{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">Утверждение отчётов</h1>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    {% if stats|length > 0 %}
    <div class="row mb-4">
        {% for item in stats %}
        <div class="col-md-4 col-12">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <h5 class="mb-1">{{ item.organization }}</h5>
                            <span class="text-muted">{{ item.pending }} отчётов на утверждении</span>
                        </div>
                        <span class="badge bg-warning rounded-pill">{{ item.pending }}</span>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

    <section class="section">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Отчёты на утверждение</h4>
                    </div>
                    <div class="card-content">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Организация</th>
                                    <th>Доска</th>
                                    <th>Период</th>
                                    <th>Версия</th>
                                    <th>Создан</th>
                                    <th>Действия</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% if pendingReports|length > 0 %}
                                    {% for report in pendingReports %}
                                        <tr>
                                            <td>{{ report.id }}</td>
                                            <td>{{ report.organization.name }}</td>
                                            <td>{{ report.board.name }}</td>
                                            <td>{{ report.period ? report.period.description : '—' }}</td>
                                            <td>v{{ report.boardVersion.versionNumber }}</td>
                                            <td>{{ report.createdAt ? report.createdAt|date('d.m.Y H:i') : '—' }}</td>
                                            <td>
                                                <a href="{{ path('app_analytics_report_fill', {id: report.id}) }}" class="btn btn-sm btn-outline-info" target="_blank">
                                                    <i class="bi bi-eye"></i> Просмотр
                                                </a>
                                                <form action="{{ path('app_analytics_approval_approve', {id: report.id}) }}" method="post" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('report_approve_' ~ report.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-success" onclick="return confirm('Утвердить отчёт #{{ report.id }}?');">
                                                        <i class="bi bi-check-circle"></i> Утвердить
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                {% else %}
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-4">Нет отчётов на утверждение</td>
                                    </tr>
                                {% endif %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
