{% extends 'base_dashboard.html.twig' %}

{% block title %}Мои отчёты{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    <style>
        .report-row-clickable {
            cursor: pointer;
        }
    </style>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">Мои отчёты</h1>
        <a href="{{ path('app_analytics_report_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Новый отчёт
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    <section class="section">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Список отчётов</h4>
                    </div>
                    <div class="card-content">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Доска</th>
                                    <th>Период</th>
                                    <th>Версия</th>
                                    <th>Статус</th>
                                    <th>Создан</th>
                                    <th>Действия</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% if reports|length > 0 %}
                                    {% for report in reports %}
                                        <tr class="report-row-clickable" onclick="window.location.href='{{ path('app_analytics_report_view', {id: report.id}) }}'">
                                            <td>{{ report.id }}</td>
                                            <td>{{ report.board.name }}</td>
                                            <td>{{ report.period ? report.period.displayLabel : '—' }}</td>
                                            <td>v{{ report.boardVersion.versionNumber }}</td>
                                            <td>
                                                {% if report.status.value == 'draft' %}
                                                    <span class="badge bg-info">Черновик</span>
                                                {% else %}
                                                    <span class="badge bg-success">Подтверждён</span>
                                                {% endif %}
                                            </td>
                                            <td>{{ report.createdAt ? report.createdAt|date('d.m.Y H:i') : '—' }}</td>
                                            <td>
                                                {% if report.status.value == 'draft' %}
                                                    <a href="{{ path('app_analytics_report_fill', {id: report.id}) }}" class="btn btn-sm btn-outline-primary">
                                                        <i class="bi bi-pencil"></i> Редактировать
                                                    </a>
                                                    {% if is_granted('ROLE_MANAGER') %}
                                                        <form action="{{ path('app_analytics_report_confirm', {id: report.id}) }}" method="post" class="d-inline">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('report_confirm_' ~ report.id) }}">
                                                            <button type="submit" class="btn btn-sm btn-outline-success" onclick="return confirm('Подтвердить отчёт #{{ report.id }}?');">
                                                                <i class="bi bi-check-circle"></i> Подтвердить
                                                            </button>
                                                        </form>
                                                        <form action="{{ path('app_analytics_report_delete', {id: report.id}) }}" method="post" class="d-inline">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('report_delete_' ~ report.id) }}">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Удалить черновик отчёта?')">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        </form>
                                                    {% endif %}
                                                {% else %}
                                                    {% if is_granted('ROLE_ADMIN') %}
                                                        <a href="{{ path('app_analytics_report_fill', {id: report.id}) }}" class="btn btn-sm btn-outline-primary">
                                                            <i class="bi bi-pencil"></i> Редактировать
                                                        </a>
                                                        <form action="{{ path('app_analytics_report_delete', {id: report.id}) }}" method="post" class="d-inline">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('report_delete_' ~ report.id) }}">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Удалить подтверждённый отчёт?')">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        </form>
                                                    {% else %}
                                                        <span class="text-muted">Подтверждён</span>
                                                    {% endif %}
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                {% else %}
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-4">Отчётов пока нет</td>
                                    </tr>
                                {% endif %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
