{% extends 'base_dashboard.html.twig' %}

{% block title %}Просмотр отчёта: {{ report.board.name }} — {{ report.period ? report.period.displayLabel : '—' }}{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% import 'analytics/report/_metric_notes_view.html.twig' as notesView %}

{% block main %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>Просмотр отчёта</h1>
            <p class="text-muted mb-0">{{ report.board.name }} — {{ report.period ? report.period.displayLabel : '—' }} (v{{ report.boardVersion.versionNumber }})</p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_analytics_report_export_excel', {id: report.id}) }}" class="btn btn-success">
                <i class="bi bi-file-earmark-excel me-1"></i>Выгрузить в Excel
            </a>
            <a href="{{ path('app_analytics_report') }}" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-1"></i>Назад к списку
            </a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    <div class="mb-3">
        Статус:
        {% if report.status.value == 'draft' %}
            <span class="badge bg-info">Черновик</span>
        {% else %}
            <span class="badge bg-success">Подтверждён</span>
        {% endif %}
    </div>

    <style>
        .metric-notes-view-list { padding-left: 18px; font-size: 0.875rem; margin-top: 0; margin-bottom: 0; }
        .metric-notes-view-list ul { padding-left: 18px; }
        .metrics-view-table td.metric-cell { vertical-align: middle; }
        .metrics-view-table .child-indicator { color: #adb5bd; margin-right: 6px; }
        .metrics-view-table td.metric-notes-cell { background: #fafbfc; padding: 8px 12px; }
    </style>

    <section>
        <div class="row match-height">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Метрики</h4>
                    </div>
                    <div class="card-content">
                        <div class="card-body">
                            <table class="table table-bordered metrics-view-table">
                                <thead>
                                <tr>
                                    <th>Метрика</th>
                                    <th>Тип</th>
                                    <th>Ед. изм.</th>
                                    <th>Значение</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for entry in versionMetricsFlat %}
                                    {% set vm = entry.versionMetric %}
                                    {% set metric = entry.metric %}
                                    {% set value = currentValues[vm.id] ?? '' %}
                                    {% set nodes = currentNotes[vm.id] ?? [] %}
                                    <tr data-depth="{{ entry.depth }}">
                                        <td class="metric-cell" style="padding-left: {{ 12 + entry.depth * 40 }}px;">
                                            {% if entry.depth > 0 %}<i class="bi bi-arrow-return-right child-indicator"></i>{% endif %}
                                            <strong>{{ metric.name }}</strong>
                                            {% if vm.required %}<span class="text-danger">*</span>{% endif %}
                                        </td>
                                        <td>{{ metric.type }}</td>
                                        <td>{{ metric.unit }}</td>
                                        <td>
                                            {% if metric.type == 'bool' %}
                                                {% if value == '1' %}
                                                    Да
                                                {% elseif value == '0' %}
                                                    Нет
                                                {% else %}
                                                    —
                                                {% endif %}
                                            {% else %}
                                                {{ value is not empty ? value : '—' }}
                                            {% endif %}
                                        </td>
                                    </tr>
                                    {% if nodes is iterable and nodes|length > 0 %}
                                        <tr class="metric-notes-row-view">
                                            <td colspan="4" class="metric-notes-cell" style="padding-left: {{ 12 + entry.depth * 40 }}px;">
                                                {{ notesView.renderList(nodes) }}
                                            </td>
                                        </tr>
                                    {% endif %}
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
