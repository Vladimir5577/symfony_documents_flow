{#
    Редактируемое дерево пояснений (ключ — значение, с вложенностью)
    для метрик отчёта аналитики. Используется в fill_new.html.twig и fill.html.twig.

    На каждую метрику в HTML рендерится:
      1. Кнопка-toggle (внутри ячейки значения метрики).
      2. Скрытый <tr class="metric-notes-row" data-vm-id data-initial>.
      3. Скрытый <input type="hidden" name="notes[vmId]">.

    JS читает data-initial, рисует дерево внутри tr, синкает hidden input на каждое изменение.
#}

{% macro toggleButton(vmId) %}
    <button type="button" class="btn btn-sm btn-outline-secondary metric-notes-toggle"
            data-target-vm="{{ vmId }}">
        <i class="bi bi-list-nested me-1"></i>Добавить описание
    </button>
{% endmacro %}

{% macro row(vmId, initial, colspan = 4) %}
    <tr class="metric-notes-row" data-vm-id="{{ vmId }}"
        data-initial="{{ (initial ?? [])|json_encode|e('html_attr') }}" hidden>
        <td colspan="{{ colspan }}" class="metric-notes-cell">
            <div class="metric-notes-container"></div>
            <input type="hidden" name="notes[{{ vmId }}]" value="">
        </td>
    </tr>
{% endmacro %}

<style>
    .metric-notes-cell { background: #fafbfc; }
    .metric-notes-container { padding: 8px 4px; }
    .metric-notes-node { display: flex; align-items: center; gap: 6px; margin-bottom: 6px; }
    .metric-notes-node .metric-notes-key,
    .metric-notes-node .metric-notes-value { flex: 1 1 0; min-width: 0; }
    .metric-notes-actions { display: flex; gap: 4px; flex: 0 0 auto; }
    .metric-notes-children { margin-left: 24px; border-left: 2px solid #e9ecef; padding-left: 10px; }
    .metric-notes-empty { color: #6c757d; font-size: 0.875rem; padding: 4px 0; }
</style>

<script>
(function () {
    var MAX_DEPTH = 5;

    function parseInitial(tr) {
        var raw = tr.getAttribute('data-initial');
        if (!raw) return [];
        try {
            var parsed = JSON.parse(raw);
            return Array.isArray(parsed) ? parsed : [];
        } catch (e) {
            return [];
        }
    }

    function readonlyFromForm(form) {
        return form && form.dataset && form.dataset.notesReadonly === '1';
    }

    function createNode(initial) {
        return {
            key: (initial && typeof initial.key === 'string') ? initial.key : '',
            value: (initial && typeof initial.value === 'string') ? initial.value : '',
            children: (initial && Array.isArray(initial.children))
                ? initial.children.map(createNode)
                : [],
        };
    }

    function serializeTree(nodes) {
        var result = [];
        for (var i = 0; i < nodes.length; i++) {
            var n = nodes[i];
            var key = (n.key || '').trim();
            var val = (n.value || '').trim();
            var children = serializeTree(n.children || []);
            if (key === '' && val === '' && children.length === 0) continue;
            result.push({ key: key, value: val, children: children });
        }
        return result;
    }

    function renderTree(container, nodes, depth, readonly, sync) {
        container.innerHTML = '';

        if (nodes.length === 0 && depth === 0) {
            var empty = document.createElement('div');
            empty.className = 'metric-notes-empty';
            empty.textContent = 'Нет пунктов.';
            container.appendChild(empty);
        }

        for (var i = 0; i < nodes.length; i++) {
            renderNode(container, nodes, i, depth, readonly, sync);
        }

        // На корне — кнопка всегда; на дочерних уровнях — только когда уже есть хотя бы
        // один пункт (для первого подпункта используется кнопка ↳ у родителя).
        if (!readonly && (depth === 0 || nodes.length > 0)) {
            var addBtn = document.createElement('button');
            addBtn.type = 'button';
            addBtn.className = 'btn btn-sm btn-outline-primary mt-1';
            addBtn.innerHTML = '<i class="bi bi-plus"></i> Добавить пункт';
            addBtn.addEventListener('click', function () {
                nodes.push(createNode());
                renderTree(container, nodes, depth, readonly, sync);
                sync();
            });
            container.appendChild(addBtn);
        }
    }

    function renderNode(container, siblings, index, depth, readonly, sync) {
        var node = siblings[index];

        var wrap = document.createElement('div');
        wrap.className = 'metric-notes-node-wrap';

        var row = document.createElement('div');
        row.className = 'metric-notes-node';

        var keyInput = document.createElement('input');
        keyInput.type = 'text';
        keyInput.className = 'form-control form-control-sm metric-notes-key';
        keyInput.placeholder = 'Ключ';
        keyInput.maxLength = 500;
        keyInput.value = node.key;
        keyInput.disabled = readonly;
        keyInput.addEventListener('input', function () { node.key = keyInput.value; sync(); });
        row.appendChild(keyInput);

        var valInput = document.createElement('input');
        valInput.type = 'text';
        valInput.className = 'form-control form-control-sm metric-notes-value';
        valInput.placeholder = 'Значение';
        valInput.maxLength = 500;
        valInput.value = node.value;
        valInput.disabled = readonly;
        valInput.addEventListener('input', function () { node.value = valInput.value; sync(); });
        row.appendChild(valInput);

        if (!readonly) {
            var actions = document.createElement('div');
            actions.className = 'metric-notes-actions';

            if (depth + 1 < MAX_DEPTH) {
                var childBtn = document.createElement('button');
                childBtn.type = 'button';
                childBtn.className = 'btn btn-sm btn-outline-secondary';
                childBtn.title = 'Добавить вложенный';
                childBtn.innerHTML = '<i class="bi bi-arrow-return-right"></i>';
                childBtn.addEventListener('click', function () {
                    node.children.push(createNode());
                    renderTree(container, siblings, depth, readonly, sync);
                    sync();
                });
                actions.appendChild(childBtn);
            }

            var delBtn = document.createElement('button');
            delBtn.type = 'button';
            delBtn.className = 'btn btn-sm btn-outline-danger';
            delBtn.title = 'Удалить';
            delBtn.innerHTML = '<i class="bi bi-x"></i>';
            delBtn.addEventListener('click', function () {
                siblings.splice(index, 1);
                renderTree(container, siblings, depth, readonly, sync);
                sync();
            });
            actions.appendChild(delBtn);

            row.appendChild(actions);
        }

        wrap.appendChild(row);

        if (node.children.length > 0 || (!readonly && depth + 1 < MAX_DEPTH)) {
            var childContainer = document.createElement('div');
            childContainer.className = 'metric-notes-children';
            wrap.appendChild(childContainer);
            renderTree(childContainer, node.children, depth + 1, readonly, sync);
        }

        container.appendChild(wrap);
    }

    function initRow(tr) {
        var container = tr.querySelector('.metric-notes-container');
        var hidden = tr.querySelector('input[type="hidden"][name^="notes["]');
        if (!container || !hidden) return;

        var form = tr.closest('form');
        var readonly = readonlyFromForm(form);

        var nodes = parseInitial(tr).map(createNode);

        function sync() {
            hidden.value = JSON.stringify(serializeTree(nodes));
        }

        function render() {
            renderTree(container, nodes, 0, readonly, sync);
        }

        render();
        sync();

        // Если в инициальных данных уже что-то есть — сразу разворачиваем
        if (nodes.length > 0) {
            tr.hidden = false;
        }

        // Публичный хук для toggle: при первом открытии — добавить пустую ноду,
        // чтобы пользователь сразу видел поля «ключ — значение».
        tr.__metricNotesEnsureRow = function () {
            if (readonly) return;
            if (nodes.length === 0) {
                nodes.push(createNode());
                render();
                sync();
            }
        };
    }

    function initToggle(btn) {
        btn.addEventListener('click', function () {
            var vmId = btn.getAttribute('data-target-vm');
            var tr = document.querySelector('tr.metric-notes-row[data-vm-id="' + vmId + '"]');
            if (!tr) return;
            var willOpen = tr.hidden;
            tr.hidden = !tr.hidden;
            if (willOpen && typeof tr.__metricNotesEnsureRow === 'function') {
                tr.__metricNotesEnsureRow();
            }
        });
    }

    function init() {
        var rows = document.querySelectorAll('tr.metric-notes-row');
        for (var i = 0; i < rows.length; i++) initRow(rows[i]);

        var toggles = document.querySelectorAll('.metric-notes-toggle');
        for (var j = 0; j < toggles.length; j++) initToggle(toggles[j]);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }
})();
</script>
