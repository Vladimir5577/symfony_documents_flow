{% extends 'base_dashboard.html.twig' %}

{% block title %}Создание отчёта{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    <style>
        .board-choice-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 0.75rem;
        }
        .board-choice {
            border: 1px solid rgba(130, 146, 167, 0.28);
            border-radius: 0.6rem;
            padding: 0.9rem 1rem;
            cursor: pointer;
            transition: border-color .2s, box-shadow .2s, background-color .2s;
        }
        .board-choice:hover {
            border-color: rgba(67, 94, 190, 0.55);
            background-color: rgba(67, 94, 190, 0.04);
        }
        .board-choice-input:checked + .board-choice {
            border-color: rgba(67, 94, 190, 0.9);
            box-shadow: 0 0 0 2px rgba(67, 94, 190, 0.18);
            background-color: rgba(67, 94, 190, 0.08);
        }
    </style>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Создание отчёта</h1>
        <a href="{{ path('app_analytics_report') }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Назад к списку
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    <section id="multiple-column-form">
        <div class="row match-height">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Выберите доску для отчёта</h4>
                    </div>
                    <div class="card-content">
                        <div class="card-body">
                            {% if orgBoards|length > 0 %}
                                <div class="form-group">
                                    <label class="form-label">Доска <span class="text-danger">*</span></label>
                                    <div class="small text-muted mb-2">Нажмите на карточку, чтобы перейти к заполнению. Отчёт будет создан только после первого сохранения данных.</div>
                                    <div class="board-choice-list mt-2">
                                        {% for orgBoard in orgBoards %}
                                            <a href="{{ path('app_analytics_report_fill_new', {board_id: orgBoard.board.id}) }}" class="board-choice text-decoration-none text-reset">
                                                <div class="d-flex justify-content-between align-items-start gap-2">
                                                    <div>
                                                        <div class="fw-semibold">{{ orgBoard.board.name }}</div>
                                                        <div class="small text-muted">
                                                            Назначена: {{ orgBoard.organization.name }}
                                                        </div>
                                                    </div>
                                                    {% if orgBoard.required %}
                                                        <span class="badge bg-warning text-dark">Обязательная</span>
                                                    {% endif %}
                                                </div>
                                            </a>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% else %}
                                <p class="text-muted">Вам не назначено ни одной доски с опубликованной версией. Обратитесь к администратору.</p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
