{% extends 'base_dashboard.html.twig' %}

{% block title %}Сертификаты УЦ{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">Сертификаты УЦ</h1>
        <a href="{{ path('app_admin_certificates_issue') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Выпустить сертификат
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    <div class="mb-3">
        <div class="btn-group" role="group" aria-label="Фильтр по статусу">
            <a href="{{ path('app_admin_certificates') }}"
               class="btn btn-sm {{ status_filter is null ? 'btn-secondary' : 'btn-outline-secondary' }}">Все</a>
            <a href="{{ path('app_admin_certificates', {status: 'active'}) }}"
               class="btn btn-sm {{ status_filter == 'active' ? 'btn-secondary' : 'btn-outline-secondary' }}">Активные</a>
            <a href="{{ path('app_admin_certificates', {status: 'revoked'}) }}"
               class="btn btn-sm {{ status_filter == 'revoked' ? 'btn-secondary' : 'btn-outline-secondary' }}">Отозванные</a>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            {% if certificates is empty %}
                <p class="text-muted mb-0">Сертификатов нет.</p>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                        <tr>
                            <th>Пользователь</th>
                            <th>Серийный номер</th>
                            <th>Срок действия</th>
                            <th>Статус</th>
                            <th>Кем выпущен</th>
                            <th class="text-end">Действия</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for cert in certificates %}
                            {% set is_expired = cert.validTo < now %}
                            {% set is_expiring = not is_expired and cert.validTo < expiring_threshold %}
                            {% set is_active = cert.status.value == 'active' %}
                            <tr class="{{ is_active and is_expired ? 'table-danger' : (is_active and is_expiring ? 'table-warning' : '') }}">
                                <td>
                                    {{ cert.user.lastname }} {{ cert.user.firstname }}
                                    <div class="text-muted small">{{ cert.user.login }}</div>
                                </td>
                                <td><code>{{ cert.serialNumber }}</code></td>
                                <td>
                                    {{ cert.validFrom|date('d.m.Y') }} — {{ cert.validTo|date('d.m.Y') }}
                                    {% if is_expired %}
                                        <span class="badge bg-danger">Истёк</span>
                                    {% elseif is_expiring %}
                                        <span class="badge bg-warning text-dark">Истекает {{ cert.validTo|date('d.m.Y') }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if is_active %}
                                        <span class="badge bg-success">Активен</span>
                                    {% else %}
                                        <span class="badge bg-danger">Отозван</span>
                                        <div class="text-muted small">
                                            {{ cert.revokedAt ? cert.revokedAt|date('d.m.Y H:i') : '' }}
                                            {% if cert.revocationReason %}— {{ cert.revocationReason }}{% endif %}
                                        </div>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if cert.issuedBy %}
                                        {{ cert.issuedBy.lastname }} {{ cert.issuedBy.firstname }}
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    {% if is_active %}
                                        <button type="button" class="btn btn-sm btn-outline-warning"
                                                data-bs-toggle="modal" data-bs-target="#reissueModal{{ cert.id }}">
                                            <i class="bi bi-arrow-repeat me-1"></i>Перевыпустить
                                        </button>
                                        <button type="button" class="btn btn-sm btn-outline-danger"
                                                data-bs-toggle="modal" data-bs-target="#revokeModal{{ cert.id }}">
                                            <i class="bi bi-x-circle me-1"></i>Отозвать
                                        </button>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>

    {# Модальные окна отзыва и перевыпуска — только для активных сертификатов #}
    {% for cert in certificates %}
        {% if cert.status.value == 'active' %}
            <div class="modal fade" id="revokeModal{{ cert.id }}" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form action="{{ path('app_admin_certificates_revoke', {id: cert.id}) }}" method="post">
                            <input type="hidden" name="_token" value="{{ csrf_token('certificate_revoke_' ~ cert.id) }}">
                            <div class="modal-header">
                                <h5 class="modal-title">Отзыв сертификата</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                            </div>
                            <div class="modal-body">
                                <p>
                                    Сертификат <code>{{ cert.serialNumber }}</code>
                                    пользователя <strong>{{ cert.user.lastname }} {{ cert.user.firstname }}</strong>
                                    будет отозван. Подписывать документы этим сертификатом станет невозможно.
                                </p>
                                <div class="form-group">
                                    <label for="revoke_reason_{{ cert.id }}">Причина отзыва <span class="text-danger">*</span></label>
                                    <textarea id="revoke_reason_{{ cert.id }}" name="reason" class="form-control" rows="2" required></textarea>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                                <button type="submit" class="btn btn-danger">Отозвать</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="reissueModal{{ cert.id }}" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form action="{{ path('app_admin_certificates_reissue', {id: cert.id}) }}" method="post">
                            <input type="hidden" name="_token" value="{{ csrf_token('certificate_reissue_' ~ cert.id) }}">
                            <div class="modal-header">
                                <h5 class="modal-title">Перевыпуск сертификата</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                            </div>
                            <div class="modal-body">
                                <p>
                                    Текущий сертификат <code>{{ cert.serialNumber }}</code> будет отозван
                                    (причина «reissued»), для пользователя
                                    <strong>{{ cert.user.lastname }} {{ cert.user.firstname }}</strong>
                                    будет выпущен новый.
                                </p>
                                <div class="alert alert-warning mb-3">
                                    <i class="bi bi-exclamation-triangle me-1"></i>
                                    Новый файл <strong>.p12</strong> будет скачан <strong>один раз</strong> —
                                    он нигде не хранится, повторное скачивание невозможно.
                                </div>
                                <div class="form-group">
                                    <label for="reissue_password_{{ cert.id }}">Пароль контейнера .p12 (минимум 8 символов) <span class="text-danger">*</span></label>
                                    <input type="password" id="reissue_password_{{ cert.id }}" name="p12_password"
                                           class="form-control" minlength="8" required autocomplete="new-password">
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                                <button type="submit" class="btn btn-warning">Перевыпустить и скачать .p12</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        {% endif %}
    {% endfor %}
{% endblock %}
