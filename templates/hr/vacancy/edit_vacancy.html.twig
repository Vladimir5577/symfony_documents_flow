{% extends 'base_dashboard.html.twig' %}

{% block title %}Редактирование: {{ vacancy.title }}{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}

<h1>Редактирование вакансии</h1>

<div class="mb-3">
    <a href="{{ path('app_hr_vacancies_show', {id: vacancy.id}) }}" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Назад
    </a>
</div>

<div id="form-error" class="alert alert-danger d-none" role="alert"></div>

<section class="section">

    <form id="edit-form" novalidate>

        <div class="card mb-3">
            <div class="card-header"><h4 class="card-title mb-0">Основная информация</h4></div>
            <div class="card-body">
                <div class="row g-3">

                    <div class="col-12">
                        <label class="form-label">Название <span class="text-danger">*</span></label>
                        <input type="text" name="title" class="form-control" value="{{ vacancy.title }}" required maxlength="255">
                    </div>

                    <div class="col-12">
                        <label class="form-label">Зарплата</label>
                        <input type="text" name="salary" class="form-control" value="{{ vacancy.salary ?? '' }}" maxlength="100" placeholder="от 50 000 ₽">
                    </div>

                    <div class="col-12">
                        <label class="form-label">Город <span class="text-danger">*</span></label>
                        <select name="city" class="form-select" required>
                            <option value="donetsk"      {{ vacancy.cityValue == 'donetsk'      ? 'selected' : '' }}>Донецк</option>
                            <option value="makeyevka"    {{ vacancy.cityValue == 'makeyevka'    ? 'selected' : '' }}>Макеевка</option>
                            <option value="mariupol"     {{ vacancy.cityValue == 'mariupol'     ? 'selected' : '' }}>Мариуполь</option>
                            <option value="gorlovka"     {{ vacancy.cityValue == 'gorlovka'     ? 'selected' : '' }}>Горловка</option>
                            <option value="enakievo"     {{ vacancy.cityValue == 'enakievo'     ? 'selected' : '' }}>Енакиево</option>
                            <option value="shakhtersk"   {{ vacancy.cityValue == 'shakhtersk'   ? 'selected' : '' }}>Шахтёрск</option>
                            <option value="torez"        {{ vacancy.cityValue == 'torez'        ? 'selected' : '' }}>Торез</option>
                            <option value="amvrosievka"  {{ vacancy.cityValue == 'amvrosievka'  ? 'selected' : '' }}>Амвросиевка</option>
                            <option value="yasinovataya" {{ vacancy.cityValue == 'yasinovataya' ? 'selected' : '' }}>Ясиноватая</option>
                        </select>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Занятость <span class="text-danger">*</span></label>
                        <select name="employmentType" class="form-select" required>
                            <option value="full_time"  {{ vacancy.employmentTypeValue == 'full_time'  ? 'selected' : '' }}>Полная занятость</option>
                            <option value="part_time"  {{ vacancy.employmentTypeValue == 'part_time'  ? 'selected' : '' }}>Частичная занятость</option>
                            <option value="internship" {{ vacancy.employmentTypeValue == 'internship' ? 'selected' : '' }}>Стажировка</option>
                            <option value="contract"   {{ vacancy.employmentTypeValue == 'contract'   ? 'selected' : '' }}>Контракт</option>
                        </select>
                    </div>

                    <div class="col-12">
                        <label class="form-label">График <span class="text-danger">*</span></label>
                        <select name="schedule" class="form-select" required>
                            <option value="five_two" {{ vacancy.scheduleValue == 'five_two' ? 'selected' : '' }}>График 5/2</option>
                            <option value="two_two"  {{ vacancy.scheduleValue == 'two_two'  ? 'selected' : '' }}>График 2/2</option>
                            <option value="shift"    {{ vacancy.scheduleValue == 'shift'    ? 'selected' : '' }}>Сменный</option>
                            <option value="flexible" {{ vacancy.scheduleValue == 'flexible' ? 'selected' : '' }}>Гибкий</option>
                            <option value="remote"   {{ vacancy.scheduleValue == 'remote'   ? 'selected' : '' }}>Удалённо</option>
                        </select>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Опыт <span class="text-danger">*</span></label>
                        <select name="experience" class="form-select" required>
                            <option value="none"        {{ vacancy.experienceValue == 'none'        ? 'selected' : '' }}>Без опыта</option>
                            <option value="one_year"    {{ vacancy.experienceValue == 'one_year'    ? 'selected' : '' }}>От 1 года</option>
                            <option value="two_years"   {{ vacancy.experienceValue == 'two_years'   ? 'selected' : '' }}>От 2 лет</option>
                            <option value="three_years" {{ vacancy.experienceValue == 'three_years' ? 'selected' : '' }}>От 3 лет</option>
                            <option value="five_years"  {{ vacancy.experienceValue == 'five_years'  ? 'selected' : '' }}>От 5 лет</option>
                        </select>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Телефон</label>
                        <input type="text" name="contactPhone" class="form-control" value="{{ vacancy.contactPhone ?? '' }}" maxlength="32">
                    </div>

                    <div class="col-12">
                        <label class="form-label">Email</label>
                        <input type="email" name="contactEmail" class="form-control" value="{{ vacancy.contactEmail ?? '' }}">
                    </div>

                    <div class="col-12">
                        <label class="form-label">Порядок сортировки</label>
                        <input type="number" name="sortOrder" class="form-control" value="{{ vacancy.sortOrder }}" min="0">
                    </div>

                    <div class="col-12">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" name="isPublished" id="isPublished" {{ vacancy.isPublished ? 'checked' : '' }}>
                            <label class="form-check-label" for="isPublished">Опубликована</label>
                        </div>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Краткое описание</label>
                        <textarea name="shortDescription" class="form-control" rows="3" maxlength="5000">{{ vacancy.shortDescription ?? '' }}</textarea>
                    </div>

                </div>
            </div>
        </div>

        {% set blockTypes = [
            {value: 'requirements', label: 'Требования'},
            {value: 'duties',       label: 'Обязанности'},
            {value: 'conditions',   label: 'Условия'},
        ] %}

        {% for blockType in blockTypes %}
            {% set existingItems = [] %}
            {% for block in vacancy.bodyBlocks %}
                {% if block.type.value == blockType.value %}
                    {% set existingItems = block.items %}
                {% endif %}
            {% endfor %}

            <div class="card mb-3" id="block-{{ blockType.value }}">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="card-title mb-0">{{ blockType.label }}</h4>
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="addItem('{{ blockType.value }}')">
                        <i class="bi bi-plus"></i> Добавить пункт
                    </button>
                </div>
                <div class="card-body">
                    <div class="items-list" id="items-{{ blockType.value }}">
                        {% if existingItems|length > 0 %}
                            {% for item in existingItems %}
                                <div class="input-group mb-2">
                                    <input type="text" class="form-control" value="{{ item }}" maxlength="500">
                                    <button type="button" class="btn btn-outline-danger" onclick="removeItem(this)">
                                        <i class="bi bi-x"></i>
                                    </button>
                                </div>
                            {% endfor %}
                        {% else %}
                            <p class="text-muted small mb-0" id="empty-{{ blockType.value }}">Нет пунктов. Нажмите «Добавить пункт».</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endfor %}

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary" id="submit-btn">Сохранить</button>
            <a href="{{ path('app_hr_vacancies_show', {id: vacancy.id}) }}" class="btn btn-outline-secondary">Отмена</a>
        </div>

    </form>

</section>

<script>
const updateUrl = '{{ path('app_hr_vacancies_update', {id: vacancy.id}) }}';
const showUrl   = '{{ path('app_hr_vacancies_show',  {id: vacancy.id}) }}';

function addItem(blockType) {
    const list = document.getElementById('items-' + blockType);
    const empty = document.getElementById('empty-' + blockType);
    if (empty) empty.remove();

    const div = document.createElement('div');
    div.className = 'input-group mb-2';
    div.innerHTML = '<input type="text" class="form-control" maxlength="500">'
        + '<button type="button" class="btn btn-outline-danger" onclick="removeItem(this)">'
        + '<i class="bi bi-x"></i></button>';
    list.appendChild(div);
    div.querySelector('input').focus();
}

function removeItem(btn) {
    const group = btn.closest('.input-group');
    const list  = group.parentElement;
    group.remove();
    if (list.querySelectorAll('.input-group').length === 0) {
        const blockType = list.id.replace('items-', '');
        const p = document.createElement('p');
        p.className = 'text-muted small mb-0';
        p.id = 'empty-' + blockType;
        p.textContent = 'Нет пунктов. Нажмите «Добавить пункт».';
        list.appendChild(p);
    }
}

document.getElementById('edit-form').addEventListener('submit', async function(e) {
    e.preventDefault();

    const form = e.target;
    const errorBox = document.getElementById('form-error');
    errorBox.classList.add('d-none');

    const blockTypes = ['requirements', 'duties', 'conditions'];
    const bodyBlocks = [];
    for (const type of blockTypes) {
        const inputs = document.querySelectorAll('#items-' + type + ' input');
        const items = Array.from(inputs).map(i => i.value.trim()).filter(v => v !== '');
        if (items.length > 0) {
            bodyBlocks.push({ type, items });
        }
    }

    const salary        = form.salary.value.trim();
    const shortDesc     = form.shortDescription.value.trim();
    const contactPhone  = form.contactPhone.value.trim();
    const contactEmail  = form.contactEmail.value.trim();

    const payload = {
        title:            form.title.value.trim(),
        city:             form.city.value,
        employmentType:   form.employmentType.value,
        schedule:         form.schedule.value,
        experience:       form.experience.value,
        salary:           salary || null,
        shortDescription: shortDesc || null,
        contactPhone:     contactPhone || null,
        contactEmail:     contactEmail || null,
        sortOrder:        parseInt(form.sortOrder.value, 10) || 0,
        isPublished:      form.isPublished.checked,
        bodyBlocks,
    };

    const btn = document.getElementById('submit-btn');
    btn.disabled = true;
    btn.textContent = 'Сохранение…';

    try {
        const res = await fetch(updateUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
        });

        const data = await res.json();

        if (!res.ok) {
            errorBox.textContent = data.error ?? 'Произошла ошибка';
            errorBox.classList.remove('d-none');
            errorBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
            return;
        }

        window.location.href = showUrl;
    } catch (err) {
        errorBox.textContent = 'Ошибка сети: ' + err.message;
        errorBox.classList.remove('d-none');
    } finally {
        btn.disabled = false;
        btn.textContent = 'Сохранить';
    }
});
</script>

{% endblock %}
