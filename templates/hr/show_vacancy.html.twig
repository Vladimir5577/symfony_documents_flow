{% extends 'base_dashboard.html.twig' %}

{% block title %}{{ vacancy.title }}{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}

{% for message in app.flashes('error') %}
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
{% endfor %}

<h1>{{ vacancy.title }}</h1>

<div class="mb-3 d-flex gap-2">
    <a href="{{ path('app_hr_vacancies') }}" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Назад к списку
    </a>
    <a href="{{ path('app_hr_vacancies_edit', {id: vacancy.id}) }}" class="btn btn-sm btn-primary">
        <i class="bi bi-pencil"></i> Редактировать
    </a>
</div>

<section class="section">

    <div class="card mb-3">
        <div class="card-header">
            <h4 class="card-title mb-0">Публикация</h4>
        </div>
        <div class="card-body">
            <form method="post" action="{{ path('app_hr_vacancies_publish', {id: vacancy.id}) }}" class="d-inline">
                {% if vacancy.isPublished %}
                    <input type="hidden" name="isPublished" value="0">
                    <button type="submit" class="btn btn-outline-secondary">Скрыть вакансию</button>
                {% else %}
                    <input type="hidden" name="isPublished" value="1">
                    <button type="submit" class="btn btn-success">Опубликовать вакансию</button>
                {% endif %}
            </form>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">
            <h4 class="card-title mb-0">Основная информация</h4>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3 text-muted">Статус</dt>
                <dd class="col-sm-9">
                    {% if vacancy.isPublished %}
                        <span class="badge bg-success">Опубликована</span>
                    {% else %}
                        <span class="badge bg-secondary">Скрыта</span>
                    {% endif %}
                </dd>

                <dt class="col-sm-3 text-muted">Зарплата</dt>
                <dd class="col-sm-9">{{ vacancy.salary ?? '—' }}</dd>

                <dt class="col-sm-3 text-muted">Город</dt>
                <dd class="col-sm-9">{{ vacancy.cityLabel }}</dd>

                <dt class="col-sm-3 text-muted">Занятость</dt>
                <dd class="col-sm-9">{{ vacancy.employmentTypeLabel }}</dd>

                <dt class="col-sm-3 text-muted">График</dt>
                <dd class="col-sm-9">{{ vacancy.scheduleLabel }}</dd>

                <dt class="col-sm-3 text-muted">Опыт</dt>
                <dd class="col-sm-9">{{ vacancy.experienceLabel }}</dd>

                {% if vacancy.contactPhone %}
                    <dt class="col-sm-3 text-muted">Телефон</dt>
                    <dd class="col-sm-9">{{ vacancy.contactPhone }}</dd>
                {% endif %}

                {% if vacancy.contactEmail %}
                    <dt class="col-sm-3 text-muted">Email</dt>
                    <dd class="col-sm-9">{{ vacancy.contactEmail }}</dd>
                {% endif %}

                <dt class="col-sm-3 text-muted">Создана</dt>
                <dd class="col-sm-9">{{ vacancy.createdAt|date('d.m.Y H:i') }}</dd>

                <dt class="col-sm-3 text-muted">Обновлена</dt>
                <dd class="col-sm-9">{{ vacancy.updatedAt|date('d.m.Y H:i') }}</dd>
            </dl>
        </div>
    </div>

    {% if vacancy.shortDescription %}
        <div class="card mb-3">
            <div class="card-header">
                <h4 class="card-title mb-0">Краткое описание</h4>
            </div>
            <div class="card-body">
                <p class="mb-0">{{ vacancy.shortDescription }}</p>
            </div>
        </div>
    {% endif %}

    {% for block in vacancy.bodyBlocks %}
        <div class="card mb-3">
            <div class="card-header">
                <h4 class="card-title mb-0">{{ block.type.label }}</h4>
            </div>
            <div class="card-body">
                <ul class="mb-0">
                    {% for item in block.items %}
                        <li>{{ item }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    {% endfor %}


</section>

{% endblock %}
