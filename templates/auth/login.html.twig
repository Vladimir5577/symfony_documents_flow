    {# Login form centered #}
    <div style="position: relative; z-index: 10; width: 100%; max-width: 460px; padding: 0 1rem;">
        <div id="login-card" style="background: rgba(18,18,20,0.88); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px); border: 1px solid rgba(255,255,255,0.08); border-radius: 1.25rem; padding: 2.75rem 2.5rem 2.25rem; box-shadow: 0 24px 64px rgba(0,0,0,0.6);">

            <h1 style="font-size: 1.75rem; font-weight: 700; color: #fff; text-align: center; margin: 0 0 0.5rem;">Корпоративный портал</h1>
            <p style="font-size: 0.82rem; color: rgba(255,255,255,0.45); text-align: center; margin: 0 0 2rem; line-height: 1.5;">
                Информационные системы и цифровые сервисы<br>ГУП ДНР «Донснабкомплект»
            </p>

            <form action="{{ path('app_login') }}" method="post">
                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                {% if error %}
                    <div class="alert alert-danger" style="border-radius: 0.75rem; background: rgba(220,53,69,0.12); border: 1px solid rgba(220,53,69,0.25); color: #ff7b7b; font-size: 0.875rem; padding: 0.75rem 1rem; margin-bottom: 1.25rem;">
                        <i class="bi bi-exclamation-triangle me-2"></i>Неправильные логин или пароль
                    </div>
                {% endif %}

                {% if app.user %}
                    <div class="mb-3" style="color: #fff; font-size: 0.875rem;">
                        Вы вошли как {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}" style="color: #90caf9;">Выйти</a>
                    </div>
                {% endif %}

                <div class="form-group position-relative has-icon-left mb-3">
                    <input type="text" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="username" placeholder="Имя пользователя" required autofocus
                           style="background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); color: #fff; border-radius: 0.75rem; padding: 0.8rem 0.75rem 0.8rem 2.75rem; font-size: 0.95rem; transition: border-color 0.2s, background 0.2s;">
                    <div class="form-control-icon">
                        <i class="bi bi-person" style="color: rgba(255,255,255,0.4);"></i>
                    </div>
                </div>
                <div class="form-group position-relative has-icon-left mb-3">
                    <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" placeholder="Пароль" required
                           style="background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); color: #fff; border-radius: 0.75rem; padding: 0.8rem 0.75rem 0.8rem 2.75rem; font-size: 0.95rem; transition: border-color 0.2s, background 0.2s;">
                    <div class="form-control-icon">
                        <i class="bi bi-shield-lock" style="color: rgba(255,255,255,0.4);"></i>
                    </div>
                </div>

                <div style="text-align: center; margin-bottom: 1.5rem;">
                    <a href="#" style="font-size: 0.82rem; color: rgba(255,255,255,0.4); text-decoration: none;"
                       onmouseover="this.style.color='rgba(255,255,255,0.7)'" onmouseout="this.style.color='rgba(255,255,255,0.4)'">
                        Забыли пароль?
                    </a>
                </div>

                <button class="btn btn-primary btn-block btn-lg" type="submit"
                        style="width: 100%; border-radius: 0.75rem; padding: 0.85rem; font-size: 1rem; font-weight: 700; letter-spacing: 0.03em; background: #3b5bdb; border-color: #3b5bdb;">
                    Войти
                </button>
            </form>

            <p style="text-align: center; margin: 1.75rem 0 0; font-size: 0.78rem; color: rgba(255,255,255,0.3);">
                Авторизованный доступ к ресурсам предприятия
            </p>
        </div>
    </div>
</div>




