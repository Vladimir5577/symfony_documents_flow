<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>



    <link rel="shortcut icon" href="./front_end/assets/compiled/svg/logo-horizontal-main.svg" type="image/x-icon">
    <link rel="shortcut icon" href="data:image/png;base64," type="image/png">
    <link rel="stylesheet" href="./front_end/assets/compiled/css/app.css">
    <link rel="stylesheet" href="./front_end/assets/compiled/css/app-dark.css">
    <link rel="stylesheet" href="./front_end/assets/compiled/css/auth.css">


    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>

<body data-turbo="false">
<script src="./front_end/assets/static/js/initTheme.js"></script>

{# Background Paths - fullscreen #}
<div style="position: relative; min-height: 100vh; width: 100%; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #0a0a0a;">
    {# SVG floating paths background #}
    <div style="position: absolute; inset: 0; pointer-events: none;">
        <svg id="paths-svg-1" style="width: 100%; height: 100%; color: #ffffff;" viewBox="0 0 696 316" fill="none"></svg>
    </div>
    <div style="position: absolute; inset: 0; pointer-events: none;">
        <svg id="paths-svg-2" style="width: 100%; height: 100%; color: #ffffff;" viewBox="0 0 696 316" fill="none"></svg>
    </div>

    {# Login form centered on top #}
    <div style="position: relative; z-index: 10; width: 100%; max-width: 420px; padding: 0 1rem;">
        <div id="login-card" style="background: rgba(255,255,255,0.06); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1); border-radius: 1.5rem; padding: 3rem; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);">

            <h1 style="font-size: 2.5rem; margin-bottom: 2rem; text-align: center; font-weight: 700; color: #fff;">Войти</h1>

            <form action="{{ path('app_login') }}" method="post">
                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                {% if error %}
                    <div class="alert alert-danger" style="border-radius: 0.75rem; background: rgba(220,53,69,0.15); border: 1px solid rgba(220,53,69,0.3); color: #ff6b6b;">
                        Неправильные логин или пароль
                    </div>
                {% endif %}

                {% if app.user %}
                    <div class="mb-3" style="color: #fff;">
                        You are logged in as {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}" style="color: #90caf9;">Logout</a>
                    </div>
                {% endif %}

                <div class="form-group position-relative has-icon-left mb-4">
                    <input type="text" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="username" placeholder="Имя пользователя" required autofocus
                           style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); color: #fff; border-radius: 0.75rem; padding: 0.75rem 0.75rem 0.75rem 2.5rem;">
                    <div class="form-control-icon">
                        <i class="bi bi-person" style="color: rgba(255,255,255,0.5);"></i>
                    </div>
                </div>
                <div class="form-group position-relative has-icon-left mb-4">
                    <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" placeholder="Пароль" required
                           style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); color: #fff; border-radius: 0.75rem; padding: 0.75rem 0.75rem 0.75rem 2.5rem;">
                    <div class="form-control-icon">
                        <i class="bi bi-shield-lock" style="color: rgba(255,255,255,0.5);"></i>
                    </div>
                </div>

                <button class="btn btn-primary btn-block btn-lg shadow-lg mt-3" type="submit" style="width: 100%; border-radius: 0.75rem; padding: 0.75rem; font-size: 1.1rem;">Войти</button>
            </form>
        </div>
    </div>
</div>




<script src="./front_end/assets/static/js/components/dark.js"></script>
<script src="./front_end/assets/extensions/perfect-scrollbar/perfect-scrollbar.min.js"></script>


<script src="./front_end/assets/compiled/js/app.js"></script>



<script>
    // If you want to use tooltips in your project, we suggest initializing them globally
    // instead of a "per-page" level.
    document.addEventListener('DOMContentLoaded', function () {
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    }, false);
</script>

<style>
    @keyframes floatingPath {
        0% { stroke-dashoffset: 0; }
        100% { stroke-dashoffset: -2; }
    }
    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    #login-card {
        animation: fadeInUp 1.2s ease forwards;
    }
    #login-card input::placeholder {
        color: rgba(255,255,255,0.4);
    }
</style>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        function createFloatingPaths(svgId, position) {
            var svg = document.getElementById(svgId);
            if (!svg) return;
            var ns = 'http://www.w3.org/2000/svg';

            for (var i = 0; i < 36; i++) {
                var p = document.createElementNS(ns, 'path');
                var d = 'M-' + (380 - i * 5 * position) + ' -' + (189 + i * 6) +
                    'C-' + (380 - i * 5 * position) + ' -' + (189 + i * 6) +
                    ' -' + (312 - i * 5 * position) + ' ' + (216 - i * 6) +
                    ' ' + (152 - i * 5 * position) + ' ' + (343 - i * 6) +
                    'C' + (616 - i * 5 * position) + ' ' + (470 - i * 6) +
                    ' ' + (684 - i * 5 * position) + ' ' + (875 - i * 6) +
                    ' ' + (684 - i * 5 * position) + ' ' + (875 - i * 6);

                p.setAttribute('d', d);
                p.setAttribute('stroke', 'currentColor');
                p.setAttribute('stroke-width', (0.5 + i * 0.03).toString());
                p.setAttribute('stroke-opacity', (0.08 + i * 0.025).toString());
                p.setAttribute('fill', 'none');
                p.setAttribute('pathLength', '1');
                p.style.strokeDasharray = '0.3 0.7';
                p.style.strokeDashoffset = '0';

                var duration = 20 + Math.random() * 10;
                p.style.animation = 'floatingPath ' + duration + 's linear infinite';
                p.style.animationDelay = (-Math.random() * duration) + 's';

                svg.appendChild(p);
            }
        }

        createFloatingPaths('paths-svg-1', 1);
        createFloatingPaths('paths-svg-2', -1);
    });
</script>
</body>

</html>
