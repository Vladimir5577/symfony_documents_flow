<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>



    <link rel="shortcut icon" href="./front_end/assets/compiled/svg/logo-horizontal-main.svg" type="image/x-icon">
    <link rel="shortcut icon" href="data:image/png;base64," type="image/png">
    <link rel="stylesheet" href="./front_end/assets/compiled/css/app.css">
    <link rel="stylesheet" href="./front_end/assets/compiled/css/app-dark.css">
    <link rel="stylesheet" href="./front_end/assets/compiled/css/auth.css">

    {#  Google font  #}
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">


    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>

<body data-turbo="false">
<script src="./front_end/assets/static/js/initTheme.js"></script>

{# Background - fullscreen #}
<div style="position: relative; min-height: 100vh; width: 100%; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #0a0a0a;">

    {# Scene background layer #}
    <div style="position: absolute; inset: 0; pointer-events: none;">

        {# Ground line #}
        <div style="position: absolute; bottom: 0; left: 0; right: 0; height: 1px; background: rgba(255,255,255,0.06);"></div>
        <div style="position: absolute; bottom: 0; left: 0; right: 0; height: 70px; background: linear-gradient(to top, rgba(255,255,255,0.018), transparent);"></div>

        {# === STATIC CONTAINERS scattered along the bottom === #}

        {# Container small - 6% #}
        <div style="position: absolute; bottom: 1px; left: 6%; opacity: 0.5;">
            <svg width="52" height="68" viewBox="0 0 52 68" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="2" y="22" width="48" height="43" rx="3" fill="#1e1e1e" stroke="#2b2b2b" stroke-width="1.5"/>
                <rect x="0" y="14" width="52" height="12" rx="3" fill="#272727" stroke="#333" stroke-width="1.5"/>
                <rect x="17" y="16" width="18" height="4" rx="2" fill="#343434"/>
                <line x1="5" y1="34" x2="47" y2="34" stroke="#282828" stroke-width="1.5"/>
                <line x1="5" y1="46" x2="47" y2="46" stroke="#282828" stroke-width="1.5"/>
                <line x1="5" y1="58" x2="47" y2="58" stroke="#282828" stroke-width="1.5"/>
