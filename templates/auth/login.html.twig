    document.addEventListener('DOMContentLoaded', function () {
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    }, false);
</script>

<style>
    body, body * {
        font-family: 'Montserrat', sans-serif !important;
    }
    /* Truck drive: enters from left, exits to the right */
    @keyframes driveTruck {
        from { transform: translateX(-540px); }
        to   { transform: translateX(110vw);  }
    }
    /* Truck drive: enters from right, exits to the left */
    @keyframes driveTruckRtL {
        from { transform: translateX(110vw);  }
        to   { transform: translateX(-540px); }
    }
    /* Wheel spin */
    @keyframes wheelSpin {
        from { transform: rotate(0deg); }
        to   { transform: rotate(360deg); }
    }
    /* Exhaust smoke puffs */
    @keyframes smokeA {
        0%   { opacity: 0.65; transform: translate(0, 0)    scale(1);   }
        100% { opacity: 0;    transform: translate(-6px, -40px) scale(2.4); }
    }
    @keyframes smokeB {
        0%   { opacity: 0.5;  transform: translate(0, 0)    scale(1);   }
        100% { opacity: 0;    transform: translate(5px, -50px) scale(2.8); }
    }
    @keyframes smokeC {
        0%   { opacity: 0.4;  transform: translate(0, 0)    scale(1);   }
        100% { opacity: 0;    transform: translate(-3px,-32px) scale(2); }
    }
    .truck-smoke-a { animation: smokeA 2s   ease-out infinite; }
    .truck-smoke-b { animation: smokeB 2.5s ease-out infinite; animation-delay: -0.8s; }
    .truck-smoke-c { animation: smokeC 1.7s ease-out infinite; animation-delay: -1.3s; }

    /* Login card entrance */
    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    #login-card { animation: fadeInUp 1.2s ease forwards; }
    #login-card input::placeholder { color: rgba(255,255,255,0.35); }
    #login-card input:focus {
        outline: none;
        background: rgba(255,255,255,0.11) !important;
        border-color: rgba(255,255,255,0.3) !important;
        box-shadow: 0 0 0 3px rgba(255,255,255,0.05);
    }
</style>
