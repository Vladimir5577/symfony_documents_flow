{% extends 'base_dashboard.html.twig' %}

{% block title %}Редактировать фото — {{ user.lastname }} {{ user.firstname }}{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    <style>
        .user-photo-filedrop {
            min-height: 200px;
            border: 2px dashed var(--bs-border-color, rgba(0,0,0,.175));
            background: var(--bs-body-bg);
            padding: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: border-color .2s, background-color .2s;
        }
        .user-photo-filedrop:hover,
        .user-photo-filedrop.user-photo-filedrop-dragover {
            border-color: var(--bs-primary);
            background: color-mix(in srgb, var(--bs-primary) 8%, var(--bs-body-bg));
        }
        .user-photo-filedrop-text { color: var(--bs-secondary-color); font-size: 0.95rem; }
        .user-photo-preview-wrap {
            max-width: 280px;
            max-height: 320px;
            overflow: hidden;
            border-radius: 0.5rem;
            border: 1px solid var(--bs-border-color);
            background: var(--bs-light);
        }
        .user-photo-preview-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }
    </style>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Редактировать фото</h1>
        <a href="{{ path('app_view_user', {id: user.id}) }}" class="btn btn-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-arrow-left">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            Назад к просмотру
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <section class="section">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Фото пользователя</h4>
                    </div>
                    <div class="card-content">
                        <div class="card-body">
                            <form action="{{ path('app_update_user_photo', {id: user.id}) }}" method="post" enctype="multipart/form-data" id="user-photo-form">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('user_photo_' ~ user.id) }}">
                                <input type="file" id="user_photo_input" name="avatar_file" accept="image/jpeg,image/png,image/gif,image/webp" class="d-none">

                                <div class="d-flex flex-wrap align-items-start gap-4">
                                    {% if user.avatarName %}
                                    <div id="user_photo_current_wrap" class="flex-shrink-0">
                                        <p class="text-muted small mb-1">Текущее фото</p>
                                        <div class="user-photo-preview-wrap">
                                            <img id="user_photo_current_img" src="{{ (user.id ~ '/' ~ user.avatarName) | imagine_filter('avatar_medium') }}" alt="Текущее фото">
                                        </div>
                                    </div>
                                    {% endif %}
                                    <div class="flex-shrink-0">
                                        <div id="user_photo_dropzone" class="user-photo-filedrop rounded" role="button" tabindex="0">
                                            <span class="user-photo-filedrop-text">Перетащите сюда изображение или нажмите для выбора</span>
                                        </div>
                                        <p class="text-muted small mt-2 mb-0">Один файл: JPG, PNG, GIF или WebP</p>
                                    </div>
                                    <div id="user_photo_preview_wrap" class="d-none">
                                        <p class="text-muted small mb-1">Новое фото</p>
                                        <div class="user-photo-preview-wrap">
                                            <img id="user_photo_preview_img" src="" alt="Превью">
                                        </div>
                                        <button type="button" id="user_photo_remove_btn" class="btn btn-outline-danger btn-sm mt-2">Убрать и выбрать другое</button>
                                    </div>
                                </div>

                                <div class="mt-4">
                                    <button type="submit" id="user_photo_submit_btn" class="btn btn-primary" disabled>Сохранить фото</button>
                                    <a href="{{ path('app_view_user', {id: user.id}) }}" class="btn btn-outline-secondary">Отмена</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var input = document.getElementById('user_photo_input');
            var dropzone = document.getElementById('user_photo_dropzone');
            var previewWrap = document.getElementById('user_photo_preview_wrap');
            var previewImg = document.getElementById('user_photo_preview_img');
            var currentWrap = document.getElementById('user_photo_current_wrap');
            var removeBtn = document.getElementById('user_photo_remove_btn');
            var submitBtn = document.getElementById('user_photo_submit_btn');
            var form = document.getElementById('user-photo-form');

            if (!input || !dropzone) return;

            var currentObjectUrl = null;

            function setPreview(file) {
                if (currentObjectUrl) {
                    URL.revokeObjectURL(currentObjectUrl);
                    currentObjectUrl = null;
                }
                if (!file || !file.type || file.type.indexOf('image/') !== 0) {
                    previewWrap.classList.add('d-none');
                    dropzone.classList.remove('d-none');
                    if (currentWrap) currentWrap.classList.remove('d-none');
                    submitBtn.disabled = true;
                    if (input) input.value = '';
                    return;
                }
                currentObjectUrl = URL.createObjectURL(file);
                previewImg.src = currentObjectUrl;
                previewWrap.classList.remove('d-none');
                dropzone.classList.add('d-none');
                if (currentWrap) currentWrap.classList.add('d-none');
                submitBtn.disabled = false;
            }

            function clearPreview() {
                setPreview(null);
                dropzone.classList.remove('d-none');
            }

            dropzone.addEventListener('click', function () { input.click(); });
            dropzone.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    input.click();
                }
            });

            dropzone.addEventListener('dragover', function (e) {
                e.preventDefault();
                e.stopPropagation();
                dropzone.classList.add('user-photo-filedrop-dragover');
            });
            dropzone.addEventListener('dragleave', function (e) {
                e.preventDefault();
                e.stopPropagation();
                dropzone.classList.remove('user-photo-filedrop-dragover');
            });
            dropzone.addEventListener('drop', function (e) {
                e.preventDefault();
                e.stopPropagation();
                dropzone.classList.remove('user-photo-filedrop-dragover');
                var dt = e.dataTransfer;
                if (!dt || !dt.files || !dt.files.length) return;
                var file = dt.files[0];
                if (file && file.type && file.type.indexOf('image/') === 0) {
                    var dt2 = new DataTransfer();
                    dt2.items.add(file);
                    input.files = dt2.files;
                    setPreview(file);
                }
            });

            input.addEventListener('change', function () {
                var file = input.files && input.files[0];
                setPreview(file || null);
            });

            if (removeBtn) {
                removeBtn.addEventListener('click', function () {
                    clearPreview();
                    input.value = '';
                });
            }

            if (form) {
                form.addEventListener('submit', function () {
                    if (currentObjectUrl) URL.revokeObjectURL(currentObjectUrl);
                    currentObjectUrl = null;
                });
            }
        });
    </script>
{% endblock %}
