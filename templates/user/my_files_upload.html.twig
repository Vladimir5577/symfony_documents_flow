{% extends 'base_dashboard.html.twig' %}

{% block title %}Загрузить файлы{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    <style>
        .my-files-filedrop {
            min-height: 140px;
            border: 2px dashed var(--bs-border-color, rgba(0,0,0,.175));
            background: var(--bs-body-bg);
            padding: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: border-color .2s, background-color .2s;
        }
        .my-files-filedrop:hover,
        .my-files-filedrop.my-files-filedrop-dragover {
            border-color: var(--bs-primary);
            background: color-mix(in srgb, var(--bs-primary) 8%, var(--bs-body-bg));
        }
        .my-files-filedrop-text { color: var(--bs-secondary-color); font-size: 0.95rem; }
        #my_files_list .list-group-item { padding: 0.5rem 0.75rem; }
    </style>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Загрузить файлы</h1>
        <a href="{{ path('app_my_files') }}" class="btn btn-outline-secondary">К списку файлов</a>
    </div>

    <section class="section">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">Добавление файлов</h4>
                    </div>
                    <div class="card-content">
                        <div class="card-body">
                            <form action="{{ path('app_my_files_upload') }}" method="post" class="form" enctype="multipart/form-data">
                                <input type="hidden" name="_token" value="{{ csrf_token('my_files_upload') }}">

                                {% for message in app.flashes('error') %}
                                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                        {{ message }}
                                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрыть"></button>
                                    </div>
                                {% endfor %}

                                <div class="mb-3">
                                    <label for="my_files_folder" class="form-label">Папка</label>
                                    <select id="my_files_folder" name="folder_id" class="form-select">
                                        <option value="" {{ selected_folder_id is empty ? 'selected' : '' }}>Корень</option>
                                        {% for folder in folders %}
                                            <option value="{{ folder.id }}" {{ selected_folder_id == folder.id ? 'selected' : '' }}>{{ folder.name }}</option>
                                        {% endfor %}
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label d-block mb-2">Файлы</label>
                                    <input type="file" id="my_files_input" name="files[]" multiple class="d-none">
                                    <div id="my_files_dropzone" class="my-files-filedrop rounded" role="button" tabindex="0">
                                        <span class="my-files-filedrop-text">Перетащите файлы сюда или нажмите для выбора</span>
                                    </div>
                                    <ul id="my_files_list" class="list-group list-group-flush mt-2 small"></ul>
                                    <small class="text-muted">Максимум 5 МБ на файл. При ошибке валидации файлы нужно выбрать заново.</small>
                                </div>

                                <div class="d-flex gap-2">
                                    <button type="submit" id="my_files_submit_btn" class="btn btn-primary" disabled>Загрузить</button>
                                    <a href="{{ path('app_my_files') }}" class="btn btn-light-secondary">Отмена</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var input = document.getElementById('my_files_input');
            var dropzone = document.getElementById('my_files_dropzone');
            var submitBtn = document.getElementById('my_files_submit_btn');
            if (!input || !dropzone) return;

            function formatSize(bytes) {
                if (bytes === 0) return '0 Б';
                var k = 1024;
                var sizes = ['Б', 'КБ', 'МБ', 'ГБ'];
                var i = Math.floor(Math.log(bytes) / Math.log(k));
                return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
            }

            function updateSubmitState() {
                if (submitBtn) {
                    submitBtn.disabled = !input.files || input.files.length === 0;
                }
            }

            function renderList() {
                var listEl = document.getElementById('my_files_list');
                listEl.innerHTML = '';
                var files = input.files;
                for (var i = 0; i < files.length; i++) {
                    (function (idx) {
                        var file = files[idx];
                        var li = document.createElement('li');
                        li.className = 'list-group-item d-flex align-items-center gap-2';
                        li.innerHTML = '<span class="flex-shrink-0 text-muted"><i class="bi bi-file-earmark"></i></span>' +
                            '<span class="flex-grow-1 text-truncate" title="' + (file.name || '').replace(/"/g, '&quot;') + '">' + (file.name || '—') + '</span>' +
                            '<span class="flex-shrink-0 text-muted small">' + formatSize(file.size) + '</span>' +
                            '<button type="button" class="btn btn-sm btn-outline-danger flex-shrink-0" data-index="' + idx + '" aria-label="Удалить">×</button>';
                        li.querySelector('button').addEventListener('click', function () {
                            var dt = new DataTransfer();
                            for (var j = 0; j < files.length; j++) { if (j !== idx) dt.items.add(files[j]); }
                            input.files = dt.files;
                            renderList();
                            updateSubmitState();
                        });
                        listEl.appendChild(li);
                    })(i);
                }
                updateSubmitState();
            }

            dropzone.addEventListener('click', function () { input.click(); });
            dropzone.addEventListener('keydown', function (e) { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); input.click(); } });

            dropzone.addEventListener('dragover', function (e) {
                e.preventDefault();
                e.stopPropagation();
                dropzone.classList.add('my-files-filedrop-dragover');
            });
            dropzone.addEventListener('dragleave', function (e) {
                e.preventDefault();
                e.stopPropagation();
                dropzone.classList.remove('my-files-filedrop-dragover');
            });
            dropzone.addEventListener('drop', function (e) {
                e.preventDefault();
                e.stopPropagation();
                dropzone.classList.remove('my-files-filedrop-dragover');
                var dt = e.dataTransfer;
                if (!dt || !dt.files || !dt.files.length) return;
                var existing = input.files;
                var newDt = new DataTransfer();
                for (var i = 0; i < existing.length; i++) newDt.items.add(existing[i]);
                for (var j = 0; j < dt.files.length; j++) newDt.items.add(dt.files[j]);
                input.files = newDt.files;
                renderList();
            });

            input.addEventListener('change', function () {
                renderList();
            });
        });
    </script>
{% endblock %}
