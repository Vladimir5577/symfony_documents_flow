                    </div>
                    <div class="theme-toggle d-flex gap-2 align-items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true"
                             role="img" class="iconify iconify--system-uicons" width="20" height="20"
                             preserveAspectRatio="xMidYMid meet" viewBox="0 0 21 21">
                            <g fill="none" fill-rule="evenodd" stroke="currentColor" stroke-linecap="round"
                               stroke-linejoin="round">
                                <path
                                    d="M10.5 14.5c2.219 0 4-1.763 4-3.982a4.003 4.003 0 0 0-4-4.018c-2.219 0-4 1.781-4 4c0 2.219 1.781 4 4 4zM4.136 4.136L5.55 5.55m9.9 9.9l1.414 1.414M1.5 10.5h2m14 0h2M4.135 16.863L5.55 15.45m9.899-9.9l1.414-1.415M10.5 19.5v-2m0-14v-2"
                                    opacity=".3"></path>
                                <g transform="translate(-210 -1)">
                                    <path d="M220.5 2.5v2m6.5.5l-1.5 1.5"></path>
                                    <circle cx="220.5" cy="11.5" r="4"></circle>
                                    <path d="m214 5l1.5 1.5m5 14v-2m6.5-.5l-1.5-1.5M214 18l1.5-1.5m-4-5h2m14 0h2"></path>
                                </g>
                            </g>
                        </svg>
                        <div class="form-check form-switch fs-6">
                            <input class="form-check-input  me-0" type="checkbox" id="toggle-dark" style="cursor: pointer">
                            <label class="form-check-label"></label>
                        </div>
                        <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" aria-hidden="true"
                             role="img" class="iconify iconify--mdi" width="20" height="20" preserveAspectRatio="xMidYMid meet"
                             viewBox="0 0 24 24">
                            <path fill="currentColor"
                                  d="m17.75 4.09l-2.53 1.94l.91 3.06l-2.63-1.81l-2.63 1.81l.91-3.06l-2.53-1.94L12.44 4l1.06-3l1.06 3l3.19.09m3.5 6.91l-1.64 1.25l.59 1.98l-1.7-1.17l-1.7 1.17l.59-1.98L15.75 11l2.06-.05L18.5 9l.69 1.95l2.06.05m-2.28 4.95c.83-.08 1.72 1.1 1.19 1.85c-.32.45-.66.87-1.08 1.27C15.17 23 8.84 23 4.94 19.07c-3.91-3.9-3.91-10.24 0-14.14c.4-.4.82-.76 1.27-1.08c.75-.53 1.93.36 1.85 1.19c-.27 2.86.69 5.83 2.89 8.02a9.96 9.96 0 0 0 8.02 2.89m-1.64 2.02a12.08 12.08 0 0 1-7.8-3.47c-2.17-2.19-3.33-5-3.49-7.82c-2.81 3.14-2.7 7.96.31 10.98c3.02 3.01 7.84 3.12 10.98.31Z">
                            </path>
                        </svg>
                    </div>
                    <div class="logo mb-1">
                        <a href="#"><img src="/front_end/assets/compiled/svg/logo-horizontal-main.svg" alt="Logo" style="width: 250px; height: auto;"></a>
                    </div>
                </div>
            </div>
            <div class="sidebar-menu">

                {% block sidebar_list %}{% endblock %}

            </div>
            <button class="sidebar-collapse-toggle" id="sidebar-collapse-btn">
                <i class="bi bi-chevron-double-left"></i>
                <span class="sct-label">Hide</span>
            </button>
        </div>
    </div>




    <div id="main">
        <header class="mb-3">
            <div class="d-flex justify-content-between align-items-center w-100">
                <a href="#" class="burger-btn d-block d-xl-none">
                    <i class="bi bi-justify fs-3"></i>
                </a>
                {% if app.user %}
                    <div class="d-flex align-items-center ms-auto gap-2">
                        {# Notification bell #}
                        <div class="dropdown">
                            <a class="btn btn-link position-relative p-2" href="#" role="button" id="notificationDropdown" data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside" style="border: none; box-shadow: none; color: inherit;">
                                <i class="bi bi-bell" style="font-size: 1.25rem;"></i>
                                <span id="notification-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem; display: none;"></span>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end shadow-sm p-0" aria-labelledby="notificationDropdown" style="min-width: 340px; max-width: 400px;">
                                <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                                    <h6 class="mb-0" style="font-size: 0.9rem; font-weight: 600;">Уведомления</h6>
                                    <button id="mark-all-read-btn" class="btn btn-link btn-sm text-decoration-none p-0" style="font-size: 0.8rem;">Прочитать все</button>
                                </div>
                                <div id="notification-list" style="max-height: 350px; overflow-y: auto;">
                                    <div class="text-center text-muted py-4" style="font-size: 0.85rem;">Нет уведомлений</div>
                                </div>
                                <div class="border-top text-center py-2">
                                    <a href="{{ path('app_notifications') }}" class="text-decoration-none" style="font-size: 0.85rem;">Все уведомления</a>
                                </div>
                            </div>
                        </div>

                        {# User dropdown #}
                        <div class="dropdown">
                        <a class="btn btn-link text-decoration-none dropdown-toggle d-flex align-items-center gap-2 px-3 py-2" href="#" role="button" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="border: none; box-shadow: none; color: inherit;">
                            <i class="bi bi-person-circle" style="font-size: 1.25rem;"></i>
                            <span class="d-none d-md-inline" style="font-size: 0.9rem; font-weight: 500;">
                                {% if app.user.lastname or app.user.firstname %}
                                    {{ app.user.lastname ?? '' }} {{ app.user.firstname ?? '' }}
                                {% else %}
                                    {{ app.user.userIdentifier }}
                                {% endif %}
                            </span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm" aria-labelledby="userDropdown" style="min-width: 200px;">
                            <li>
                                <h6 class="dropdown-header text-truncate mb-0" style="max-width: 180px;">
                                    {% if app.user.lastname or app.user.firstname %}
                                        {{ app.user.lastname ?? '' }} {{ app.user.firstname ?? '' }} {{ app.user.patronymic ?? '' }}
                                    {% else %}
                                        {{ app.user.userIdentifier }}
                                    {% endif %}
                                </h6>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" href="{{ path('app_view_user', {id: app.user.id}) }}">
                                    <i class="bi bi-person me-2"></i>Мой профиль
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="{{ path('app_edit_user', {id: app.user.id}) }}">
                                    <i class="bi bi-gear me-2"></i>Настройки
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                                    <i class="bi bi-box-arrow-right me-2"></i>Выход
                                </a>
                            </li>
                        </ul>
                        </div>
                    </div>
                {% endif %}
            </div>
        </header>

        <div class="page-heading">

            {% block main %}{% endblock %}

        </div>

{#        <footer>#}
{#            <div class="footer clearfix mb-0 text-muted">#}
{#                <div class="float-start">#}
{#                    <p>2026 &copy; Copyright</p>#}
{#                </div>#}
{#                <div class="float-end">#}
{#                    <p>#}
{#                        Документооборот#}
{#                    </p>#}
{#                </div>#}
{#            </div>#}
{#        </footer>#}
    </div>


</div>
<script>
(function() {
    var sidebar = document.getElementById('sidebar');
    var btn = document.getElementById('sidebar-collapse-btn');
    if (!sidebar || !btn) return;
    var label = btn.querySelector('.sct-label');
    function updateLabel() {
        if (!label) return;
        label.textContent = sidebar.classList.contains('sidebar-collapsed') ? '' : 'Hide';
    }
    if (localStorage.getItem('sidebar-collapsed') === 'true') {
        sidebar.classList.add('sidebar-collapsed');
    }
    updateLabel();
    btn.addEventListener('click', function(e) {
        e.preventDefault();
        sidebar.classList.toggle('sidebar-collapsed');
        localStorage.setItem('sidebar-collapsed', sidebar.classList.contains('sidebar-collapsed'));
        updateLabel();
    });
})();
</script>
<script src="/front_end/assets/static/js/components/dark.js"></script>
<script src="/front_end/assets/extensions/perfect-scrollbar/perfect-scrollbar.min.js"></script>
<script>
    // Intercept PerfectScrollbar — skip sidebar-wrapper
    (function() {
        var Real = window.PerfectScrollbar;
        window.PerfectScrollbar = function(el, opts) {
            if (el && el.classList.contains('sidebar-wrapper')) {
                this.destroy = function() {};
                this.update = function() {};
                return;
            }
            return new Real(el, opts);
        };
        window.PerfectScrollbar.prototype = Real.prototype;
    })();
</script>

<script src="/front_end/assets/compiled/js/app.js"></script>
<script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>


<script>
    // If you want to use tooltips in your project, we suggest initializing them globally
    // instead of a "per-page" level.
    document.addEventListener('DOMContentLoaded', function () {
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    }, false);
</script>

{% if app.user %}
    <div class="toast-stack" id="toastStack"></div>
    <script src="/front_end/assets/static/js/notifications.js"></script>
{% endif %}

</body>

</html>
