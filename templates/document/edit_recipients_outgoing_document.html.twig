{% extends 'base_dashboard.html.twig' %}

{% block title %}Редактирование получателей: {{ document.name }}{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}

    <link rel="stylesheet" href="/front_end/assets/compiled/css/choices.min.css">

    <h1 class="mb-0">Редактирование получателей</h1>

    <section id="multiple-column-form">
        <div class="row match-height">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title">{{ document.name }}</h4>
                    </div>
                    <div class="card-content">
                        <div class="card-body">
                            <form action="{{ path('app_edit_recipients_outgoing_document', {'id': document.id}) }}" method="post" class="form">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('edit_recipients_outgoing_document') }}">

                                {% for message in app.flashes('error') %}
                                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                        {{ message }}
                                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                    </div>
                                {% endfor %}

                                {% for message in app.flashes('success') %}
                                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                                        {{ message }}
                                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                    </div>
                                {% endfor %}

                                <div class="row">
                                    <div class="col-12">
                                        <div class="form-group">
                                            <label for="document_executor_users">Пользователи исполнители</label>
                                            <div id="document_executor_users_trigger"
                                                 class="document-users-trigger"
                                                 data-target-select="document_executor_users"
                                                 style="cursor: pointer;"
                                                 title="Нажмите, чтобы выбрать по организациям">
                                                <select id="document_executor_users" class="form-control" name="executor_user_ids[]" multiple>
                                                    {% if executor_users is defined and executor_users|length > 0 %}
                                                        {% for user in executor_users %}
                                                            <option value="{{ user.id }}" selected>
                                                                {{ user.lastname }} {{ user.firstname }}{% if user.patronymic %} {{ user.patronymic }}{% endif %}
                                                            </option>
                                                        {% endfor %}
                                                    {% elseif users is defined and users|length > 0 %}
                                                        {% for user in users %}
                                                            <option value="{{ user.id }}" selected>
                                                                {{ user.lastname }} {{ user.firstname }}{% if user.patronymic %} {{ user.patronymic }}{% endif %}
                                                            </option>
                                                        {% endfor %}
                                                    {% endif %}
                                                </select>
                                            </div>
                                            <small class="text-muted">Нажмите на поле или кнопку ниже, чтобы выбрать исполнителей по организациям</small>
                                            <div class="mt-1">
                                                <button type="button"
                                                        class="btn btn-outline-secondary btn-sm"
                                                        data-target-select="document_executor_users"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#organizationUserModal">
                                                    Выбрать по организациям
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <div class="form-group">
                                            <label for="document_recipient_users">Пользователи получатели</label>
                                            <div id="document_recipient_users_trigger"
                                                 class="document-users-trigger"
                                                 data-target-select="document_recipient_users"
                                                 style="cursor: pointer;"
                                                 title="Нажмите, чтобы выбрать по организациям">
                                                <select id="document_recipient_users" class="form-control" name="recipient_user_ids[]" multiple>
                                                    {% if recipient_users is defined and recipient_users|length > 0 %}
                                                        {% for user in recipient_users %}
                                                            <option value="{{ user.id }}" selected>
                                                                {{ user.lastname }} {{ user.firstname }}{% if user.patronymic %} {{ user.patronymic }}{% endif %}
                                                            </option>
                                                        {% endfor %}
                                                    {% endif %}
                                                </select>
                                            </div>
                                            <small class="text-muted">Нажмите на поле или кнопку ниже, чтобы выбрать получателей по организациям</small>
                                            <div class="mt-1">
                                                <button type="button"
                                                        class="btn btn-outline-secondary btn-sm"
                                                        data-target-select="document_recipient_users"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#organizationUserModal">
                                                    Выбрать по организациям
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-12 d-flex justify-content-end">
                                        <button type="submit" class="btn btn-primary me-1 mb-1">Сохранить получателей</button>
                                        <a href="{{ path('app_view_outgoing_document', {'id': document.id}) }}" class="btn btn-light-secondary me-1 mb-1">Отмена</a>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div id="org-tree-data" data-users-url-template="{{ path('app_document_org_users', {'id': 0})|replace({'0':'__ORG__'}) }}" data-users-search-url="{{ path('app_document_users_search') }}">
        {% if organizations is defined and organizations|length > 0 %}
            {% for org in organizations %}
                {% if org %}
                    {% include 'document/_organization_tree_data.html.twig' with {'organization': org} %}
                {% endif %}
            {% endfor %}
        {% endif %}
    </div>

    {% include 'document/partials/_organization_user_modal.html.twig' %}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const userSelectIds = ['document_executor_users', 'document_recipient_users'];
            const choicesMap = {};

            userSelectIds.forEach(function (selectId) {
                const selectEl = document.getElementById(selectId);
                if (!selectEl || !window.Choices) {
                    return;
                }
                choicesMap[selectId] = new Choices(selectEl, {
                    removeItemButton: true,
                    searchEnabled: false,
                    itemSelectText: '',
                    noChoicesText: 'Нажмите на поле или «Выбрать по организациям»',
                });
            });

            function setModalTargetSelect(targetSelectId) {
                if (!targetSelectId) {
                    return;
                }
                window.__documentFlowOrgUserModalTargetSelect = targetSelectId;
                window.__documentFlowOrgUserModalChoices = choicesMap[targetSelectId] || null;
            }

            document.querySelectorAll('.document-users-trigger').forEach(function (triggerEl) {
                triggerEl.addEventListener('click', function (e) {
                    if (e.target.closest('.choices__button') || e.target.closest('.choices__item')) {
                        return;
                    }
                    e.preventDefault();
                    const targetSelectId = triggerEl.getAttribute('data-target-select');
                    setModalTargetSelect(targetSelectId);
                    var modalEl = document.getElementById('organizationUserModal');
                    if (modalEl) {
                        var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                        modal.show();
                    }
                });
            });

            document.querySelectorAll('button[data-bs-target="#organizationUserModal"]').forEach(function (buttonEl) {
                buttonEl.addEventListener('click', function () {
                    setModalTargetSelect(buttonEl.getAttribute('data-target-select'));
                });
            });

            setModalTargetSelect('document_executor_users');
        });
    </script>
    {% include 'document/partials/_organization_user_modal_script.html.twig' %}

{% endblock %}
