{% extends 'base_dashboard.html.twig' %}

{% block title %}Подписание документа: {{ document.name }}{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <h1 class="mb-4">Подписание документа</h1>

    <section class="section">
        <div class="card">
            <div class="card-header">
                <h4 class="card-title mb-0">{{ document.name }}</h4>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3 text-muted">Уровень подписи</dt>
                    <dd class="col-sm-9">{{ document.signatureLevel ? document.signatureLevel.label : 'Простая подпись' }}</dd>
                    <dt class="col-sm-3 text-muted">Хэш документа (SHA-256)</dt>
                    <dd class="col-sm-9"><code class="text-break">{{ document.canonicalFileHash ?? '—' }}</code></dd>
                    {% if document.canonicalFile %}
                        <dt class="col-sm-3 text-muted">Подписываемый файл</dt>
                        <dd class="col-sm-9">
                            <a href="{{ path('app_document_download_file', {id: document.id, type: 'original', inline: 1}) }}" target="_blank" rel="noopener">Просмотреть документ</a>
                        </dd>
                    {% endif %}
                </dl>
            </div>
        </div>

        {% if hasSigned %}
            <div class="alert alert-success mt-4">Вы уже подписали этот документ.</div>
        {% elseif not canSign %}
            <div class="alert alert-warning mt-4">
                {% if document.status.value != 'ON_SIGNING' %}
                    Документ не находится на подписании.
                {% else %}
                    Сейчас не ваша очередь подписывать документ.
                {% endif %}
            </div>
        {% else %}
            {% if allowSimple %}
                <div class="card mt-4">
                    <div class="card-header">
                        <h4 class="card-title mb-0">Простая электронная подпись (ПЭП)</h4>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">Для подтверждения подписи введите пароль от вашей учётной записи.</p>
                        <form method="post" action="{{ path('app_document_sign_simple', {id: document.id}) }}" class="row g-2 align-items-end">
                            <input type="hidden" name="_token" value="{{ csrf_token('sign_simple_' ~ document.id) }}">
                            <div class="col-md-5">
                                <label for="simple_sign_password" class="form-label">Пароль учётной записи</label>
                                <input type="password" id="simple_sign_password" name="password" class="form-control" autocomplete="current-password" required>
                            </div>
                            <div class="col-md-4">
                                <button type="submit" class="btn btn-success">Подписать (ПЭП)</button>
                            </div>
                        </form>
                    </div>
                </div>
            {% endif %}

            <div class="card mt-4">
                <div class="card-header">
                    <h4 class="card-title mb-0">Усиленная электронная подпись (УНЭП)</h4>
                </div>
                <div class="card-body">
                    <p class="text-muted">
                        Выберите файл ключа <code>.p12</code> (например, с флешки) и введите пароль контейнера.
                        Подпись формируется в браузере — ключ и пароль на сервер не передаются.
                    </p>
                    {% if certificates|length == 0 %}
                        <div class="alert alert-warning mb-0">
                            У вас нет активных сертификатов. Обратитесь к администратору за выпуском ключа подписи.
                        </div>
                    {% else %}
                        <form id="enhanced-sign-form"
                              action="{{ path('app_document_sign_enhanced', {id: document.id}) }}"
                              data-document-hash="{{ document.canonicalFileHash }}"
                              data-certificates="{{ certificates|json_encode|e('html_attr') }}"
                              class="row g-2 align-items-end">
                            <input type="hidden" name="_token" value="{{ csrf_token('sign_enhanced_' ~ document.id) }}">
                            <div class="col-md-5">
                                <label for="enhanced_sign_file" class="form-label">Файл ключа (.p12)</label>
                                <input type="file" id="enhanced_sign_file" name="p12_file" class="form-control" accept=".p12,.pfx" required>
                            </div>
                            <div class="col-md-4">
                                <label for="enhanced_sign_password" class="form-label">Пароль контейнера</label>
                                <input type="password" id="enhanced_sign_password" name="container_password" class="form-control" autocomplete="off" required>
                            </div>
                            <div class="col-md-3">
                                <button type="submit" class="btn btn-primary">Подписать (УНЭП)</button>
                            </div>
                        </form>
                        <div id="enhanced-sign-error" class="alert alert-danger mt-3 d-none" role="alert"></div>
                        <div class="text-muted small mt-2">
                            Ваши активные сертификаты:
                            {% for certificate in certificates %}
                                <code>{{ certificate.serialNumber }}</code> (до {{ certificate.validTo }}){{ not loop.last ? ',' }}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endif %}

        {% if document.status.value == 'ON_SIGNING' and not hasSigned %}
            <div class="card mt-4">
                <div class="card-header">
                    <h4 class="card-title mb-0">Отказ от подписания</h4>
                </div>
                <div class="card-body">
                    <p class="text-muted">Отказ переведёт документ в статус «Отклонен». Причина обязательна.</p>
                    <form method="post" action="{{ path('app_document_decline_signing', {id: document.id}) }}" class="row g-2 align-items-end">
                        <input type="hidden" name="_token" value="{{ csrf_token('decline_signing_' ~ document.id) }}">
                        <div class="col-md-9">
                            <label for="decline_reason" class="form-label">Причина отказа</label>
                            <textarea id="decline_reason" name="reason" class="form-control" rows="2" required></textarea>
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-outline-danger">Отказаться подписывать</button>
                        </div>
                    </form>
                </div>
            </div>
        {% endif %}

        <div class="mt-4">
            <a href="{{ path('app_view_incoming_document', {id: document.id}) }}" class="btn btn-light-secondary">Назад к документу</a>
        </div>
    </section>

    {{ importmap('document_sign') }}
{% endblock %}
