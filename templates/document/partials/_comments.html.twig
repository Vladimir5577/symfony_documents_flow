{# Блок комментариев к документу. Подключается через include в view-страницах. #}
{# Ожидает переменные: document (Document), currentUser (User|null) #}
{% set currentUser = currentUser ?? app.user %}
{% set isAdmin = is_granted('ROLE_ADMIN') %}

<div class="card mt-4" id="document-comments">
    <div class="card-header">
        <h4 class="card-title mb-0">Комментарии</h4>
    </div>
    <div class="card-body">
        {% if currentUser %}
            <form method="post"
                  action="{{ path('app_document_comment_create', {id: document.id}) }}"
                  enctype="multipart/form-data"
                  class="mb-4">
                <input type="hidden" name="_token" value="{{ csrf_token('document_comment_create_' ~ document.id) }}">
                <div class="mb-2">
                    <textarea name="body"
                              class="form-control"
                              rows="3"
                              placeholder="Напишите комментарий..."
                              maxlength="10000"></textarea>
                </div>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <input type="file"
                           name="files[]"
                           multiple
                           class="form-control form-control-sm"
                           style="max-width:320px;">
                    <small class="text-muted">до 25 МБ на файл</small>
                    <button type="submit" class="btn btn-primary ms-auto">Отправить</button>
                </div>
            </form>
        {% endif %}

        {% set comments = document.comments %}
        {% if comments|length > 0 %}
            <ul class="list-unstyled mb-0">
                {% for comment in comments|reverse %}
                    {% set author = comment.author %}
                    {% set canEdit = currentUser and (isAdmin or (author and author.id == currentUser.id)) %}
                    {% set canDelete = canEdit %}
                    <li class="pb-3 mb-3{% if not loop.last %} border-bottom{% endif %}" data-comment-id="{{ comment.id }}">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width:32px;height:32px;font-size:0.8rem;font-weight:600;">
                                {{ ((author.firstname|default(''))|slice(0, 1) ~ (author.lastname|default(''))|slice(0, 1))|upper|default('?') }}
                            </div>
                            <div class="flex-grow-1">
                                <div class="fw-semibold">
                                    {{ author.lastname }} {{ author.firstname }}{% if author.patronymic %} {{ author.patronymic }}{% endif %}
                                </div>
                                <small class="text-muted">
                                    {{ comment.createdAt|date('d.m.Y H:i') }}
                                    {% if comment.updatedAt and comment.updatedAt > comment.createdAt %}
                                        <span class="ms-1" title="Изменён {{ comment.updatedAt|date('d.m.Y H:i') }}">(изменён)</span>
                                    {% endif %}
                                </small>
                            </div>
                            {% if canEdit %}
                                <button type="button"
                                        class="btn btn-sm btn-link text-secondary p-0 flex-shrink-0 js-comment-edit-toggle"
                                        data-comment-id="{{ comment.id }}"
                                        title="Изменить">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            {% endif %}
                            {% if canDelete %}
                                <form method="post"
                                      action="{{ path('app_document_comment_delete', {id: comment.id}) }}"
                                      class="flex-shrink-0"
                                      onsubmit="return confirm('Удалить комментарий?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('document_comment_delete_' ~ comment.id) }}">
                                    <button type="submit" class="btn btn-sm btn-link text-danger p-0" title="Удалить">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            {% endif %}
                        </div>

                        <div class="js-comment-view{% if not comment.body %} d-none{% endif %}">
                            {% if comment.body %}
                                <div class="ms-5 mb-2" style="white-space:pre-wrap;word-break:break-word;">{{ comment.body }}</div>
                            {% endif %}
                        </div>

                        {% if canEdit %}
                            <form method="post"
                                  action="{{ path('app_document_comment_edit', {id: comment.id}) }}"
                                  class="ms-5 mb-2 js-comment-edit-form d-none"
                                  data-comment-id="{{ comment.id }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('document_comment_edit_' ~ comment.id) }}">
                                <textarea name="body"
                                          class="form-control mb-2"
                                          rows="3"
                                          maxlength="10000">{{ comment.body }}</textarea>
                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-sm btn-primary">Сохранить</button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary js-comment-edit-cancel"
                                            data-comment-id="{{ comment.id }}">Отмена</button>
                                </div>
                            </form>
                        {% endif %}

                        {% if comment.files|length > 0 %}
                            <ul class="list-group list-group-flush ms-5">
                                {% for file in comment.files %}
                                    {% set filename = file.filename ?? '' %}
                                    {% set ext = filename ? (filename|split('.')|last|lower) : '' %}
                                    <li class="list-group-item d-flex align-items-center gap-2 px-0 py-1 border-0">
                                        <i class="bi bi-paperclip text-muted"></i>
                                        <span class="flex-grow-1 text-truncate">{{ file.filename ?: '—' }}</span>
                                        {% if file.sizeBytes %}
                                            <small class="text-muted flex-shrink-0">
                                                {% if file.sizeBytes >= 1048576 %}
                                                    {{ (file.sizeBytes / 1048576)|number_format(1, '.', ' ') }} МБ
                                                {% elseif file.sizeBytes >= 1024 %}
                                                    {{ (file.sizeBytes / 1024)|number_format(0) }} КБ
                                                {% else %}
                                                    {{ file.sizeBytes }} Б
                                                {% endif %}
                                            </small>
                                        {% endif %}
                                        {% if ext in ['pdf'] %}
                                            <a href="{{ path('app_document_comment_file_download', {id: file.id, inline: 1}) }}"
                                               class="btn btn-sm btn-outline-secondary flex-shrink-0"
                                               target="_blank"
                                               rel="noopener">
                                                Просмотр
                                            </a>
                                        {% endif %}
                                        {% if ext in ['jpeg', 'jpg', 'png', 'gif', 'webp', 'bmp'] %}
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-secondary flex-shrink-0"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#imagePreviewModal"
                                                    data-image-url="{{ path('app_document_comment_file_download', {id: file.id, inline: 1}) }}">
                                                Просмотр
                                            </button>
                                        {% endif %}
                                        <a href="{{ path('app_document_comment_file_download', {id: file.id}) }}"
                                           class="btn btn-sm btn-outline-primary flex-shrink-0"
                                           download>
                                            Скачать
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p class="text-muted mb-0">Комментариев пока нет.</p>
        {% endif %}
    </div>
</div>

<script>
    (function () {
        var root = document.getElementById('document-comments');
        if (!root) return;

        function toggle(commentId, editing) {
            var li = root.querySelector('li[data-comment-id="' + commentId + '"]');
            if (!li) return;
            var view = li.querySelector('.js-comment-view');
            var form = li.querySelector('.js-comment-edit-form');
            if (!form) return;
            if (editing) {
                if (view) view.classList.add('d-none');
                form.classList.remove('d-none');
                var ta = form.querySelector('textarea[name="body"]');
                if (ta) { ta.focus(); ta.setSelectionRange(ta.value.length, ta.value.length); }
            } else {
                form.classList.add('d-none');
                if (view && view.querySelector('div')) view.classList.remove('d-none');
            }
        }

        root.addEventListener('click', function (e) {
            var toggleBtn = e.target.closest('.js-comment-edit-toggle');
            if (toggleBtn) { toggle(toggleBtn.dataset.commentId, true); return; }
            var cancelBtn = e.target.closest('.js-comment-edit-cancel');
            if (cancelBtn) { toggle(cancelBtn.dataset.commentId, false); }
        });
    })();
</script>
