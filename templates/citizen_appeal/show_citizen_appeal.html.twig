{% extends 'base_dashboard.html.twig' %}

{% block title %}Обращение {{ appeal.publicId }}{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}

{% for message in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
{% endfor %}

<h1>Обращение {{ appeal.publicId }}</h1>

<div class="mb-3">
    <a href="{{ path('app_citizen_appeal') }}" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Назад к списку
    </a>
</div>

<section class="section">

    <div class="card mb-3">
        <div class="card-header">
            <h4 class="card-title mb-0">Данные заявителя</h4>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3 text-muted">ФИО</dt>
                <dd class="col-sm-9">{{ appeal.fio }}</dd>

                <dt class="col-sm-3 text-muted">Телефон</dt>
                <dd class="col-sm-9">{{ appeal.phone ?? '—' }}</dd>

                <dt class="col-sm-3 text-muted">Email</dt>
                <dd class="col-sm-9">{{ appeal.email ?? '—' }}</dd>

                <dt class="col-sm-3 text-muted">Способ ответа</dt>
                <dd class="col-sm-9">
                    {% if appeal.replyTo == 'any' %}Любой
                    {% elseif appeal.replyTo == 'phone' %}По телефону
                    {% elseif appeal.replyTo == 'email' %}По email
                    {% else %}Ответ не нужен
                    {% endif %}
                </dd>
            </dl>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">
            <h4 class="card-title mb-0">Обращение</h4>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3 text-muted">Статус</dt>
                <dd class="col-sm-9">
                    {% if appeal.status == 'new' %}
                        <span class="badge bg-secondary">{{ appeal.statusLabel }}</span>
                    {% elseif appeal.status == 'in_progress' %}
                        <span class="badge bg-warning text-dark">{{ appeal.statusLabel }}</span>
                    {% else %}
                        <span class="badge bg-success">{{ appeal.statusLabel }}</span>
                    {% endif %}
                </dd>

                <dt class="col-sm-3 text-muted">Тип обращения</dt>
                <dd class="col-sm-9">{{ appeal.appealTypeLabel }}</dd>

                <dt class="col-sm-3 text-muted">Город</dt>
                <dd class="col-sm-9">{{ appeal.cityLabel }}</dd>

                <dt class="col-sm-3 text-muted">Адрес</dt>
                <dd class="col-sm-9">{{ appeal.address }}</dd>

                <dt class="col-sm-3 text-muted">Дата подачи</dt>
                <dd class="col-sm-9">{{ appeal.createdAt|date('d.m.Y H:i') }}</dd>

                <dt class="col-sm-3 text-muted">Дата обновления</dt>
                <dd class="col-sm-9">{{ appeal.updatedAt|date('d.m.Y H:i') }}</dd>

                {% if appeal.message %}
                    <dt class="col-sm-3 text-muted">Текст обращения</dt>
                    <dd class="col-sm-9">
                        <div class="border rounded p-3" style="background: var(--bs-secondary-bg);">{{ appeal.message|nl2br }}</div>
                    </dd>
                {% endif %}

                {% if appeal.adminComment %}
                    <dt class="col-sm-3 text-muted">Комментарий администратора</dt>
                    <dd class="col-sm-9">
                        <div class="border rounded p-3" style="background: var(--bs-secondary-bg);">{{ appeal.adminComment|nl2br }}</div>
                    </dd>
                {% endif %}
            </dl>
        </div>
    </div>

    {% if appeal.files|length > 0 %}
        <div class="card mb-3">
            <div class="card-header">
                <h4 class="card-title mb-0">Прикреплённые файлы ({{ appeal.files|length }})</h4>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    {% for file in appeal.files %}
                        {% set ext = file.originalName|split('.')|last|lower %}
                        <li class="list-group-item d-flex align-items-center gap-3 px-3">
                            <div class="flex-shrink-0 rounded d-flex align-items-center justify-content-center text-muted" style="width: 40px; height: 40px; background: var(--bs-secondary-bg);">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16"><path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5h-2z"/></svg>
                            </div>
                            <span class="flex-grow-1">
                                {{ file.originalName }}
                                <span class="text-muted small ms-2">{{ file.fileSizeFormatted }}</span>
                            </span>
                            {% if ext in ['pdf'] %}
                                <a href="{{ file.url }}" class="btn btn-sm btn-outline-secondary flex-shrink-0" target="_blank" rel="noopener">
                                    Просмотр
                                </a>
                            {% endif %}
                            {% if ext in ['jpeg', 'jpg', 'png', 'gif', 'webp', 'bmp'] %}
                                <button type="button"
                                        class="btn btn-sm btn-outline-secondary flex-shrink-0"
                                        data-bs-toggle="modal"
                                        data-bs-target="#imagePreviewModal"
                                        data-image-url="{{ file.url }}">
                                    Просмотр
                                </button>
                            {% endif %}
                            <a href="{{ file.url }}" class="btn btn-sm btn-outline-primary flex-shrink-0" download target="_blank" rel="noopener">
                                Скачать
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    {% endif %}

    <div class="card mb-3">
        <div class="card-header">
            <h4 class="card-title mb-0">Изменить статус</h4>
        </div>
        <div class="card-body d-flex gap-2">
            <form method="post" action="{{ path('app_citizen_appeal_update', {id: appeal.id}) }}" class="d-inline">
                <input type="hidden" name="status" value="new">
                <button type="submit" class="btn {{ appeal.status == 'new' ? 'btn-secondary' : 'btn-outline-secondary' }}">
                    Новое
                </button>
            </form>
            <form method="post" action="{{ path('app_citizen_appeal_update', {id: appeal.id}) }}" class="d-inline">
                <input type="hidden" name="status" value="in_progress">
                <button type="submit" class="btn {{ appeal.status == 'in_progress' ? 'btn-warning' : 'btn-outline-warning' }}">
                    В работе
                </button>
            </form>
            <form method="post" action="{{ path('app_citizen_appeal_update', {id: appeal.id}) }}" class="d-inline">
                <input type="hidden" name="status" value="done">
                <button type="submit" class="btn {{ appeal.status == 'done' ? 'btn-success' : 'btn-outline-success' }}">
                    Обработано
                </button>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h4 class="card-title mb-0">Комментарий администратора</h4>
        </div>
        <div class="card-body">
            <form method="post" action="{{ path('app_citizen_appeal_update', {id: appeal.id}) }}">
                <div class="mb-3">
                    <textarea name="adminComment" class="form-control" rows="4">{{ appeal.adminComment }}</textarea>
                </div>
                <button type="submit" class="btn btn-primary">Сохранить</button>
            </form>
        </div>
    </div>

</section>

<div class="modal fade" id="imagePreviewModal" tabindex="-1" aria-labelledby="imagePreviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="imagePreviewModalLabel">Просмотр изображения</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
            </div>
            <div class="modal-body text-center p-0 bg-dark d-flex align-items-center justify-content-center" style="min-height: calc(100vh - 60px);">
                <img src="" alt="Просмотр" class="img-fluid" id="imagePreviewModalImg" style="max-height: calc(100vh - 60px); max-width: 100%; object-fit: contain;">
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('imagePreviewModal')?.addEventListener('show.bs.modal', function (event) {
        var button = event.relatedTarget;
        var imageUrl = button?.getAttribute('data-image-url');
        var img = document.getElementById('imagePreviewModalImg');
        if (img && imageUrl) { img.src = imageUrl; }
    });
    document.getElementById('imagePreviewModal')?.addEventListener('hidden.bs.modal', function () {
        var img = document.getElementById('imagePreviewModalImg');
        if (img) { img.src = ''; }
    });
</script>

{% endblock %}
