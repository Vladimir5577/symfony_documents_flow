{% extends 'base_dashboard.html.twig' %}

{% block title %}Обращения граждан{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}

<h1>Обращения граждан</h1>

{% for message in app.flashes('error') %}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
{% endfor %}

<section class="section">

    <div class="card mb-3">
        <div class="card-header">
            <h5 class="card-title mb-0">Фильтры</h5>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label mb-1">Поиск</label>
                    <input type="text" name="search" class="form-control form-control-sm" placeholder="ФИО или адрес" value="{{ filters.search }}">
                </div>
                <div class="col-md-2">
                    <label class="form-label mb-1">Статус</label>
                    <select name="status" class="form-select form-select-sm">
                        <option value="">— Все —</option>
                        <option value="new"         {{ filters.status == 'new'         ? 'selected' : '' }}>Новое</option>
                        <option value="in_progress" {{ filters.status == 'in_progress' ? 'selected' : '' }}>В работе</option>
                        <option value="done"        {{ filters.status == 'done'        ? 'selected' : '' }}>Обработано</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label mb-1">Город</label>
                    <select name="city" class="form-select form-select-sm">
                        <option value="">— Все —</option>
                        <option value="donetsk"      {{ filters.city == 'donetsk'      ? 'selected' : '' }}>Донецк</option>
                        <option value="makeyevka"    {{ filters.city == 'makeyevka'    ? 'selected' : '' }}>Макеевка</option>
                        <option value="mariupol"     {{ filters.city == 'mariupol'     ? 'selected' : '' }}>Мариуполь</option>
                        <option value="gorlovka"     {{ filters.city == 'gorlovka'     ? 'selected' : '' }}>Горловка</option>
                        <option value="enakievo"     {{ filters.city == 'enakievo'     ? 'selected' : '' }}>Енакиево</option>
                        <option value="shakhtersk"   {{ filters.city == 'shakhtersk'   ? 'selected' : '' }}>Шахтёрск</option>
                        <option value="torez"        {{ filters.city == 'torez'        ? 'selected' : '' }}>Торез</option>
                        <option value="amvrosievka"  {{ filters.city == 'amvrosievka'  ? 'selected' : '' }}>Амвросиевка</option>
                        <option value="yasinovataya" {{ filters.city == 'yasinovataya' ? 'selected' : '' }}>Ясиноватая</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label mb-1">Дата от</label>
                    <input type="date" name="dateFrom" class="form-control form-control-sm" value="{{ filters.dateFrom }}">
                </div>
                <div class="col-md-2">
                    <label class="form-label mb-1">Дата до</label>
                    <input type="date" name="dateTo" class="form-control form-control-sm" value="{{ filters.dateTo }}">
                </div>
                <div class="col-12 d-flex gap-2 justify-content-end">
                    <a href="{{ path('app_citizen_appeal') }}" class="btn btn-outline-secondary btn-sm">Сбросить</a>
                    <button type="submit" class="btn btn-primary btn-sm">Применить</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <p class="text-muted mb-0">Всего обращений: {{ list ? list.total : 0 }}</p>
        </div>
        <div class="card-body p-0">
            {% if list and list.items|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>№</th>
                                <th>ФИО</th>
                                <th>Телефон</th>
                                <th>Тип</th>
                                <th>Город</th>
                                <th>Статус</th>
                                <th>Дата подачи</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for appeal in list.items %}
                                <tr class="appeal-row" data-href="{{ path('app_citizen_appeal_show', {id: appeal.id}) }}" role="button" tabindex="0">
                                    <td><span class="text-muted small">{{ appeal.publicId }}</span></td>
                                    <td>{{ appeal.fio }}</td>
                                    <td class="text-muted small">{{ appeal.phone ?? '—' }}</td>
                                    <td>{{ appeal.appealTypeLabel }}</td>
                                    <td>{{ appeal.cityLabel }}</td>
                                    <td>
                                        {% if appeal.status == 'new' %}
                                            <span class="badge bg-secondary">{{ appeal.statusLabel }}</span>
                                        {% elseif appeal.status == 'in_progress' %}
                                            <span class="badge bg-warning text-dark">{{ appeal.statusLabel }}</span>
                                        {% else %}
                                            <span class="badge bg-success">{{ appeal.statusLabel }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-muted small">{{ appeal.createdAt|date('d.m.Y H:i') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {% if list.pages > 1 %}
                    <div class="card-footer">
                        <nav>
                            <ul class="pagination pagination-sm justify-content-center mb-0">
                                {% if list.page > 1 %}
                                    <li class="page-item">
                                        <a class="page-link" href="{{ path('app_citizen_appeal', filters|merge({page: list.page - 1})) }}">«</a>
                                    </li>
                                {% endif %}
                                {% for p in 1..list.pages %}
                                    <li class="page-item {{ p == list.page ? 'active' : '' }}">
                                        <a class="page-link" href="{{ path('app_citizen_appeal', filters|merge({page: p})) }}">{{ p }}</a>
                                    </li>
                                {% endfor %}
                                {% if list.page < list.pages %}
                                    <li class="page-item">
                                        <a class="page-link" href="{{ path('app_citizen_appeal', filters|merge({page: list.page + 1})) }}">»</a>
                                    </li>
                                {% endif %}
                            </ul>
                        </nav>
                    </div>
                {% endif %}

            {% elseif list %}
                <div class="text-center text-muted py-5">
                    <i class="bi bi-inbox fs-1"></i>
                    <p class="mt-2">Обращений не найдено</p>
                </div>
            {% endif %}
        </div>
    </div>

</section>

<style>
    tr.appeal-row { cursor: pointer; }
</style>

<script>
document.querySelectorAll('tr.appeal-row[data-href]').forEach(function(row) {
    row.addEventListener('click', function() {
        window.location.href = this.dataset.href;
    });
});
</script>

{% endblock %}
