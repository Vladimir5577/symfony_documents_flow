<div class="post-comment d-flex gap-2 py-2">
    <div class="comment-avatar flex-shrink-0">
        {% if comment.user.avatarName %}
            <img src="/uploads/users/{{ comment.user.id }}/{{ comment.user.avatarName }}"
                 alt="" class="rounded-circle" width="32" height="32" style="object-fit:cover">
        {% else %}
            <div class="rounded-circle bg-secondary-subtle d-flex align-items-center justify-content-center"
                 style="width:32px;height:32px;font-size:0.75rem;font-weight:600;color:var(--bs-primary)">
                {{ comment.user.lastname|default('?')|first }}{{ comment.user.firstname|default('')|first }}
            </div>
        {% endif %}
    </div>
    <div class="flex-grow-1">
        <div class="d-flex align-items-baseline gap-2">
            <span class="fw-semibold small">{{ comment.user.lastname }} {{ comment.user.firstname }}</span>
            <span class="text-muted" style="font-size:0.7rem">{{ comment.createdAt|date('d.m.Y H:i') }}</span>
        </div>
        <div class="small mt-1" style="white-space:pre-line">{{ comment.content }}</div>
    </div>
</div>
