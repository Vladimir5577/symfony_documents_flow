{% extends 'base_dashboard.html.twig' %}

{% block title %}Редактирование участников: {{ project.name }}{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}
    <link rel="stylesheet" href="/front_end/assets/compiled/css/choices.min.css">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Редактирование участников проекта</h1>
        <a href="{{ path('app_kanban_project', {id: project.id}) }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>
            К проекту
        </a>
    </div>

    <section id="multiple-column-form">
        <div class="row match-height">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h4 class="card-title mb-0">{{ project.name }}</h4>
                    </div>
                    <div class="card-content">
                        <div class="card-body">
                            <form action="{{ path('app_kanban_edit_project_members', {id: project.id}) }}" method="post" class="form">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('edit_project_members') }}">

                                {% for message in app.flashes('error') %}
                                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                        {{ message }}
                                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                    </div>
                                {% endfor %}

                                {% for message in app.flashes('success') %}
                                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                                        {{ message }}
                                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                    </div>
                                {% endfor %}

                                <div class="row">
                                    <div class="col-12">
                                        <div class="form-group mb-3">
                                            <label for="project_member_users">Участники проекта</label>
                                            <div id="project_member_users_trigger" style="cursor: pointer;" title="Нажмите, чтобы выбрать по организациям">
                                                <select id="project_member_users" class="form-control" name="user_ids[]" multiple>
                                                    {% if users is defined and users|length > 0 %}
                                                        {% for user in users %}
                                                            <option value="{{ user.id }}" selected>
                                                                {{ user.lastname }} {{ user.firstname }}{% if user.patronymic %} {{ user.patronymic }}{% endif %}
                                                            </option>
                                                        {% endfor %}
                                                    {% endif %}
                                                </select>
                                            </div>
                                            <small class="text-muted">Нажмите на поле или кнопку ниже, чтобы выбрать участников по организациям</small>
                                            <div class="mt-1">
                                                <button type="button"
                                                        class="btn btn-outline-secondary btn-sm"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#organizationUserModal">
                                                    Выбрать по организациям
                                                </button>
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label>Роли участников</label>
                                            <div class="table-responsive">
                                                <table class="table table-sm table-hover mb-0">
                                                    <thead>
                                                        <tr>
                                                            <th>Участник</th>
                                                            <th style="width:220px;">Роль</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="members-roles-tbody">
                                                        {% set ownerId = project.owner ? project.owner.id : null %}
                                                        {% for pu in projectUsers %}
                                                            {% if pu.user %}
                                                            <tr data-user-id="{{ pu.user.id }}">
                                                                <td>{{ pu.user.lastname }} {{ pu.user.firstname }}{% if pu.user.patronymic %} {{ pu.user.patronymic }}{% endif %}</td>
                                                                <td>
                                                                    {% if pu.user.id == ownerId %}
                                                                        <select name="member_roles[{{ pu.user.id }}]" class="form-select form-select-sm" disabled>
                                                                            <option value="KANBAN_ADMIN" selected>{{ kanban_roles['KANBAN_ADMIN'] ?? 'Администратор канбан' }}</option>
                                                                        </select>
                                                                        <input type="hidden" name="member_roles[{{ pu.user.id }}]" value="KANBAN_ADMIN">
                                                                    {% else %}
                                                                        <select name="member_roles[{{ pu.user.id }}]" class="form-select form-select-sm">
                                                                            {% for value, label in kanban_roles %}
                                                                                <option value="{{ value }}" {{ pu.role and pu.role.value == value ? 'selected' : '' }}>{{ label }}</option>
                                                                            {% endfor %}
                                                                        </select>
                                                                    {% endif %}
                                                                </td>
                                                            </tr>
                                                            {% endif %}
                                                        {% endfor %}
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-12 d-flex justify-content-end">
                                        <button type="submit" class="btn btn-primary me-1 mb-1">Сохранить участников</button>
                                        <a href="{{ path('app_kanban_project', {id: project.id}) }}" class="btn btn-light-secondary me-1 mb-1">Отмена</a>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div id="org-tree-data" data-users-url-template="{{ path('app_document_org_users', {'id': 0})|replace({'0':'__ORG__'}) }}">
        {% if organizations is defined and organizations|length > 0 %}
            {% for org in organizations %}
                {% if org %}
                    {% include 'document/_organization_tree_data.html.twig' with {'organization': org} %}
                {% endif %}
            {% endfor %}
        {% endif %}
    </div>

    {% include 'document/partials/_organization_user_modal.html.twig' %}

    <div id="members-roles-data" data-role-choices="{{ kanban_roles|json_encode }}" data-owner-id="{{ project.owner ? project.owner.id : '' }}"></div>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const usersSelect = document.getElementById('project_member_users');
            const usersTrigger = document.getElementById('project_member_users_trigger');
            const tbody = document.getElementById('members-roles-tbody');
            const dataEl = document.getElementById('members-roles-data');
            const roleChoices = dataEl && dataEl.dataset.roleChoices ? JSON.parse(dataEl.dataset.roleChoices) : {};
            const ownerId = dataEl && dataEl.dataset.ownerId ? String(dataEl.dataset.ownerId) : '';
            let choicesInstance = null;

            function syncMembersTable() {
                if (!tbody || !usersSelect) return;
                const selected = Array.from(usersSelect.selectedOptions || usersSelect.querySelectorAll('option:checked'));
                const currentIds = new Set(Array.from(tbody.querySelectorAll('tr[data-user-id]')).map(function (tr) { return tr.dataset.userId; }));
                const selectedIds = new Set(selected.map(function (opt) { return String(opt.value); }));

                selected.forEach(function (opt) {
                    const id = String(opt.value);
                    const name = (opt.textContent || opt.label || '').trim() || 'Пользователь #' + id;
                    if (currentIds.has(id)) return;
                    const tr = document.createElement('tr');
                    tr.dataset.userId = id;
                    let roleHtml;
                    if (id === ownerId) {
                        roleHtml = '<select class="form-select form-select-sm" disabled><option value="KANBAN_ADMIN">' + (roleChoices['KANBAN_ADMIN'] || 'Администратор канбан') + '</option></select><input type="hidden" name="member_roles[' + id + ']" value="KANBAN_ADMIN">';
                    } else {
                        roleHtml = '<select name="member_roles[' + id + ']" class="form-select form-select-sm">' +
                            Object.keys(roleChoices).map(function (v) {
                                return '<option value="' + v + '"' + (v === 'KANBAN_EDITOR' ? ' selected' : '') + '>' + (roleChoices[v] || v) + '</option>';
                            }).join('') + '</select>';
                    }
                    tr.innerHTML = '<td>' + name + '</td><td>' + roleHtml + '</td>';
                    tbody.appendChild(tr);
                    currentIds.add(id);
                });

                Array.from(tbody.querySelectorAll('tr[data-user-id]')).forEach(function (tr) {
                    if (!selectedIds.has(tr.dataset.userId)) tr.remove();
                });
            }

            if (usersSelect && window.Choices) {
                choicesInstance = new Choices(usersSelect, {
                    removeItemButton: true,
                    searchEnabled: false,
                    itemSelectText: '',
                    noChoicesText: 'Нажмите на поле или «Выбрать по организациям»',
                });
                usersSelect.addEventListener('change', syncMembersTable);
            }

            var addBtn = document.getElementById('add-selected-users-btn');
            if (addBtn) {
                addBtn.addEventListener('click', function () { setTimeout(syncMembersTable, 50); });
            }

            if (usersTrigger) {
                usersTrigger.addEventListener('click', function (e) {
                    if (e.target.closest('.choices__button') || e.target.closest('.choices__item')) {
                        return;
                    }
                    e.preventDefault();
                    var modalEl = document.getElementById('organizationUserModal');
                    if (modalEl) {
                        var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                        modal.show();
                    }
                });
            }

            window.__projectFlowOrgUserModalChoices = choicesInstance;
        });
    </script>
    {% include 'kanban/partials/_organization_user_modal_script.html.twig' %}
{% endblock %}
