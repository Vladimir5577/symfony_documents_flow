                </div>
            </div>
        </div>
    </div>

    {# Toast container #}
    <div class="kanban-toast-container" id="toast-container"></div>

    {# Gradient Color Picker #}
    <div id="gp-btn" style="position:fixed;bottom:5.5rem;right:1.5rem;z-index:9998;">
        <button id="gp-toggle" title="Настройка цветов" style="width:2.8rem;height:2.8rem;padding:0;border-radius:50%;border:none;background:var(--bs-body-bg);box-shadow:0 4px 16px rgba(0,0,0,0.18);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1.2rem;transition:transform 0.2s;">
            🎨
        </button>
    </div>

    <div id="gp-panel" style="display:none;position:fixed;bottom:8rem;right:1rem;z-index:9997;background:var(--bs-body-bg);border:1px solid var(--bs-border-color);border-radius:0.75rem;padding:0.75rem;box-shadow:0 8px 40px rgba(0,0,0,0.18);width:185px;">
        <div style="font-weight:600;font-size:0.8rem;margin-bottom:0.6rem;">Цвета</div>

        <div style="font-size:0.65rem;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;color:var(--bs-secondary-color);margin-bottom:0.35rem;">Пресеты</div>
        <div id="gp-presets" style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.3rem;margin-bottom:0.75rem;"></div>

        <div style="font-size:0.65rem;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;color:var(--bs-secondary-color);margin-bottom:0.25rem;">Фон</div>
        <div style="display:flex;gap:0.25rem;align-items:center;margin-bottom:0.5rem;">
            <input type="color" id="gp-main-bg" style="width:100%;height:1.6rem;border-radius:0.25rem;border:1px solid var(--bs-border-color);cursor:pointer;padding:0.05rem;">
            <button id="gp-main-bg-clear" title="Сбросить" style="padding:0.15rem 0.35rem;border-radius:0.25rem;border:1px solid var(--bs-border-color);background:transparent;color:var(--bs-body-color);font-size:0.7rem;cursor:pointer;flex-shrink:0;">✕</button>
        </div>

        <div style="font-size:0.65rem;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;color:var(--bs-secondary-color);margin-bottom:0.25rem;">Столбцы</div>
        <div style="display:flex;gap:0.25rem;align-items:center;margin-bottom:0.5rem;">
            <input type="color" id="gp-col-bg" style="width:100%;height:1.6rem;border-radius:0.25rem;border:1px solid var(--bs-border-color);cursor:pointer;padding:0.05rem;">
            <button id="gp-col-bg-clear" title="Сбросить" style="padding:0.15rem 0.35rem;border-radius:0.25rem;border:1px solid var(--bs-border-color);background:transparent;color:var(--bs-body-color);font-size:0.7rem;cursor:pointer;flex-shrink:0;">✕</button>
        </div>

        <div style="font-size:0.65rem;font-weight:500;text-transform:uppercase;letter-spacing:0.05em;color:var(--bs-secondary-color);margin-bottom:0.25rem;">Карточки</div>
        <div style="display:flex;gap:0.25rem;align-items:center;">
            <input type="color" id="gp-card-bg" style="width:100%;height:1.6rem;border-radius:0.25rem;border:1px solid var(--bs-border-color);cursor:pointer;padding:0.05rem;">
            <button id="gp-card-bg-clear" title="Сбросить" style="padding:0.15rem 0.35rem;border-radius:0.25rem;border:1px solid var(--bs-border-color);background:transparent;color:var(--bs-body-color);font-size:0.7rem;cursor:pointer;flex-shrink:0;">✕</button>
        </div>
    </div>

    <script>
    (function() {
        var mainBgStyleEl = document.createElement('style');
        document.head.appendChild(mainBgStyleEl);
        var colBgStyleEl  = document.createElement('style');
        document.head.appendChild(colBgStyleEl);
        var cardBgStyleEl = document.createElement('style');
        document.head.appendChild(cardBgStyleEl);

        function getTheme() {
            return document.documentElement.getAttribute('data-bs-theme') === 'dark' ? 'dark' : 'light';
        }
        function lsKey(name) { return 'kanban_' + name + '_' + getTheme(); }

        function applyMainBg(color) {
            mainBgStyleEl.textContent = color
                ? 'html,body,#app,#main{background:' + color + '!important;background-color:' + color + '!important;animation:none!important;background-size:unset!important;}'
                : '';
            color ? localStorage.setItem(lsKey('mainBg'), color) : localStorage.removeItem(lsKey('mainBg'));
        }
        function applyColBg(color) {
            colBgStyleEl.textContent = color
                ? '.kanban-column{background:' + color + '!important;animation:none!important;}'
                : '';
            color ? localStorage.setItem(lsKey('colBg'), color) : localStorage.removeItem(lsKey('colBg'));
        }
        function applyCardBg(color) {
            cardBgStyleEl.textContent = color
                ? '.kanban-card{background:' + color + '!important;}'
                : '';
            color ? localStorage.setItem(lsKey('cardBg'), color) : localStorage.removeItem(lsKey('cardBg'));
        }

        function restoreForTheme() {
            var m = localStorage.getItem(lsKey('mainBg')) || '';
            var c = localStorage.getItem(lsKey('colBg'))  || '';
            var k = localStorage.getItem(lsKey('cardBg')) || '';
            applyMainBg(m); applyColBg(c); applyCardBg(k);
            return { mainBg: m, colBg: c, cardBg: k };
        }

        restoreForTheme();

        var PRESETS = {
            light: [
                { name: 'Рассвет', bg: '#ddd5c8', col: '#f5f0e8', card: '#ffffff' },
                { name: 'Сирень',  bg: '#dbd3f0', col: '#ede8fa', card: '#ffffff' },
                { name: 'Мята',    bg: '#cce8dd', col: '#e8f7f2', card: '#ffffff' },
                { name: 'Небо',    bg: '#c8dff0', col: '#e4f1fb', card: '#ffffff' },
                { name: 'Персик',  bg: '#f2bfa8', col: '#fde5d5', card: '#ffffff' },
                { name: 'Лайм',    bg: '#c8e890', col: '#e8f7c0', card: '#ffffff' },
            ],
            dark: [
                { name: 'Полночь', bg: '#090d15', col: '#222c49', card: '#0a1124' },
                { name: 'Изумруд', bg: '#081b14', col: '#163c29', card: '#0b2217' },
                { name: 'Аметист', bg: '#120d1f', col: '#1e1535', card: '#261c42' },
                { name: 'Уголь',   bg: '#1f1f1f', col: '#383838', card: '#141414' },
                { name: 'Вишня',   bg: '#230614', col: '#45122b', card: '#220714' },
                { name: 'Космос',  bg: '#05081e', col: '#151956', card: '#0a0c29' },
            ],
        };

        document.addEventListener('DOMContentLoaded', function() {
            var panel        = document.getElementById('gp-panel');
            var toggle       = document.getElementById('gp-toggle');
            var mainBgInput  = document.getElementById('gp-main-bg');
            var colBgInput   = document.getElementById('gp-col-bg');
            var cardBgInput  = document.getElementById('gp-card-bg');
            var presetsContainer = document.getElementById('gp-presets');

            function isDark() { return getTheme() === 'dark'; }

            function syncInputs() {
                var s = restoreForTheme();
                if (s.mainBg) mainBgInput.value = s.mainBg;
                if (s.colBg)  colBgInput.value  = s.colBg;
                if (s.cardBg) cardBgInput.value = s.cardBg;
            }
            syncInputs();

            function buildPreset(p) {
                var dark = isDark();
                var btn = document.createElement('button');
                btn.style.cssText = 'border:none;border-radius:0.4rem;cursor:pointer;padding:0;overflow:hidden;box-shadow:0 2px 6px rgba(0,0,0,0.18);transition:transform 0.15s,box-shadow 0.2s;text-align:left;width:100%;';
                btn.innerHTML =
                    '<div style="background:' + p.bg + ';padding:0.3rem 0.3rem 0.2rem;">' +
                        '<div style="background:' + p.col + ';border-radius:0.2rem;padding:0.2rem 0.25rem;">' +
                            '<div style="background:' + p.card + ';border-radius:0.15rem;height:0.3rem;margin-bottom:0.12rem;"></div>' +
                            '<div style="background:' + p.card + ';border-radius:0.15rem;height:0.3rem;opacity:0.6;"></div>' +
                        '</div>' +
                    '</div>' +
                    '<div style="background:' + p.col + ';padding:0.15rem 0.25rem;font-size:0.6rem;font-weight:600;color:' + (dark ? '#eee' : '#333') + ';white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + p.name + '</div>';
                btn.addEventListener('mouseenter', function() { btn.style.transform = 'translateY(-2px)'; btn.style.boxShadow = '0 6px 16px rgba(0,0,0,0.28)'; });
                btn.addEventListener('mouseleave', function() { btn.style.transform = ''; btn.style.boxShadow = '0 2px 8px rgba(0,0,0,0.18)'; });
                btn.addEventListener('click', function() {
                    applyMainBg(p.bg); applyColBg(p.col); applyCardBg(p.card);
                    mainBgInput.value = p.bg; colBgInput.value = p.col; cardBgInput.value = p.card;
                });
                return btn;
            }

            function renderPresets() {
                presetsContainer.innerHTML = '';
                (isDark() ? PRESETS.dark : PRESETS.light).forEach(function(p) {
                    presetsContainer.appendChild(buildPreset(p));
                });
            }
            renderPresets();

            // На смену темы — восстановить цвета новой темы и обновить пресеты/инпуты
            new MutationObserver(function() {
                syncInputs();
                renderPresets();
            }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-bs-theme'] });

            mainBgInput.addEventListener('input',  function() { applyMainBg(this.value); });
            colBgInput.addEventListener('input',   function() { applyColBg(this.value); });
            cardBgInput.addEventListener('input',  function() { applyCardBg(this.value); });

            document.getElementById('gp-main-bg-clear').addEventListener('click',  function() { applyMainBg(''); });
            document.getElementById('gp-col-bg-clear').addEventListener('click',   function() { applyColBg(''); });
            document.getElementById('gp-card-bg-clear').addEventListener('click',  function() { applyCardBg(''); });

            toggle.addEventListener('click', function() {
                panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
                toggle.style.transform = panel.style.display === 'none' ? '' : 'rotate(20deg)';
            });

            document.addEventListener('click', function(e) {
                if (!e.target.closest('#gp-panel') && !e.target.closest('#gp-btn')) {
                    panel.style.display = 'none';
                    toggle.style.transform = '';
                }
            });
        });
    })();
    </script>

    <script>
        (function() {
            document.addEventListener('DOMContentLoaded', function() {
                var container = document.getElementById('create-board-columns');
                var addBtn = document.getElementById('create-board-add-column');
                if (!container || !addBtn) return;
                addBtn.addEventListener('click', function() {
                    var row = document.createElement('div');
                    row.className = 'input-group input-group-sm mb-2 column-row';
                    row.innerHTML = '<input type="text" class="form-control" name="columns[]" value="" maxlength="200" placeholder="Название столбца">' +
                        '<button type="button" class="btn btn-outline-secondary create-board-remove-column" title="Удалить столбец"><i class="bi bi-dash-lg"></i></button>';
                    container.appendChild(row);
                    row.querySelector('.create-board-remove-column').addEventListener('click', function() {
                        if (container.querySelectorAll('.column-row').length > 1) row.remove();
                    });
                });
                container.addEventListener('click', function(e) {
                    var btn = e.target.closest('.create-board-remove-column');
                    if (btn) {
                        var row = btn.closest('.column-row');
                        if (row && container.querySelectorAll('.column-row').length > 1) row.remove();
                    }
                });
            });
        })();
    </script>
    <script src="/front_end/assets/extensions/dragula/dragula.min.js"></script>
    <script src="/front_end/assets/js/kanban.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            KanbanApp.init({
                boardId: '{{ board.id }}',
                projectId: {{ board.project ? board.project.id : 'null' }},
                canEdit: {{ memberRole.value != 'VIEWER' ? 'true' : 'false' }},
                currentUserId: {{ currentUser.id }},
                currentUserName: '{{ currentUser.firstname }} {{ currentUser.lastname }}'
            });

            // Board tabs menu functionality
            var currentOpenDropdown = null;

            // Toggle dropdown menu
            document.querySelectorAll('.board-tab-menu-btn').forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    var boardId = this.getAttribute('data-board-id');
                    var dropdown = document.querySelector('.board-tab-dropdown[data-board-id="' + boardId + '"]');

                    // Close other dropdowns
                    document.querySelectorAll('.board-tab-dropdown').forEach(function(dd) {
                        if (dd !== dropdown) dd.style.display = 'none';
                    });

                    // Toggle current dropdown
                    if (dropdown.style.display === 'none' || !dropdown.style.display) {
                        dropdown.style.display = 'block';
                        currentOpenDropdown = dropdown;
                    } else {
                        dropdown.style.display = 'none';
                        currentOpenDropdown = null;
                    }
                });
            });

            // Close dropdown when clicking outside
            document.addEventListener('click', function(e) {
                if (currentOpenDropdown && !e.target.closest('.board-tab-dropdown') && !e.target.closest('.board-tab-menu-btn')) {
                    currentOpenDropdown.style.display = 'none';
                    currentOpenDropdown = null;
                }
            });

            // Rename board
            document.querySelectorAll('.rename-board-btn').forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    var boardId = this.getAttribute('data-board-id');
                    var tabItem = document.querySelector('.board-tab-item[data-board-id="' + boardId + '"]');
                    var tabLinkInner = tabItem.querySelector('.board-tab-link-inner');
                    var titleSpan = tabItem.querySelector('.board-tab-title');
                    var input = tabItem.querySelector('.board-tab-input');
                    var dropdown = document.querySelector('.board-tab-dropdown[data-board-id="' + boardId + '"]');

                    // Close dropdown
                    dropdown.style.display = 'none';
                    currentOpenDropdown = null;

                    // Show input, hide title
                    titleSpan.style.display = 'none';
                    input.style.display = 'inline-block';
                    input.focus();
                    input.select();

                    // Prevent link navigation
                    tabLinkInner.style.pointerEvents = 'none';

                    // Save on blur or Enter
                    var saveRename = function() {
                        var newTitle = input.value.trim();
                        if (newTitle && newTitle !== titleSpan.textContent.trim()) {
                            // Send rename request
                            fetch('/kanban/board/' + boardId + '/rename', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                    'X-Requested-With': 'XMLHttpRequest'
                                },
                                body: JSON.stringify({ title: newTitle })
                            })
                            .then(function(response) {
                                if (response.ok) {
                                    return response.json();
                                }
                                throw new Error('Ошибка переименования');
                            })
                            .then(function(data) {
                                if (data.success) {
                                    titleSpan.textContent = newTitle;
                                } else {
                                    input.value = titleSpan.textContent;
                                    alert('Ошибка: ' + (data.error || 'Не удалось переименовать доску'));
                                }
                            })
                            .catch(function(error) {
                                console.error('Error:', error);
                                input.value = titleSpan.textContent;
                                alert('Ошибка: ' + error.message);
                            });
                        } else {
                            input.value = titleSpan.textContent;
                        }

                        titleSpan.style.display = 'inline';
                        input.style.display = 'none';
                        tabLinkInner.style.pointerEvents = 'auto';
                    };

                    input.addEventListener('blur', saveRename, { once: true });
                    input.addEventListener('keydown', function(e) {
                        if (e.key === 'Enter') {
                            e.preventDefault();
                            input.blur();
                        } else if (e.key === 'Escape') {
                            input.value = titleSpan.textContent;
                            titleSpan.style.display = 'inline';
                            input.style.display = 'none';
                            tabLinkInner.style.pointerEvents = 'auto';
                        }
                    });
                });
            });

            // Delete board
            document.querySelectorAll('.delete-board-btn').forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    var boardId = this.getAttribute('data-board-id');
                    var dropdown = document.querySelector('.board-tab-dropdown[data-board-id="' + boardId + '"]');

                    // Close dropdown
                    dropdown.style.display = 'none';
                    currentOpenDropdown = null;

                    // Confirm deletion
                    if (confirm('Вы уверены, что хотите удалить эту доску? Это действие нельзя отменить.')) {
                        // Send delete request
                        fetch('/kanban/board/' + boardId + '/delete', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        })
                        .then(function(response) {
                            if (response.ok) {
                                return response.json();
                            }
                            throw new Error('Ошибка удаления');
                        })
                        .then(function(data) {
                            if (data.success) {
                                // Redirect to project boards list or another board
                                if (data.redirectUrl) {
                                    window.location.href = data.redirectUrl;
                                } else {
                                    window.location.href = '/kanban/personal-projects';
                                }
                            } else {
                                alert('Ошибка: ' + (data.error || 'Не удалось удалить доску'));
                            }
                        })
                        .catch(function(error) {
                            console.error('Error:', error);
                            alert('Ошибка: ' + error.message);
                        });
                    }
                });
            });

            // Card menu functionality
            var currentOpenCardDropdown = null;

            // Toggle card dropdown menu
            document.addEventListener('click', function(e) {
                var menuBtn = e.target.closest('.kanban-card-menu-btn');
                if (menuBtn) {
                    e.preventDefault();
                    e.stopPropagation();
                    e.stopImmediatePropagation();
                    var cardId = menuBtn.getAttribute('data-card-id');
                    var dropdown = document.querySelector('.kanban-card-dropdown[data-card-id="' + cardId + '"]');

                    // Move to <body> to fix position:fixed inside a CSS-transformed ancestor (.kanban-card has transform)
                    if (dropdown && dropdown.parentNode !== document.body) {
                        document.body.appendChild(dropdown);
                    }

                    // Close other dropdowns
                    document.querySelectorAll('.kanban-card-dropdown').forEach(function(dd) {
                        if (dd !== dropdown) dd.style.display = 'none';
                    });

                    // Toggle current dropdown
                    if (dropdown.style.display === 'none' || !dropdown.style.display) {
                        // Position dropdown relative to button
                        var rect = menuBtn.getBoundingClientRect();
                        var dropdownWidth = 200; // min-width from CSS
                        var dropdownHeight = dropdown.offsetHeight || 200;

                        // Calculate position
                        var top = rect.bottom + 4; // 4px gap
                        var left = rect.right - dropdownWidth;

                        // Adjust if dropdown goes off screen
                        var viewportWidth = window.innerWidth;
                        var viewportHeight = window.innerHeight;

                        // Check right edge
                        if (left < 10) {
                            left = rect.left;
                        }
                        if (left + dropdownWidth > viewportWidth - 10) {
                            left = viewportWidth - dropdownWidth - 10;
                        }

                        // Check bottom edge - open upwards if needed
                        if (top + dropdownHeight > viewportHeight - 10) {
                            top = rect.top - dropdownHeight - 4;
                            // If still off screen, position at bottom with scroll
                            if (top < 10) {
                                top = Math.max(10, viewportHeight - dropdownHeight - 10);
                            }
                        }

                        dropdown.style.top = top + 'px';
                        dropdown.style.left = left + 'px';
                        dropdown.style.display = 'block';
                        menuBtn.classList.add('active');
                        currentOpenCardDropdown = dropdown;
                    } else {
                        dropdown.style.display = 'none';
                        menuBtn.classList.remove('active');
                        currentOpenCardDropdown = null;
                    }
                    return false;
                }
            });

            // Prevent clicks inside dropdown from bubbling to card
            document.addEventListener('click', function(e) {
                var dropdown = e.target.closest('.kanban-card-dropdown');
                if (dropdown) {
                    e.stopPropagation();
                }
            });

            // Close card dropdown when clicking outside
            document.addEventListener('click', function(e) {
                if (currentOpenCardDropdown && !e.target.closest('.kanban-card-dropdown') && !e.target.closest('.kanban-card-menu-btn')) {
                    currentOpenCardDropdown.style.display = 'none';
                    currentOpenCardDropdown = null;
                    document.querySelectorAll('.kanban-card-menu-btn.active').forEach(function(btn) {
                        btn.classList.remove('active');
                    });
                }
            });

            // Change card color
            document.addEventListener('click', function(e) {
                var colorOption = e.target.closest('.card-color-option');
                if (colorOption) {
                    e.preventDefault();
                    e.stopPropagation();
                    e.stopImmediatePropagation();
                    var color = colorOption.getAttribute('data-color');
                    var dropdown = colorOption.closest('.kanban-card-dropdown');
                    var cardId = dropdown.getAttribute('data-card-id');
                    var card = document.querySelector('.kanban-card[data-card-id="' + cardId + '"]');

                    // Send color change request
                    fetch('/api/kanban/cards/' + cardId, {
                        method: 'PATCH',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify({ borderColor: color || null })
                    })
                    .then(function(response) {
                        if (response.ok) {
                            return response.json();
                        }
                        return response.json().then(function(data) {
                            throw new Error(data.error || 'Ошибка изменения цвета');
                        });
                    })
                    .then(function(data) {
                        // Update card color
                        card.removeAttribute('data-border-color');
                        if (data.borderColor) {
                            card.setAttribute('data-border-color', data.borderColor);
                        }
                    })
                    .catch(function(error) {
                        console.error('Error:', error);
                        alert('Ошибка: ' + error.message);
                    });

                    // Close menu
                    dropdown.style.display = 'none';
                    currentOpenCardDropdown = null;
                    document.querySelectorAll('.kanban-card-menu-btn.active').forEach(function(btn) {
                        btn.classList.remove('active');
                    });
                }
            });

            // Rename card
            document.addEventListener('click', function(e) {
                var renameBtn = e.target.closest('.rename-card-btn');
                if (renameBtn) {
                    e.preventDefault();
                    e.stopPropagation();
                    e.stopImmediatePropagation();
                    var cardId = renameBtn.getAttribute('data-card-id');
                    var card = document.querySelector('.kanban-card[data-card-id="' + cardId + '"]');
                    var titleDiv = card.querySelector('.kanban-card-title');
                    var dropdown = document.querySelector('.kanban-card-dropdown[data-card-id="' + cardId + '"]');
                    var originalTitle = titleDiv.textContent.trim();

                    // Close dropdown
                    dropdown.style.display = 'none';
                    currentOpenCardDropdown = null;
                    document.querySelectorAll('.kanban-card-menu-btn.active').forEach(function(btn) {
                        btn.classList.remove('active');
                    });

                    // Create input
                    var input = document.createElement('input');
                    input.type = 'text';
                    input.className = 'form-control form-control-sm';
                    input.value = originalTitle;
                    input.style.fontWeight = '600';
                    input.style.fontSize = '0.95rem';

                    titleDiv.style.display = 'none';
                    titleDiv.parentNode.insertBefore(input, titleDiv);
                    input.focus();
                    input.select();

                    var saveRename = function() {
                        var newTitle = input.value.trim();
                        if (newTitle && newTitle !== originalTitle) {
                            // Send rename request
                            fetch('/api/kanban/cards/' + cardId, {
                                method: 'PATCH',
                                headers: {
                                    'Content-Type': 'application/json',
                                    'X-Requested-With': 'XMLHttpRequest'
                                },
                                body: JSON.stringify({ title: newTitle })
                            })
                            .then(function(response) {
                                if (response.ok) {
                                    return response.json();
                                }
                                return response.json().then(function(data) {
                                    throw new Error(data.error || 'Ошибка переименования');
                                });
                            })
                            .then(function(data) {
                                // Update title with the response data
                                titleDiv.textContent = data.title;
                            })
                            .catch(function(error) {
                                console.error('Error:', error);
                                alert('Ошибка: ' + error.message);
                            });
                        }

                        input.remove();
                        titleDiv.style.display = 'block';
                    };

                    input.addEventListener('blur', saveRename);
                    input.addEventListener('keydown', function(e) {
                        if (e.key === 'Enter') {
                            e.preventDefault();
                            input.blur();
                        } else if (e.key === 'Escape') {
                            input.remove();
                            titleDiv.style.display = 'block';
                        }
                    });
                }
            });

            // Delete card
            document.addEventListener('click', function(e) {
                var deleteBtn = e.target.closest('.delete-card-btn');
                if (deleteBtn) {
                    e.preventDefault();
                    e.stopPropagation();
                    e.stopImmediatePropagation();
                    var cardId = deleteBtn.getAttribute('data-card-id');
                    var card = document.querySelector('.kanban-card[data-card-id="' + cardId + '"]');
                    var dropdown = document.querySelector('.kanban-card-dropdown[data-card-id="' + cardId + '"]');

                    // Close dropdown
                    dropdown.style.display = 'none';
                    currentOpenCardDropdown = null;

                    // Confirm deletion
                    if (confirm('Вы уверены, что хотите удалить эту карточку?')) {
                        // Send delete request
                        fetch('/api/kanban/cards/' + cardId, {
                            method: 'DELETE',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        })
                        .then(function(response) {
                            if (response.ok || response.status === 204) {
                                // Remove card and its dropdown from DOM
                                card.remove();
                                if (dropdown && dropdown.parentNode) dropdown.remove();
                                // Update column counter
                                var column = card.closest('.kanban-column');
                                if (column) {
                                    var counter = column.querySelector('.column-count');
                                    if (counter) {
                                        var count = parseInt(counter.textContent) - 1;
                                        counter.textContent = count;
                                    }
                                }
                            } else {
                                return response.json().then(function(data) {
                                    throw new Error(data.error || 'Не удалось удалить карточку');
                                });
                            }
                        })
                        .catch(function(error) {
                            console.error('Error:', error);
                            alert('Ошибка: ' + error.message);
                        });
                    }
                }
            });
        });
    </script>
{% endblock %}
