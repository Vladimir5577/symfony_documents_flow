                {# Subtasks Tab #}
                <div class="task-sidebar-tab-pane" id="pane-subtasks" role="tabpanel" hidden>
                    <div class="task-subtasks-pane">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="mb-0">Подзадачи</h6>
