{% extends 'base_dashboard.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block sidebar_list %}
    {% include 'sidebar/sidebar_list.html.twig' %}
{% endblock %}

{% block main %}

    <style>
        /* --- Появление блоков --- */
        @keyframes fadeSlideUp {
            from { opacity: 0; transform: translateY(24px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .dash-animate {
            animation: fadeSlideUp .5s cubic-bezier(.22,1,.36,1) both;
        }
        .dash-animate-d1 { animation-delay: .05s; }
        .dash-animate-d2 { animation-delay: .15s; }
        .dash-animate-d3 { animation-delay: .25s; }

        /* --- Приветствие --- */
        .dash-greeting {
            font-size: 1.5rem;
            font-weight: 700;
        }
        .dash-search {
            max-width: 260px;
        }
        .dash-search .form-control {
            border-radius: 0.5rem;
            padding-left: 2.25rem;
            transition: box-shadow .25s, border-color .25s;
        }
        .dash-search .form-control:focus {
            box-shadow: 0 0 0 3px rgba(67,94,190,.18);
        }
        .dash-search .search-icon {
            position: absolute;
            left: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--bs-secondary-color);
            pointer-events: none;
            transition: color .2s;
        }
        .dash-search .form-control:focus ~ .search-icon,
        .dash-search:focus-within .search-icon {
            color: var(--bs-primary);
        }

        /* --- Новости --- */
        .dash-section-title {
            font-size: 1.25rem;
            font-weight: 700;
            border-left: 3px solid var(--bs-primary);
            padding-left: 0.75rem;
        }
        .news-header-bar {
            background: color-mix(in srgb, var(--bs-primary) 8%, var(--bs-body-bg));
            border-bottom: 2px solid color-mix(in srgb, var(--bs-primary) 25%, var(--bs-border-color));
            border-radius: 0.5rem 0.5rem 0 0;
            padding: 0.85rem 1rem;
            margin-bottom: 0.75rem;
        }
        .news-carousel-wrap {
            position: relative;
            margin: -0.75rem 0;
        }
        .news-carousel {
            display: flex;
            gap: 1rem;
            overflow-x: auto;
            overflow-y: visible;
            scroll-behavior: smooth;
            scrollbar-width: none;
            -ms-overflow-style: none;
            padding: 0.75rem 0;
        }
        .news-carousel::-webkit-scrollbar { display: none; }
        .news-card {
            flex: 0 0 260px;
            min-width: 260px;
            border-radius: 0.75rem;
            overflow: hidden;
            background: var(--bs-body-bg);
            border: 1px solid var(--bs-border-color);
            transition: transform .3s cubic-bezier(.22,1,.36,1), box-shadow .3s ease, border-color .3s;
            cursor: pointer;
        }
        .news-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 32px rgba(0,0,0,.14);
            border-color: var(--bs-primary);
        }
        .news-card-img {
            width: 100%;
            height: 140px;
            object-fit: cover;
            display: block;
            background: var(--bs-secondary-bg);
            transition: transform .4s cubic-bezier(.22,1,.36,1);
        }
        .news-card:hover .news-card-img {
            transform: scale(1.06);
        }
        .news-card-body {
            padding: 0.75rem 1rem;
        }
        .news-card-badge {
            display: inline-block;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            padding: 0.2rem 0.6rem;
            border-radius: 0.25rem;
            color: #fff;
            position: absolute;
            top: 0.75rem;
            left: 0.75rem;
            transition: transform .3s cubic-bezier(.22,1,.36,1), box-shadow .3s;
        }
        .news-card:hover .news-card-badge {
            transform: scale(1.08);
            box-shadow: 0 2px 8px rgba(0,0,0,.2);
        }
        .news-card-badge--news       { background: #198754; }
        .news-card-badge--event      { background: #0d6efd; }
        .news-card-badge--order      { background: #6f42c1; }
        .news-card-badge--important  { background: #dc3545; }
        .news-card-badge--instruction { background: #fd7e14; }
        .news-card-badge--regulation { background: #20c997; }
        .news-card-badge--disposition { background: #0dcaf0; }
        .news-card-title {
            font-size: 0.95rem;
            font-weight: 600;
            margin-bottom: 0.35rem;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            transition: color .2s;
        }
        .news-card:hover .news-card-title {
            color: var(--bs-primary);
        }
        .news-card-date {
            font-size: 0.8rem;
            color: var(--bs-secondary-color);
        }
        .news-card-img-wrap {
            position: relative;
            overflow: hidden;
        }
        .news-nav-btn {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: 1px solid var(--bs-border-color);
            background: var(--bs-body-bg);
            color: var(--bs-body-color);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all .25s cubic-bezier(.22,1,.36,1);
        }
        .news-nav-btn:hover {
            background: var(--bs-primary);
            color: #fff;
            border-color: var(--bs-primary);
            transform: scale(1.12);
            box-shadow: 0 4px 12px rgba(67,94,190,.3);
        }
        .news-nav-btn:active {
            transform: scale(0.95);
        }

        /* --- Панели (Чат / Уведомления) --- */
        .dash-panel {
            background: var(--bs-body-bg);
            border: 1px solid var(--bs-border-color);
            border-radius: 0.75rem;
            padding: 1.25rem;
            height: 100%;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            overflow-y: visible;
            transition: box-shadow .3s, border-color .3s;
        }
        .dash-panel:hover {
            box-shadow: 0 8px 28px rgba(0,0,0,.08);
            border-color: color-mix(in srgb, var(--bs-primary) 30%, var(--bs-border-color));
        }
        .dash-panel-title {
            font-size: 1.1rem;
            font-weight: 700;
            border-left: 3px solid var(--bs-primary);
            padding-left: 0.65rem;
        }

        /* --- Telegram-style Chat --- */
        .chat-container {
            display: flex;
            border: 1px solid var(--bs-border-color);
            border-radius: 0.75rem;
            overflow: hidden;
            background: var(--bs-body-bg);
            height: calc(100vh - 280px);
            min-height: 450px;
        }
        .chat-sidebar {
            width: 320px;
            min-width: 320px;
            border-right: 1px solid var(--bs-border-color);
            display: flex;
            flex-direction: column;
            background: var(--bs-body-bg);
        }
        .chat-sidebar-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.85rem 1rem;
            border-bottom: 1px solid var(--bs-border-color);
        }
        .chat-sidebar-search {
            padding: 0.5rem 0.75rem;
            border-bottom: 1px solid var(--bs-border-color);
        }
        .chat-sidebar-search .form-control {
            border-radius: 1rem;
            font-size: 0.85rem;
        }
        .chat-room-list {
            flex: 1;
            overflow-y: auto;
        }
        .chat-room-item {
            display: flex;
            gap: 0.75rem;
            padding: 0.75rem 1rem;
            cursor: pointer;
            border-bottom: 1px solid color-mix(in srgb, var(--bs-border-color) 50%, transparent);
            transition: background .15s;
        }
        .chat-room-item:hover { background: color-mix(in srgb, var(--bs-primary) 5%, var(--bs-body-bg)); }
        .chat-room-item.active { background: color-mix(in srgb, var(--bs-primary) 12%, var(--bs-body-bg)); }
        .chat-room-avatar {
            width: 46px; height: 46px; border-radius: 50%;
            background: color-mix(in srgb, var(--bs-primary) 15%, var(--bs-body-bg));
            flex-shrink: 0; display: flex; align-items: center; justify-content: center;
            font-weight: 600; font-size: 0.85rem; color: var(--bs-primary);
            overflow: hidden;
        }
        .chat-room-info { flex: 1; min-width: 0; }
        .chat-room-name { font-weight: 600; font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 160px; display: inline-block; }
        .chat-room-time { font-size: 0.72rem; color: var(--bs-secondary-color); }
        .chat-room-preview { font-size: 0.82rem; color: var(--bs-secondary-color); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 180px; display: inline-block; }
        .chat-room-badge {
            display: inline-flex; align-items: center; justify-content: center;
            min-width: 20px; height: 20px; border-radius: 10px;
            background: var(--bs-primary); color: #fff;
            font-size: 0.7rem; font-weight: 700; padding: 0 6px;
        }
        .chat-main { flex: 1; display: flex; flex-direction: column; min-width: 0; }
        .chat-placeholder {
            flex: 1; display: flex; flex-direction: column;
            align-items: center; justify-content: center;
        }
        .chat-main-inner { display: flex; flex-direction: column; height: 100%; }
        .chat-main-header {
            display: flex; align-items: center;
            padding: 0.85rem 1rem;
            border-bottom: 1px solid var(--bs-border-color);
            background: var(--bs-body-bg);
        }
        .chat-messages-area {
            flex: 1; overflow-y: auto; padding: 1rem;
            display: flex; flex-direction: column; gap: 0.5rem;
            position: relative;
        }
        .chat-input-bar {
            display: flex; align-items: center; gap: 0.5rem;
            padding: 0.75rem 1rem;
            border-top: 1px solid var(--bs-border-color);
        }
        .chat-input-bar .form-control { border-radius: 1.5rem; }

        /* Bubbles */
        .chat-bubble {
            max-width: 70%; padding: 0.55rem 0.85rem;
            border-radius: 1rem; position: relative;
            font-size: 0.9rem; word-wrap: break-word;
        }
        .chat-bubble-mine {
            align-self: flex-end;
            background: color-mix(in srgb, var(--bs-primary) 15%, var(--bs-body-bg));
            border-bottom-right-radius: 0.25rem;
        }
        .chat-bubble-other {
            align-self: flex-start;
            background: var(--bs-secondary-bg);
            border-bottom-left-radius: 0.25rem;
        }
        .chat-bubble-text { white-space: pre-wrap; word-break: break-word; }
        .chat-bubble-mine .chat-bubble-text { padding-right: 1.2rem; }
        .chat-bubble-time { font-size: 0.68rem; color: var(--bs-secondary-color); text-align: right; margin-top: 2px; }
        .chat-bubble-files { margin-top: 4px; }
        .chat-file-link { display: block; font-size: 0.82rem; text-decoration: none; }
        .chat-file-link:hover { text-decoration: underline; }
        .chat-deleted { color: var(--bs-secondary-color); font-style: italic; font-size: 0.85rem; }
        .chat-delete-btn {
            position: absolute; top: 4px; right: 4px;
            background: none; border: none; color: var(--bs-secondary-color);
            cursor: pointer; font-size: 0.75rem; opacity: 0;
            transition: opacity .15s;
        }
        .chat-bubble:hover .chat-delete-btn { opacity: 1; }
        .chat-delete-btn:hover { color: var(--bs-danger); }

        /* 3-dot action menu */
        .chat-msg-actions {
            position: absolute; top: 4px; right: 4px;
            opacity: 0; transition: opacity .15s;
        }
        .chat-bubble:hover .chat-msg-actions { opacity: 1; }
        .chat-actions-btn {
            background: none; border: none; color: var(--bs-secondary-color);
            cursor: pointer; font-size: 0.85rem; padding: 2px 4px; border-radius: 4px;
            transition: background .15s, color .15s;
        }
        .chat-actions-btn:hover { background: rgba(0,0,0,.08); color: var(--bs-body-color); }
        .chat-actions-menu {
            display: none; position: absolute; right: 0; top: 100%;
            background: var(--bs-body-bg); border: 1px solid var(--bs-border-color);
            border-radius: 0.5rem; box-shadow: 0 4px 16px rgba(0,0,0,.12);
            min-width: 160px; z-index: 10; overflow: hidden;
        }
        .chat-actions-menu.open { display: block; }
        .chat-action-item {
            display: flex; align-items: center; gap: 0.5rem;
            width: 100%; padding: 0.5rem 0.85rem; border: none;
            background: none; font-size: 0.85rem; cursor: pointer;
            color: var(--bs-body-color); transition: background .15s;
        }
        .chat-action-item:hover { background: rgba(0,0,0,.06); }
        .chat-action-delete { color: var(--bs-danger); }
        .chat-action-delete:hover { background: rgba(220,53,69,.08); }

        /* Edit mode */
        .chat-edit-input {
            font-size: 0.85rem; border-radius: 0.5rem; resize: none;
        }
        .chat-edit-buttons { display: flex; gap: 0.25rem; }

        /* Edited label */
        .chat-edited-label {
            font-style: italic; opacity: 0.7;
        }

        /* User popover */
        .chat-user-popover {
            position: absolute; z-index: 100;
            width: 280px;
            background: var(--bs-body-bg);
            border: 1px solid var(--bs-border-color);
            border-radius: 0.75rem;
            box-shadow: 0 8px 24px rgba(0,0,0,.15);
            animation: chatPopoverIn .15s ease-out;
            overflow: hidden;
        }
        @keyframes chatPopoverIn {
            from { opacity: 0; transform: translateY(6px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .chat-popover-header {
            display: flex; align-items: center; gap: 0.75rem;
            padding: 0.85rem;
        }
        .chat-popover-avatar {
            width: 48px; height: 48px; border-radius: 50%;
            flex-shrink: 0; object-fit: cover;
        }
        .chat-popover-avatar-initials {
            width: 48px; height: 48px; border-radius: 50%;
            flex-shrink: 0; display: flex; align-items: center; justify-content: center;
            background: #e0e0e0; font-weight: 600; font-size: 1rem;
        }
        .chat-popover-name { font-weight: 600; font-size: 0.95rem; line-height: 1.2; }
        .chat-popover-profession { font-size: 0.8rem; color: var(--bs-secondary-color); }
        .chat-popover-lastseen { font-size: 0.75rem; color: var(--bs-success); }
        .chat-popover-lastseen.offline { color: var(--bs-secondary-color); }
        .chat-popover-body {
            padding: 0 0.85rem 0.75rem;
            border-top: 1px solid var(--bs-border-color);
        }
        .chat-popover-row {
            display: flex; align-items: center; gap: 0.5rem;
            padding: 0.4rem 0; font-size: 0.82rem;
            color: var(--bs-body-color);
        }
        .chat-popover-row i { color: var(--bs-secondary-color); width: 16px; text-align: center; }
        .chat-popover-footer {
            padding: 0 0.85rem 0.75rem;
        }
        .chat-popover-footer .btn { font-size: 0.82rem; }
        .chat-room-avatar[data-user-id] { cursor: pointer; }
        .chat-room-avatar[data-user-id]:hover {
            box-shadow: 0 0 0 2px var(--bs-primary);
        }
        .chat-bubble-sender { font-size: 0.78rem; font-weight: 600; color: var(--bs-primary); margin-bottom: 2px; cursor: pointer; }
        .chat-body-wrap {
            flex: 1; display: flex; overflow: hidden; min-height: 0;
        }
        .chat-body-wrap .chat-messages-area {
            flex: 1;
        }
        .chat-participants-panel {
            width: 260px; min-width: 260px;
            border-left: 1px solid var(--bs-border-color);
            display: flex; flex-direction: column;
            background: var(--bs-body-bg);
        }
        .chat-participants-header {
            display: flex; justify-content: space-between; align-items: center;
            padding: 0.75rem 0.85rem;
            border-bottom: 1px solid var(--bs-border-color);
        }
        .chat-participants-list {
            flex: 1; overflow-y: auto; padding: 0.5rem 0;
        }
        .chat-participant-item {
            display: flex; align-items: center; gap: 0.6rem;
            padding: 0.5rem 0.85rem;
            transition: background .15s;
        }
        .chat-participant-item:hover { background: rgba(0,0,0,.04); }
        .chat-participant-avatar {
            width: 34px; height: 34px; border-radius: 50%;
            background: color-mix(in srgb, var(--bs-primary) 15%, var(--bs-body-bg));
            flex-shrink: 0; display: flex; align-items: center; justify-content: center;
            font-weight: 600; font-size: 0.75rem; color: var(--bs-primary);
            overflow: hidden;
        }
        .chat-participant-avatar img {
            width: 100%; height: 100%; object-fit: cover;
        }
        .chat-participant-name {
            flex: 1; font-size: 0.85rem; font-weight: 500;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .chat-participant-creator {
            font-size: 0.7rem; color: var(--bs-primary); font-weight: 600;
        }
        .chat-participant-remove {
            background: none; border: none; color: var(--bs-secondary-color);
            cursor: pointer; font-size: 0.85rem; opacity: 0; transition: opacity .15s, color .15s;
            padding: 2px 4px;
        }
        .chat-participant-item:hover .chat-participant-remove { opacity: 1; }
        .chat-participant-remove:hover { color: var(--bs-danger); }
        .chat-participants-actions {
            padding: 0.65rem 0.85rem;
            border-top: 1px solid var(--bs-border-color);
        }
        @media (max-width: 991.98px) {
            .chat-participants-panel {
                position: absolute; right: 0; top: 0; bottom: 0;
                z-index: 5; box-shadow: -4px 0 16px rgba(0,0,0,.1);
            }
        }

        /* Mobile responsive */
        @media (max-width: 991.98px) {
            .chat-container { height: calc(100vh - 200px); }
            .chat-sidebar { width: 100%; min-width: 100%; }
            .chat-main { display: none; }
            .chat-container.chat-room-open .chat-sidebar { display: none; }
            .chat-container.chat-room-open .chat-main { display: flex; }
        }

        /* --- Кнопка Добавить пост --- */
        .btn-add-post {
            transition: transform .2s cubic-bezier(.22,1,.36,1), box-shadow .2s;
        }
        .btn-add-post:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 14px rgba(67,94,190,.35);
        }
        .btn-add-post:active {
            transform: translateY(0) scale(0.97);
        }
    </style>

