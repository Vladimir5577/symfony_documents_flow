    <!-- Чат (Telegram-style) -->
    <div class="dash-animate dash-animate-d3">
        <div id="chat-container" class="chat-container">
            <!-- Sidebar -->
            <div class="chat-sidebar">
                <div class="chat-sidebar-header">
                    <h3 class="dash-panel-title mb-0">Чат</h3>
                    <div class="d-flex gap-1">
                        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#chatNewPrivateModal" title="Новый чат">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                        {% if is_granted('ROLE_MANAGER') %}
                            <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#chatNewGroupModal" title="Новая группа">
                                <i class="bi bi-people-fill"></i>
                            </button>
                        {% endif %}
                    </div>
                </div>
                <div class="chat-sidebar-search">
                    <input type="text" id="chat-room-search" class="form-control form-control-sm" placeholder="Поиск чатов...">
                </div>
                <div class="chat-room-list" id="chat-room-list">
                    <div class="text-muted small p-3 text-center">Загрузка...</div>
                </div>
            </div>

            <!-- Main chat area -->
            <div class="chat-main">
                <div id="chat-placeholder" class="chat-placeholder">
                    <i class="bi bi-chat-text" style="font-size:3rem;opacity:.3"></i>
                    <p class="text-muted mt-2">Выберите чат для начала переписки</p>
                </div>
                <div id="chat-main-panel" class="chat-main-inner d-none">
                    <div class="chat-main-header">
                        <button class="btn btn-sm btn-light d-lg-none me-2" id="chat-back-btn"><i class="bi bi-arrow-left"></i></button>
                        <h5 class="mb-0 flex-grow-1" id="chat-header-title">Чат</h5>
                        <button class="btn btn-sm btn-outline-secondary d-none" id="chat-participants-btn" title="Участники"><i class="bi bi-people"></i> <span id="chat-participants-count"></span></button>
                    </div>
                    <div class="chat-body-wrap">
                        <div class="chat-messages-area" id="chat-messages-area"></div>
                        <!-- Participants panel (slide-out) -->
                        <div class="chat-participants-panel d-none" id="chat-participants-panel">
                            <div class="chat-participants-header">
                                <h6 class="mb-0">Участники</h6>
                                <button class="btn btn-sm btn-light" id="chat-participants-close"><i class="bi bi-x-lg"></i></button>
                            </div>
                            <div class="chat-participants-list" id="chat-participants-list"></div>
                            <div class="chat-participants-actions d-none" id="chat-participants-actions">
                                <button class="btn btn-sm btn-outline-primary w-100" id="chat-add-participant-btn"><i class="bi bi-person-plus"></i> Добавить участника</button>
                            </div>
                        </div>
                    </div>
                    <div class="chat-input-bar">
                        <button class="btn btn-sm btn-light" type="button" id="chat-file-btn" title="Прикрепить файл"><i class="bi bi-paperclip"></i></button>
                        <input type="file" id="chat-file-input" multiple accept=".doc,.docx,.xls,.xlsx,.pdf,.png,.jpg,.jpeg" style="display:none">
                        <input type="text" class="form-control" id="chat-message-input" placeholder="Написать сообщение...">
                        <button class="btn btn-sm btn-primary" type="button" id="chat-send-btn"><i class="bi bi-send-fill"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Org tree data for chat modals #}
    <div id="chat-org-tree-data" data-users-url-template="{{ path('app_document_org_users', {'id': 0})|replace({'0':'__ORG__'}) }}" data-users-search-url="{{ path('app_document_users_search') }}" class="d-none">
        {% if organizations is defined and organizations|length > 0 %}
            {% for org in organizations %}
                {% if org %}
                    {% include 'document/_organization_tree_data.html.twig' with {'organization': org} %}
                {% endif %}
            {% endfor %}
        {% endif %}
    </div>

    {% include 'chat/partials/_new_chat_modal.html.twig' %}
    {% include 'chat/partials/_new_group_modal.html.twig' %}

    <script>
        window.__chatConfig = {
            mercureUrl: '{{ mercure_public_url }}',
            currentUserId: {{ current_user_id }},
        };
    </script>
    <script src="/front_end/assets/static/js/chat.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var carousel = document.getElementById('newsCarousel');
            var leftBtn = document.getElementById('newsScrollLeft');
            var rightBtn = document.getElementById('newsScrollRight');
            if (!carousel || !leftBtn || !rightBtn) return;
            var scrollAmount = 280;
            leftBtn.addEventListener('click', function () { carousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' }); });
            rightBtn.addEventListener('click', function () { carousel.scrollBy({ left: scrollAmount, behavior: 'smooth' }); });
        });
    </script>

{% endblock %}
