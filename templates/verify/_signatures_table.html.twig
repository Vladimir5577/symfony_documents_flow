{# Список подписей с результатами проверки. Ожидает: result (DocumentVerificationResult) #}
{% if result.signatures is empty %}
    <p class="text-muted mb-0">Подписей нет.</p>
{% else %}
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
            <tr>
                <th>Подписант</th>
                <th>Вид подписи</th>
                <th>Дата и время</th>
                <th>Сертификат</th>
                <th>Результат проверки</th>
            </tr>
            </thead>
            <tbody>
            {% for item in result.signatures %}
                {% set s = item.signature %}
                <tr>
                    <td>
                        {{ s.signer ? (s.signer.lastname ~ ' ' ~ s.signer.firstname ~ ' ' ~ (s.signer.patronymic ?? ''))|trim : '—' }}
                    </td>
                    <td>{{ s.level ? s.level.label : '—' }}</td>
                    <td>{{ s.signedAt ? s.signedAt|date('d.m.Y H:i:s') : '—' }}</td>
                    <td>{{ s.certificate ? s.certificate.serialNumber : '—' }}</td>
                    <td>
                        {% if item.valid %}
                            <span class="badge bg-success">Подпись действительна</span>
                            {% if item.details.revokedAfterSigning is defined %}
                                <div class="small text-muted mt-1">Сертификат отозван после подписания</div>
                            {% endif %}
                        {% else %}
                            <span class="badge bg-danger">Подпись недействительна</span>
                            {% if item.reason %}
                                <div class="small text-muted mt-1">Причина: {{ item.reason }}</div>
                            {% endif %}
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="mt-3">
        {% if result.allValid %}
            <div class="alert alert-success mb-0">Все подписи документа действительны.</div>
        {% else %}
            <div class="alert alert-danger mb-0">Проверка не пройдена: есть недействительные подписи либо документ изменён.</div>
        {% endif %}
    </div>
{% endif %}
